@page "/supervisor/timesheet/{EmployeeId:int}"
@page "/supervisor/timesheet/{EmployeeId:int}/{PeriodOffset:int}"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@attribute [Authorize(Policy = "RequireSupervisor")]
@using NewHeights.TimeClock.Shared.Audit
@using NewHeights.TimeClock.Shared.Constants
@using NewHeights.TimeClock.Shared.Enums
@using NewHeights.TimeClock.Data
@using NewHeights.TimeClock.Data.Entities
@using NewHeights.TimeClock.Web.Services
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@inject IDbContextFactory<TimeClockDbContext> DbFactory
@inject ITimesheetService TimesheetService
@inject IPayPeriodService PayPeriodService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ILogger<SupervisorTimesheetView> Logger
@inject IEmailService EmailService
@inject IAuditService Audit

<PageTitle>Review Time Sheet - @employeeName</PageTitle>

<div class="supervisor-review-page">
    <nav class="breadcrumb">
        <a href="/supervisor/timesheets">← Back to Team Timesheets</a>
    </nav>

    <header class="review-header">
        <div class="employee-card">
            @if (!string.IsNullOrEmpty(employeePhotoBase64))
            {
                <img src="data:image/jpeg;base64,@employeePhotoBase64" alt="@employeeName" class="employee-photo" />
            }
            else
            {
                <div class="employee-photo-placeholder">@employeeInitials</div>
            }
            <div class="employee-details">
                <h1>@employeeName</h1>
                <p class="employee-meta">ID: @employeeIdNumber • @employeePosition</p>
                <p class="employee-meta">Supervisor: @supervisorName</p>
            </div>
        </div>
        <div class="period-info">
            <div class="period-nav">
                <label for="sup-pp-picker" class="pp-label">Pay Period:</label>
                <select id="sup-pp-picker" class="btn-nav pp-select"
                        value="@selectedPayPeriodId"
                        @onchange="OnPayPeriodChangedAsync"
                        disabled="@isLoading">
                    @foreach (var p in availablePeriods)
                    {
                        <option value="@p.PayPeriodId">
                            @p.PeriodName (@p.StartDate.ToString("MMM d") – @p.EndDate.ToString("MMM d, yyyy"))
                            @(p.IsOpen ? " · Current" : "")
                        </option>
                    }
                </select>
            </div>
            <div class="status-summary">
                <span class="status-item @(employeeApproved ? "approved" : "pending")">
                    Employee: @(employeeApproved ? "✓ Submitted" : "⏳ Pending")
                </span>
                <span class="status-item @(supervisorApproved ? "approved" : "pending")">
                    Supervisor: @(supervisorApproved ? "✓ Approved" : "⏳ Pending")
                </span>
            </div>
        </div>
    </header>

    @if (isLoading)
    {
        <div class="loading">Loading time sheet...</div>
    }
    else if (payPeriodTimesheet != null)
    {
        <div class="period-summary-cards">
            <div class="summary-card">
                <span class="card-value">@payPeriodTimesheet.TotalHours.ToString("F2")</span>
                <span class="card-label">Total Hours</span>
            </div>
            <div class="summary-card">
                <span class="card-value">@payPeriodTimesheet.TotalRegularHours.ToString("F2")</span>
                <span class="card-label">Regular</span>
            </div>
            <div class="summary-card overtime">
                <span class="card-value">@payPeriodTimesheet.TotalOvertimeHours.ToString("F2")</span>
                <span class="card-label">Overtime</span>
            </div>
            <div class="summary-card">
                <span class="card-value">@payPeriodTimesheet.DaysWorked</span>
                <span class="card-label">Days Worked</span>
            </div>
            <div class="summary-card @(payPeriodTimesheet.ExceptionCount > 0 ? "warning" : "")">
                <span class="card-value">@payPeriodTimesheet.ExceptionCount</span>
                <span class="card-label">Exceptions</span>
            </div>
        </div>

        @foreach (var week in payPeriodTimesheet.Weeks)
        {
            <div class="week-section">
                <div class="week-header">
                    <h3>Week of @week.WeekStartDate.ToString("MMMM d") - @week.WeekEndDate.ToString("MMMM d")</h3>
                    <span class="week-total">@week.TotalHours.ToString("F2") hours</span>
                </div>
                
                <table class="timesheet-table">
                    <thead>
                        <tr>
                            <th class="col-date">Date</th>
                            <th class="col-status">AM</th>
                            <th class="col-status">PM</th>
                            <th class="col-status">Evening</th>
                            <th class="col-hours">Hours</th>
                            <th class="col-hours">Holiday</th>
                            <th class="col-actions">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var day in week.Days)
                        {
                            var amStatus = GetShiftStatus(day, "AM");
                            var pmStatus = GetShiftStatus(day, "PM");
                            var eveningStatus = GetShiftStatus(day, "Evening");
                            var holidayHours = GetHolidayHours(day);
                            var isHoliday = holidayHours > 0;
                            var holidayName = GetHolidayName(day);
                            var isExpanded = expandedDays.Contains(day.Date);

                            <tr class="day-row @(day.HasException ? "has-exception" : "") @(isHoliday ? "holiday-row" : "") @(isExpanded ? "expanded" : "")"
                                @onclick="() => ToggleDayExpand(day.Date)"
                                style="cursor: pointer;">
                                <td class="col-date">
                                    <span class="expand-icon">@(isExpanded ? "▼" : "▶")</span>
                                    <span class="day-name">@day.DayOfWeek.Substring(0, 3)</span>
                                    <span class="day-date">@day.Date.ToString("M/d")</span>
                                    @if (isHoliday)
                                    {
                                        <span class="holiday-badge" title="@holidayName">@holidayName</span>
                                    }
                                    @* Arrival + departure summary on the
                                       collapsed row (matches MyTimesheet). *@
                                    @if (day.FirstIn != null || day.LastOut != null)
                                    {
                                        <div class="day-inout">
                                            @if (day.FirstIn != null)
                                            {
                                                <span class="inout-in" title="First clock-in">In @day.FirstIn.PunchTime.ToString("h:mm tt")</span>
                                            }
                                            @if (day.FirstIn != null && day.LastOut != null)
                                            {
                                                <span class="inout-sep">·</span>
                                            }
                                            @if (day.LastOut != null)
                                            {
                                                <span class="inout-out" title="Last clock-out">Out @day.LastOut.PunchTime.ToString("h:mm tt")</span>
                                            }
                                            else if (day.FirstIn != null)
                                            {
                                                <span class="inout-open" title="Still clocked in">(still in)</span>
                                            }
                                        </div>
                                    }
                                </td>
                                <td class="col-status">
                                    @if (isHoliday)
                                    {
                                        <span class="status-pill holiday">Holiday</span>
                                    }
                                    else
                                    {
                                        <span class="status-pill @amStatus.ToLower().Replace(" ", "-")">@amStatus</span>
                                    }
                                </td>
                                <td class="col-status">
                                    @if (isHoliday)
                                    {
                                        <span class="status-pill holiday">Holiday</span>
                                    }
                                    else
                                    {
                                        <span class="status-pill @pmStatus.ToLower().Replace(" ", "-")">@pmStatus</span>
                                    }
                                </td>
                                <td class="col-status">
                                    @if (isHoliday)
                                    {
                                        <span class="status-pill holiday">Holiday</span>
                                    }
                                    else
                                    {
                                        <span class="status-pill @eveningStatus.ToLower().Replace(" ", "-")">@eveningStatus</span>
                                    }
                                </td>
                                <td class="col-hours">
                                    <span class="hours-value">@day.TotalHours.ToString("F2")</span>
                                    @if (day.OvertimeHours > 0)
                                    {
                                        <span class="ot-badge">+@day.OvertimeHours.ToString("F2") OT</span>
                                    }
                                </td>
                                <td class="col-hours @(isHoliday ? "holiday-hours" : "")">
                                    @holidayHours.ToString("F2")
                                </td>
                                <td class="col-actions">
                                    @if (day.HasException)
                                    {
                                        <span class="exception-flag" title="@day.ExceptionNotes">⚠️</span>
                                    }
                                    @if (HasPendingCorrectionForDay(day.Date))
                                    {
                                        <span class="correction-flag" title="Employee correction request pending">📝</span>
                                    }
                                    <button class="btn-edit" @onclick="() => OpenEditDay(day)" @onclick:stopPropagation="true" title="Edit">✏️</button>
                                </td>
                            </tr>

                            @* ── Drill-down: Punch detail row ────────────────────────── *@
                            @if (isExpanded)
                            {
                                <tr class="punch-detail-row">
                                    <td colspan="7">
                                        <div class="punch-detail-panel">
                                            @if (day.Punches.Any())
                                            {
                                                <table class="punch-pairs-table">
                                                    <thead>
                                                        <tr>
                                                            <th>Type</th>
                                                            <th>Actual Time</th>
                                                            <th>Rounded Time</th>
                                                            <th>Hours</th>
                                                            <th>Source</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var pair in GetPunchPairs(day))
                                                        {
                                                            <tr>
                                                                <td>
                                                                    <span class="punch-badge @pair.BadgeClass">@pair.Label</span>
                                                                </td>
                                                                <td>
                                                                    <span class="punch-time-in">@pair.InTime</span>
                                                                    <span class="punch-arrow">→</span>
                                                                    <span class="punch-time-out">@pair.OutTime</span>
                                                                </td>
                                                                <td>
                                                                    <span class="punch-time-rounded">@pair.RoundedIn</span>
                                                                    <span class="punch-arrow">→</span>
                                                                    <span class="punch-time-rounded">@pair.RoundedOut</span>
                                                                </td>
                                                                <td class="pair-hours">@pair.Hours</td>
                                                                <td>
                                                                    @if (pair.IsManual)
                                                                    {
                                                                        <span class="source-badge manual" title="Manual Entry">✎ Manual</span>
                                                                    }
                                                                    else if (pair.IsModified)
                                                                    {
                                                                        <span class="source-badge modified" title="Modified">✏️ Modified</span>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span class="source-badge auto">Badge</span>
                                                                    }
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            }
                                            else if (!isHoliday)
                                            {
                                                <p class="no-punches-detail">No punches recorded for this day.</p>
                                            }

                                            @if (isHoliday)
                                            {
                                                <div class="holiday-notice">
                                                    🎉 <strong>@holidayName</strong> — @holidayHours.ToString("F2") holiday hours credited
                                                </div>
                                            }

                                            @if (day.HasException)
                                            {
                                                <div class="exception-notice">
                                                    ⚠️ <strong>Exception:</strong> @day.ExceptionNotes
                                                </div>
                                            }

                                            @{
                                                var dayCorrectionRequests = employeeCorrectionRequests
                                                    .Where(cr => cr.WorkDate == day.Date).ToList();
                                            }
                                            @if (dayCorrectionRequests.Any())
                                            {
                                                <div class="day-correction-requests">
                                                    <h5>📝 Employee Correction Requests</h5>
                                                    @foreach (var cr in dayCorrectionRequests)
                                                    {
                                                        <div class="correction-request-card @cr.Status.ToString().ToLower()">
                                                            <div class="cr-header">
                                                                <span class="cr-type">@FormatRequestType(cr.RequestType)</span>
                                                                <span class="cr-status-badge @cr.Status.ToString().ToLower()">@cr.Status</span>
                                                            </div>
                                                            <div class="cr-details">
                                                                @if (cr.RequestedDateTime.HasValue)
                                                                {
                                                                    <span>Requested time: <strong>@cr.RequestedDateTime.Value.ToString("h:mm tt")</strong></span>
                                                                }
                                                                <p class="cr-reason">@cr.Reason</p>
                                                            </div>
                                                            @if (cr.Status == CorrectionRequestStatus.Submitted)
                                                            {
                                                                <div class="cr-actions">
                                                                    <button class="btn-approve-cr"
                                                                            @onclick="() => ApproveCorrectionRequest(cr)"
                                                                            @onclick:stopPropagation="true">✓ Approve</button>
                                                                    <button class="btn-deny-cr"
                                                                            @onclick="() => DenyCorrectionRequest(cr)"
                                                                            @onclick:stopPropagation="true">✗ Deny</button>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            }

                                            <div class="drill-down-actions">
                                                <button class="btn-edit-drill"
                                                        @onclick="() => OpenEditDay(day)"
                                                        @onclick:stopPropagation="true">
                                                    ✏️ Add Correction
                                                </button>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (PendingCorrectionRequests.Any())
        {
            <div class="corrections-queue-section">
                <h3>📝 Pending Correction Requests (@PendingCorrectionRequests.Count)</h3>
                <p class="section-subtitle">Employee-submitted requests awaiting your review</p>
                <table class="corrections-queue-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Type</th>
                            <th>Requested</th>
                            <th>Reason</th>
                            <th>Submitted</th>
                            <th style="width:140px">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cr in PendingCorrectionRequests)
                        {
                            <tr>
                                <td><strong>@cr.WorkDate.ToString("ddd M/d")</strong></td>
                                <td>@FormatRequestType(cr.RequestType)</td>
                                <td>@(cr.RequestedDateTime?.ToString("h:mm tt") ?? "—")</td>
                                <td>@cr.Reason</td>
                                <td>@cr.CreatedDate.ToString("M/d h:mm tt")</td>
                                <td>
                                    <div style="display:flex; gap:0.25rem;">
                                        <button class="btn-approve-cr" @onclick="() => ApproveCorrectionRequest(cr)">✓ Approve</button>
                                        <button class="btn-deny-cr" @onclick="() => DenyCorrectionRequest(cr)">✗ Deny</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (payPeriodTimesheet.ExceptionCount > 0)
        {
            <div id="exceptions" class="exceptions-section">
                <h3>⚠️ Exceptions Requiring Review</h3>
                <div class="exception-list">
                    @foreach (var week in payPeriodTimesheet.Weeks)
                    {
                        @foreach (var day in week.Days.Where(d => d.HasException))
                        {
                            <div class="exception-item">
                                <span class="exception-date">@day.Date.ToString("ddd M/d")</span>
                                <span class="exception-reason">@day.ExceptionNotes</span>
                                <button class="btn-resolve" @onclick="() => OpenEditDay(day)">Resolve</button>
                            </div>
                        }
                    }
                </div>
            </div>
        }

        <div class="approval-section">
            <h3>Supervisor Approval</h3>
            <div class="approval-box">
                @if (!employeeApproved)
                {
                    <div class="approval-warning">
                        <p>⚠️ This employee has not yet submitted their time sheet for this period.</p>
                        <button class="btn-remind" @onclick="SendReminder" disabled="@isSendingReminder">
                            @if (isSendingReminder)
                            {
                                <span>Sending...</span>
                            }
                            else
                            {
                                <span>📧 Send Reminder Email</span>
                            }
                        </button>
                        @if (!string.IsNullOrEmpty(reminderStatusMessage))
                        {
                            <div class="reminder-status @(reminderStatusIsError ? "error" : "success")" role="status" aria-live="polite">
                                @reminderStatusMessage
                            </div>
                        }
                    </div>
                }
                else if (supervisorApproved)
                {
                    <div class="already-approved">
                        <p>✓ Approved by @payPeriodTimesheet.SupervisorApprovedBy on @payPeriodTimesheet.SupervisorApprovedDate?.ToString("MMM d, yyyy h:mm tt")</p>
                    </div>
                }
                else
                {
                    <div class="approval-form">
                        <p>Review the time sheet above. If everything looks correct, approve to send to HR for final processing.</p>

                        @{
                            var unresolvedCount = payPeriodTimesheet.Weeks
                                .SelectMany(w => w.Days)
                                .Count(d => d.HasException);
                        }
                        @if (unresolvedCount > 0)
                        {
                            <div style="background:#fef3c7;border:1px solid #fde68a;color:#78350f;padding:0.6rem 0.75rem;border-radius:6px;margin:0.5rem 0;font-size:.9rem;">
                                ⚠️ <strong>@unresolvedCount exception@(unresolvedCount == 1 ? "" : "s") unresolved.</strong>
                                Resolve or acknowledge all exceptions before approving this time sheet.
                            </div>
                        }

                        <div class="supervisor-notes">
                            <label>Supervisor Notes (optional)</label>
                            <textarea @bind="supervisorNotes" placeholder="Add any notes about this time sheet..."></textarea>
                        </div>

                        <label class="approval-checkbox">
                            <input type="checkbox" @bind="approvalChecked" />
                            <span>I have reviewed this time sheet and confirm it is accurate</span>
                        </label>

                        <div class="approval-actions">
                            <button class="btn-approve" @onclick="ApproveTimesheet"
                                    disabled="@(!approvalChecked || isApproving || unresolvedCount > 0)">
                                @if (isApproving)
                                {
                                    <span>Approving...</span>
                                }
                                else
                                {
                                    <span>✓ Approve Time Sheet</span>
                                }
                            </button>
                            <button class="btn-reject" @onclick="OpenRejectModal">✗ Request Corrections</button>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@if (showEditModal && editingDay != null)
{
    <div class="modal-overlay" @onclick="CloseEditModal">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h2>Edit Time Entry - @editingDay.Date.ToString("dddd, MMMM d")</h2>
                <button class="modal-close" @onclick="CloseEditModal">✕</button>
            </div>
            <div class="modal-body">
                <div class="current-punches">
                    <h4>Current Punches</h4>
                    @if (editingDay.Punches.Any())
                    {
                        @foreach (var punch in editingDay.Punches)
                        {
                            <div class="punch-row">
                                <span class="punch-type">@FormatPunchType(punch.PunchType)</span>
                                <span class="punch-time">@punch.PunchTime.ToString("h:mm tt")</span>
                                @if (punch.IsManual)
                                {
                                    <span class="manual-tag">Manual</span>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <p class="no-data">No punches recorded</p>
                    }
                </div>

                <hr />

                <h4>Edit Entry</h4>

                <label style="display:flex;align-items:center;gap:6px;margin:0.5rem 0;">
                    <input type="checkbox" @bind="addPunchInCorrection" />
                    <span>Add a new punch entry</span>
                </label>

                @if (addPunchInCorrection)
                {
                    <div class="form-row">
                        <div class="form-group">
                            <label>Punch Type</label>
                            <select @bind="newPunchType">
                                <option value="In">Clock In</option>
                                <option value="Out">Clock Out</option>
                                <option value="LunchOut">Lunch Out</option>
                                <option value="LunchIn">Lunch In</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Time</label>
                            <input type="time" @bind="newPunchTime" />
                        </div>
                    </div>
                }

                <div class="form-group">
                    <label>Reason *</label>
                    <textarea @bind="correctionReason" placeholder="Required: Explain the correction, acknowledgment, or flag..."></textarea>
                </div>

                @if (editingDay.HasException)
                {
                    <div class="exception-info">
                        <label>Current Exception</label>
                        <p>@editingDay.ExceptionNotes</p>
                        <label class="resolve-checkbox">
                            <input type="checkbox" @bind="markExceptionResolved" />
                            <span>Mark exception as resolved (acknowledged)</span>
                        </label>
                    </div>
                }

                <label class="resolve-checkbox" style="margin-top:0.5rem;">
                    <input type="checkbox" @bind="flagAsException" />
                    <span>Flag this day as an exception for follow-up</span>
                </label>
                @if (flagAsException && markExceptionResolved)
                {
                    <div style="color:#b45309;font-size:.85rem;margin-top:.25rem;">
                        Resolve and Flag are mutually exclusive. Resolve wins; flag will be ignored.
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" @onclick="CloseEditModal">Cancel</button>
                <button class="btn-save" @onclick="SaveCorrection"
                        disabled="@(string.IsNullOrWhiteSpace(correctionReason) || (!addPunchInCorrection && !markExceptionResolved && !flagAsException))">
                    Save
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int EmployeeId { get; set; }
    [Parameter] public int PeriodOffset { get; set; } = 0;

    private int periodOffset = 0;
    private DateTime periodAnchorDate = DateTime.Today;
    private bool isLoading = true;
    private bool isApproving = false;
    private bool approvalChecked = false;
    private string supervisorNotes = "";
    private string currentUserEmail = "";
    private string currentUserName = "";

    // Employee info
    private string employeeName = "";
    private string employeeIdNumber = "";
    private string employeePosition = "";
    private string supervisorName = "";
    private string employeeInitials = "";
    private string employeeEmail = "";
    private string? employeePhotoBase64;
    private bool isHolidayEligible = true;

    // Approval status
    private bool employeeApproved = false;
    private bool supervisorApproved = false;

    // Data
    private PayPeriodInfo? currentPayPeriod;
    private PayPeriodTimesheet? payPeriodTimesheet;

    // Pay-period dropdown (replaced prev/next buttons 2026-04-24).
    private List<PayPeriodInfo> availablePeriods = new();
    private int selectedPayPeriodId = 0;

    // Drill-down state
    private HashSet<DateOnly> expandedDays = new();

    // Holiday data
    private List<TcHolidaySchedule> weekHolidays = new();

    // Pending employee correction requests
    private List<TcCorrectionRequest> employeeCorrectionRequests = new();
    private List<TcCorrectionRequest> PendingCorrectionRequests =>
        employeeCorrectionRequests.Where(cr => cr.Status == CorrectionRequestStatus.Submitted).ToList();

    // Edit modal
    private bool showEditModal = false;
    private DailyTimesheetEntry? editingDay;
    private string newPunchType = "In";
    private TimeOnly newPunchTime = new TimeOnly(8, 0);
    private string correctionReason = "";
    private bool markExceptionResolved = false;
    private bool addPunchInCorrection = false;
    private bool flagAsException = false;

    // Reminder email feedback — surfaces the result of SendTimesheetReminderAsync
    // so supervisors see a confirmation / error message instead of the button
    // silently doing nothing. Auto-clears after a few seconds on success.
    private bool isSendingReminder = false;
    private string reminderStatusMessage = "";
    private bool reminderStatusIsError = false;

    protected override async Task OnInitializedAsync()
    {
        periodOffset = PeriodOffset;
        for (int i = 0; i < Math.Abs(PeriodOffset); i++)
            periodAnchorDate = NavigatePeriod(periodAnchorDate, PeriodOffset < 0 ? -1 : 1);

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUserEmail = user.FindFirst("preferred_username")?.Value ??
                           user.FindFirst(ClaimTypes.Email)?.Value ?? "";
        currentUserName = user.FindFirst("name")?.Value ??
                          user.FindFirst(ClaimTypes.Name)?.Value ?? currentUserEmail;

        // Populate pay-period dropdown; seed from URL offset for back-compat.
        availablePeriods = await PayPeriodService.GetRecentPayPeriodsAsync();
        var initialPeriod = await PayPeriodService.GetPayPeriodForDateAsync(periodAnchorDate);
        selectedPayPeriodId = availablePeriods.Any(p => p.PayPeriodId == initialPeriod.PayPeriodId)
            ? initialPeriod.PayPeriodId
            : availablePeriods.FirstOrDefault(p => p.IsOpen)?.PayPeriodId ?? availablePeriods.FirstOrDefault()?.PayPeriodId ?? 0;

        await LoadEmployeeData();
    }

    private async Task OnPayPeriodChangedAsync(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var id)) return;
        selectedPayPeriodId = id;
        await LoadTimesheet();
    }

    private async Task LoadEmployeeData()
    {
        isLoading = true;

        try
        {
            using var context = await DbFactory.CreateDbContextAsync();

            var employee = await context.TcEmployees
                .Include(e => e.Staff)
                .Include(e => e.Supervisor).ThenInclude(s => s!.Staff)
                .FirstOrDefaultAsync(e => e.EmployeeId == EmployeeId);

            if (employee != null)
            {
                employeeName = employee.Staff?.FullName ?? "Unknown";
                employeeIdNumber = employee.IdNumber;
                employeePosition = employee.EmployeeType.ToString();
                supervisorName = employee.Supervisor?.Staff?.FullName ?? "Unassigned";
                employeeInitials = GetInitials(employeeName);
                employeeEmail = employee.Email ?? "";
                isHolidayEligible = employee.EmployeeType != EmployeeType.HourlyPartTime
                                 && employee.EmployeeType != EmployeeType.Substitute;

                // Load photo
                if (employee.StaffDcid > 0)
                {
                    var photo = await context.Photos
                        .FirstOrDefaultAsync(p => p.SubjectDcid == employee.StaffDcid && p.SubjectType == 1);
                    if (photo?.PhotoData != null)
                    {
                        employeePhotoBase64 = Convert.ToBase64String(photo.PhotoData);
                    }
                }

                await LoadTimesheet();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading employee {EmployeeId}", EmployeeId);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadTimesheet()
    {
        // Dropdown-driven. Fall back to today's period if selection is stale.
        currentPayPeriod = availablePeriods.FirstOrDefault(p => p.PayPeriodId == selectedPayPeriodId)
                        ?? await PayPeriodService.GetCurrentPayPeriodAsync();

        payPeriodTimesheet = await TimesheetService.GetPayPeriodTimesheetAsync(
            EmployeeId,
            currentPayPeriod.StartDate,
            currentPayPeriod.EndDate);

        employeeApproved = payPeriodTimesheet.EmployeeApprovalStatus != ApprovalStatus.Pending;
        supervisorApproved = payPeriodTimesheet.SupervisorApprovalStatus == ApprovalStatus.Approved ||
                             payPeriodTimesheet.SupervisorApprovalStatus == ApprovalStatus.Locked;

        // Load holidays for the pay period
        using var ctx = await DbFactory.CreateDbContextAsync();
        weekHolidays = await ctx.TcHolidaySchedules
            .AsNoTracking()
            .Where(h => h.IsActive && h.HolidayDate >= currentPayPeriod.StartDate && h.HolidayDate <= currentPayPeriod.EndDate)
            .ToListAsync();

        // Load pending correction requests from this employee
        employeeCorrectionRequests = await ctx.TcCorrectionRequests
            .AsNoTracking()
            .Where(cr => cr.EmployeeId == EmployeeId &&
                         cr.WorkDate >= currentPayPeriod.StartDate && cr.WorkDate <= currentPayPeriod.EndDate)
            .OrderByDescending(cr => cr.CreatedDate)
            .ToListAsync();

        expandedDays.Clear();
        approvalChecked = false;
        supervisorNotes = "";
        StateHasChanged();
    }

