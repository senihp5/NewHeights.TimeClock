    private List<PunchPairDisplay> GetPunchPairs(DailyTimesheetEntry day)
    {
        var pairs = new List<PunchPairDisplay>();
        var punches = day.Punches.OrderBy(p => p.PunchTime).ToList();
        var unmatched = new List<PunchEntry>(punches);

        var pairMappings = new[] { ("In", "Out", "Work", "work"), ("LunchOut", "LunchIn", "Lunch", "lunch"), ("BreakOut", "BreakIn", "Break", "break") };

        foreach (var (inType, outType, label, css) in pairMappings)
        {
            var ins = unmatched.Where(p => p.PunchType == inType).OrderBy(p => p.PunchTime).ToList();
            var outs = unmatched.Where(p => p.PunchType == outType).OrderBy(p => p.PunchTime).ToList();

            for (int i = 0; i < ins.Count; i++)
            {
                var inP = ins[i];
                var outP = i < outs.Count ? outs[i] : null;
                var hours = outP != null ? (decimal)(outP.PunchTime - inP.PunchTime).TotalHours : 0;

                pairs.Add(new PunchPairDisplay
                {
                    Label = label,
                    BadgeClass = css,
                    InTime = inP.PunchTime.ToString("h:mm tt"),
                    OutTime = outP?.PunchTime.ToString("h:mm tt") ?? "(open)",
                    RoundedIn = inP.RoundedTime?.ToString("h:mm tt") ?? inP.PunchTime.ToString("h:mm tt"),
                    RoundedOut = outP?.RoundedTime?.ToString("h:mm tt") ?? outP?.PunchTime.ToString("h:mm tt") ?? "—",
                    Hours = outP != null ? hours.ToString("F2") : "—",
                    IsManual = inP.IsManual || (outP?.IsManual ?? false),
                    IsModified = inP.IsModified || (outP?.IsModified ?? false)
                });

                unmatched.Remove(inP);
                if (outP != null) unmatched.Remove(outP);
            }

            var remainingOuts = unmatched.Where(p => p.PunchType == outType).ToList();
            foreach (var outP in remainingOuts)
            {
                pairs.Add(new PunchPairDisplay
                {
                    Label = label,
                    BadgeClass = "unpaired",
                    InTime = "(missing)",
                    OutTime = outP.PunchTime.ToString("h:mm tt"),
                    RoundedIn = "—",
                    RoundedOut = outP.RoundedTime?.ToString("h:mm tt") ?? outP.PunchTime.ToString("h:mm tt"),
                    Hours = "—",
                    IsManual = outP.IsManual,
                    IsModified = outP.IsModified
                });
                unmatched.Remove(outP);
            }
        }

        return pairs.OrderBy(p => p.InTime).ToList();
    }

    private async Task ApproveCorrectionRequest(TcCorrectionRequest request)
    {
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            var entity = await context.TcCorrectionRequests.FindAsync(request.RequestId);
            if (entity == null) return;

            entity.Status = CorrectionRequestStatus.Approved;
            entity.ReviewedBy = currentUserEmail;
            entity.ReviewedDate = DateTime.Now;

            TcTimePunch? newPunch = null;

            // If the request includes a punch to add, create the TcTimePunch
            if (request.RequestType == CorrectionRequestType.MissedPunch ||
                request.RequestType == CorrectionRequestType.AddPunch)
            {
                if (request.RequestedDateTime.HasValue && request.RequestedPunchType.HasValue)
                {
                    var employee = await context.TcEmployees.FindAsync(EmployeeId);
                    var punchDt = request.RequestedDateTime.Value;

                    newPunch = new TcTimePunch
                    {
                        EmployeeId = EmployeeId,
                        CampusId = employee?.HomeCampusId ?? 0,
                        PunchType = request.RequestedPunchType.Value,
                        PunchDateTime = punchDt,
                        RoundedDateTime = RoundToQuarterHour(punchDt),
                        VerificationMethod = "MANUAL",
                        ScanMethod = "CORRECTION",
                        IsManualEntry = true,
                        IsModified = true,
                        ModifiedBy = currentUserEmail,
                        ModifiedReason = $"[Approved Correction] {request.Reason}",
                        Notes = request.Reason,
                        PunchStatus = PunchStatus.Active,
                        CreatedDate = DateTime.Now
                    };
                    context.TcTimePunches.Add(newPunch);
                }
            }

            await context.SaveChangesAsync();

            // Audit: CORRECTION_APPROVED row tagged with the supervisor.
            await Audit.LogActionAsync(
                actionCode: AuditActions.Correction.Approved,
                entityType: AuditEntityTypes.Correction,
                entityId: entity.RequestId.ToString(),
                newValues: new
                {
                    entity.RequestId,
                    entity.EmployeeId,
                    RequestType = entity.RequestType.ToString(),
                    WorkDate = entity.WorkDate.ToString("yyyy-MM-dd"),
                    RequestedPunchType = entity.RequestedPunchType?.ToString(),
                    RequestedDateTime = entity.RequestedDateTime?.ToString("yyyy-MM-dd HH:mm:ss"),
                    ReviewedBy = entity.ReviewedBy,
                    ReviewedDate = entity.ReviewedDate?.ToString("yyyy-MM-dd HH:mm:ss"),
                    CreatedPunchId = newPunch?.PunchId
                },
                reason: entity.Reason,
                deltaSummary:
                    $"Correction #{entity.RequestId} ({entity.RequestType}) for employee {EmployeeId} "
                    + $"approved by {currentUserEmail}"
                    + (newPunch != null ? $"; punch #{newPunch.PunchId} created" : ""),
                source: AuditSource.AdminUi,
                employeeId: EmployeeId);

            // If a punch was applied as a result, also emit CORRECTION_APPLIED.
            if (newPunch != null)
            {
                await Audit.LogActionAsync(
                    actionCode: AuditActions.Correction.Applied,
                    entityType: AuditEntityTypes.Punch,
                    entityId: newPunch.PunchId.ToString(),
                    newValues: new
                    {
                        newPunch.PunchId,
                        newPunch.EmployeeId,
                        newPunch.CampusId,
                        PunchType = newPunch.PunchType.ToString(),
                        newPunch.PunchDateTime,
                        SourceCorrectionId = entity.RequestId
                    },
                    deltaSummary:
                        $"Applied correction #{entity.RequestId}: new {newPunch.PunchType} punch at {newPunch.PunchDateTime:MMM d h:mm tt}",
                    source: AuditSource.AdminUi,
                    employeeId: EmployeeId,
                    punchId: newPunch.PunchId);
            }

            // Recalculate daily timecard
            await TimesheetService.RecalculateDailyTimecardAsync(EmployeeId, request.WorkDate);

            Logger.LogInformation("Supervisor {Sup} approved correction {Id} for employee {Emp}",
                currentUserEmail, request.RequestId, EmployeeId);

            // Email notification to the employee. Wrapped in try/catch so a mail
            // delivery failure (SMTP hiccup, wrong address) cannot break the
            // correction workflow — the DB writes + audit row are already committed.
            if (!string.IsNullOrWhiteSpace(employeeEmail))
            {
                try
                {
                    await EmailService.SendCorrectionApprovedAsync(
                        employeeEmail,
                        employeeName,
                        currentUserName,
                        FormatRequestType(entity.RequestType),
                        entity.WorkDate,
                        entity.Reason ?? "",
                        newPunch?.PunchDateTime,
                        newPunch?.PunchType.ToString());
                }
                catch (Exception mailEx)
                {
                    Logger.LogError(mailEx,
                        "Correction-approved email failed for employee {EmployeeId} correction {RequestId}. Decision already committed.",
                        EmployeeId, request.RequestId);
                }
            }

            await LoadTimesheet();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error approving correction request {Id}", request.RequestId);
        }
    }

    private async Task DenyCorrectionRequest(TcCorrectionRequest request)
    {
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            var entity = await context.TcCorrectionRequests.FindAsync(request.RequestId);
            if (entity == null) return;

            var oldStatus = entity.Status;
            entity.Status = CorrectionRequestStatus.Denied;
            entity.ReviewedBy = currentUserEmail;
            entity.ReviewedDate = DateTime.Now;

            await context.SaveChangesAsync();

            await Audit.LogActionAsync(
                actionCode: AuditActions.Correction.Denied,
                entityType: AuditEntityTypes.Correction,
                entityId: entity.RequestId.ToString(),
                oldValues: new { Status = oldStatus.ToString() },
                newValues: new
                {
                    entity.RequestId,
                    entity.EmployeeId,
                    RequestType = entity.RequestType.ToString(),
                    WorkDate = entity.WorkDate.ToString("yyyy-MM-dd"),
                    Status = entity.Status.ToString(),
                    ReviewedBy = entity.ReviewedBy,
                    ReviewedDate = entity.ReviewedDate?.ToString("yyyy-MM-dd HH:mm:ss")
                },
                reason: entity.Reason,
                deltaSummary:
                    $"Correction #{entity.RequestId} ({entity.RequestType}) for employee {EmployeeId} denied by {currentUserEmail}",
                source: AuditSource.AdminUi,
                employeeId: EmployeeId);

            Logger.LogInformation("Supervisor {Sup} denied correction {Id} for employee {Emp}",
                currentUserEmail, request.RequestId, EmployeeId);

            // Email notification to the employee — same safety-first pattern as the
            // approve path. DB + audit are already committed; mail failures are logged.
            if (!string.IsNullOrWhiteSpace(employeeEmail))
            {
                try
                {
                    await EmailService.SendCorrectionDeniedAsync(
                        employeeEmail,
                        employeeName,
                        currentUserName,
                        FormatRequestType(entity.RequestType),
                        entity.WorkDate,
                        entity.Reason ?? "");
                }
                catch (Exception mailEx)
                {
                    Logger.LogError(mailEx,
                        "Correction-denied email failed for employee {EmployeeId} correction {RequestId}. Decision already committed.",
                        EmployeeId, request.RequestId);
                }
            }

            await LoadTimesheet();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error denying correction request {Id}", request.RequestId);
        }
    }

    private static string FormatRequestType(CorrectionRequestType type) => type switch
    {
        CorrectionRequestType.MissedPunch => "Missed Punch",
        CorrectionRequestType.WrongTime => "Wrong Time",
        CorrectionRequestType.WrongType => "Wrong Type",
        CorrectionRequestType.AddPunch => "Add Punch",
        CorrectionRequestType.DeletePunch => "Delete Punch",
        _ => type.ToString()
    };

    private string GetShiftStatus(DailyTimesheetEntry day, string shift)
    {
        if (day.TotalHours == 0 && !day.Punches.Any())
        {
            if (day.Date.DayOfWeek == DayOfWeek.Saturday || day.Date.DayOfWeek == DayOfWeek.Sunday)
                return "N/A";
            return "—";
        }

        foreach (var p in day.Punches)
        {
            var hour = p.PunchTime.Hour;
            bool inShift = shift switch
            {
                "AM" => hour >= 6 && hour < 12,
                "PM" => hour >= 12 && hour < 17,
                "Evening" => hour >= 16 && hour < 22,
                _ => false
            };
            if (inShift) return "In Office";
        }

        return day.Date.DayOfWeek == DayOfWeek.Saturday || day.Date.DayOfWeek == DayOfWeek.Sunday ? "N/A" : "—";
    }

    private static string FormatPunchType(string punchType) => punchType switch
    {
        "In" => "IN",
        "Out" => "OUT",
        "LunchOut" => "L-Out",
        "LunchIn" => "L-In",
        _ => punchType
    };


    private static DateTime NavigatePeriod(DateTime anchor, int direction)
    {
        bool isFirstHalf = anchor.Day <= 15;
        if (direction < 0)
        {
            return isFirstHalf
                ? new DateTime(anchor.AddMonths(-1).Year, anchor.AddMonths(-1).Month, 16)
                : new DateTime(anchor.Year, anchor.Month, 1);
        }
        else
        {
            if (isFirstHalf)
                return new DateTime(anchor.Year, anchor.Month, 16);
            var next = anchor.AddMonths(1);
            return new DateTime(next.Year, next.Month, 1);
        }
    }
    private static string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[^1][0]}".ToUpper();
        return parts.Length > 0 ? parts[0][0].ToString().ToUpper() : "?";
    }

    private static DateTime RoundToQuarterHour(DateTime dt)
    {
        var minutes = (int)(Math.Round(dt.Minute / 15.0) * 15);
        if (minutes == 60)
            return new DateTime(dt.Year, dt.Month, dt.Day, dt.Hour, 0, 0).AddHours(1);
        return new DateTime(dt.Year, dt.Month, dt.Day, dt.Hour, minutes, 0);
    }

    private class PunchPairDisplay
    {
        public string Label { get; set; } = "";
        public string BadgeClass { get; set; } = "";
        public string InTime { get; set; } = "";
        public string OutTime { get; set; } = "";
        public string RoundedIn { get; set; } = "";
        public string RoundedOut { get; set; } = "";
        public string Hours { get; set; } = "";
        public bool IsManual { get; set; }
        public bool IsModified { get; set; }
    }
}

