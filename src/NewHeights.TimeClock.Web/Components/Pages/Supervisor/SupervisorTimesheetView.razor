    private async Task ApproveTimesheet()
    {
        if (!approvalChecked || isApproving || currentPayPeriod == null) return;

        isApproving = true;
        try
        {
            await TimesheetService.ApproveTimesheetAsync(
                EmployeeId,
                currentPayPeriod.StartDate,
                currentPayPeriod.EndDate,
                currentUserEmail,
