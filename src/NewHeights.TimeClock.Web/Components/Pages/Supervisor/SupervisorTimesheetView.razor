    private async Task SaveCorrection()
    {
        if (editingDay == null || string.IsNullOrWhiteSpace(correctionReason)) return;
        if (!addPunchInCorrection && !markExceptionResolved && !flagAsException) return;

        try
        {
            using var context = await DbFactory.CreateDbContextAsync();

            var employee = await context.TcEmployees.FindAsync(EmployeeId);
            if (employee == null) return;

            TcTimePunch? newPunch = null;

            // 1. Optional punch creation
            if (addPunchInCorrection)
            {
                var punchDateTime = editingDay.Date.ToDateTime(newPunchTime);
                var punchType = Enum.Parse<PunchType>(newPunchType);

                newPunch = new TcTimePunch
                {
                    EmployeeId = EmployeeId,
                    CampusId = employee.HomeCampusId,
                    PunchType = punchType,
                    PunchDateTime = punchDateTime,
                    RoundedDateTime = RoundToQuarterHour(punchDateTime),
                    VerificationMethod = "MANUAL",
                    ScanMethod = "SUPERVISOR",
                    IsManualEntry = true,
                    IsModified = true,
                    ModifiedBy = currentUserEmail,
                    ModifiedReason = $"[Supervisor Correction] {correctionReason}",
                    Notes = correctionReason,
                    PunchStatus = PunchStatus.Active,
                    CreatedDate = DateTime.Now
                };

                context.TcTimePunches.Add(newPunch);
                await context.SaveChangesAsync();

                await Audit.LogActionAsync(
                    actionCode: AuditActions.Punch.Modified,
                    entityType: AuditEntityTypes.Punch,
                    entityId: newPunch.PunchId.ToString(),
                    newValues: new
                    {
                        newPunch.PunchId,
                        newPunch.EmployeeId,
                        newPunch.CampusId,
                        PunchType = newPunch.PunchType.ToString(),
                        newPunch.PunchDateTime,
                        ScanMethod = newPunch.ScanMethod,
                        Source = "SUPERVISOR_CORRECTION"
                    },
                    reason: correctionReason,
                    deltaSummary:
                        $"Supervisor correction: added {newPunch.PunchType} at {newPunch.PunchDateTime:MMM d h:mm tt} for employee {EmployeeId} by {currentUserEmail}",
                    source: AuditSource.AdminUi,
                    employeeId: EmployeeId,
                    punchId: newPunch.PunchId);

                await TimesheetService.RecalculateDailyTimecardAsync(EmployeeId, editingDay.Date);
            }

            // 2. Exception state change: resolve OR flag (Resolve wins if both)
            if (markExceptionResolved || flagAsException)
            {
                var timecard = await context.TcDailyTimecards
                    .FirstOrDefaultAsync(t => t.EmployeeId == EmployeeId && t.WorkDate == editingDay.Date);

                if (timecard == null && flagAsException)
                {
                    timecard = new TcDailyTimecard
                    {
                        EmployeeId = EmployeeId,
                        CampusId = employee.HomeCampusId,
                        WorkDate = editingDay.Date,
                        ApprovalStatus = ApprovalStatus.Pending,
                        CreatedDate = DateTime.Now,
                        ModifiedDate = DateTime.Now
                    };
                    context.TcDailyTimecards.Add(timecard);
                }

                if (timecard != null)
                {
                    if (markExceptionResolved)
                    {
                        timecard.HasException = false;
                        timecard.ExceptionNotes =
                            $"Acknowledged by {currentUserName} on {DateTime.Now:MMM d h:mm tt}: {correctionReason}";
                    }
                    else if (flagAsException)
                    {
                        timecard.HasException = true;
                        timecard.ExceptionNotes =
                            $"Flagged by {currentUserName} on {DateTime.Now:MMM d h:mm tt}: {correctionReason}";
                    }
                    timecard.ModifiedDate = DateTime.Now;
                    await context.SaveChangesAsync();

                    await Audit.LogActionAsync(
                        actionCode: markExceptionResolved
                            ? AuditActions.Timesheet.ExceptionAcknowledged
                            : AuditActions.Timesheet.ExceptionFlagged,
                        entityType: AuditEntityTypes.Timecard,
                        entityId: timecard.TimecardId.ToString(),
                        newValues: new
                        {
                            timecard.TimecardId,
                            timecard.EmployeeId,
                            WorkDate = timecard.WorkDate.ToString("yyyy-MM-dd"),
                            HasException = timecard.HasException,
                            PunchCreated = newPunch?.PunchId,
                            Actor = currentUserEmail
                        },
                        reason: correctionReason,
                        deltaSummary: markExceptionResolved
                            ? $"Exception acknowledged on {timecard.WorkDate:MMM d} by {currentUserEmail} for employee {EmployeeId}"
                            : $"Day {timecard.WorkDate:MMM d} flagged as exception by {currentUserEmail} for employee {EmployeeId}",
                        source: AuditSource.AdminUi,
                        employeeId: EmployeeId);
                }
            }

            Logger.LogInformation(
                "Supervisor {Supervisor} edit on {Date} for employee {Employee}: AddPunch={AddPunch}, Resolve={Resolve}, Flag={Flag}",
                currentUserEmail, editingDay.Date, EmployeeId,
                addPunchInCorrection, markExceptionResolved, flagAsException);

            CloseEditModal();
            await LoadTimesheet();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving correction");
        }
    }

