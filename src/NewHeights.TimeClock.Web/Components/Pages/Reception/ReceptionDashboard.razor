@page "/reception"
@page "/reception/{CampusCode}"
@layout KioskLayout
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@attribute [Authorize(Policy = "RequireCampusAdmin")]
@using NewHeights.TimeClock.Shared.Constants
@using NewHeights.TimeClock.Data
@using NewHeights.TimeClock.Data.Entities
@using NewHeights.TimeClock.Shared.Audit
@using NewHeights.TimeClock.Web.Services
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@using Microsoft.AspNetCore.SignalR.Client
@inject IDbContextFactory<TimeClockDbContext> DbFactory
@inject IJSRuntime JS
@inject ILogger<ReceptionDashboard> Logger
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IAuditService Audit
@implements IAsyncDisposable

<PageTitle>Reception - @selectedCampusName</PageTitle>

@if (!hasCampusSelected)
{
    <div class="campus-selector-overlay">
        <div class="campus-selector-modal">
            <h2>Select Your Campus</h2>
            <p>Choose the campus you are working at today:</p>
            <div class="campus-buttons">
                @foreach (var campus in availableCampuses)
                {
                    <button class="campus-btn" @onclick="() => SelectCampus(campus.CampusCode)">
                        @campus.CampusName
                    </button>
                }
            </div>
        </div>
    </div>
}
else
{
    <div class="reception-dashboard">
        <header class="reception-header">
            <div class="header-brand">
                <span class="header-icon">🛡️</span>
                <div class="header-titles">
                    <h1>@selectedCampusName</h1>
                    <span class="header-subtitle">Reception Dashboard</span>
                </div>
            </div>
            <div class="header-stats">
                <div class="stat-pill staff">
                    <span class="stat-count">@staffCount</span>
                    <span class="stat-label">Staff</span>
                </div>
                <div class="stat-pill students">
                    <span class="stat-count">@studentCount</span>
                    <span class="stat-label">Students</span>
                </div>
                <div class="stat-pill total">
                    <span class="stat-count">@(staffCount + studentCount)</span>
                    <span class="stat-label">Total</span>
                </div>
            </div>
            <div class="header-actions">
                <a class="btn-icon" href="/" title="Back to Home" style="text-decoration:none;">
                    🏠
                </a>
                <span class="last-updated">@lastRefresh.ToString("h:mm:ss tt")</span>
                <button class="btn-icon" @onclick="RefreshData" disabled="@isLoading" title="Refresh">
                    🔄
                </button>
                <button class="btn-manual-entry" @onclick="OpenManualEntry" title="Manual Check-In">
                    ➕ Manual Entry
                </button>

                <button class="btn-change-campus" @onclick="ChangeCampus" title="Change Campus">
                    📍
                </button>
            </div>
        </header>

        <div class="reception-content">
            <div class="onsite-section">
                <div class="section-toolbar">
                    <h2>👥 Currently On Site</h2>
                    <div class="toolbar-controls">
                        <input type="text" 
                               @bind="searchTerm" 
                               @bind:event="oninput"
                               placeholder="Search name or ID..." 
                               class="search-input" />
                        <select @bind="personTypeFilter" class="filter-select">
                            <option value="">All</option>
                            <option value="STAFF">Staff</option>
                            <option value="STUDENT">Students</option>
                        </select>
                    </div>
                </div>
                <div class="onsite-table-wrapper">
                    <table class="onsite-table">
                        <thead>
                            <tr>
                                <th class="sortable" @onclick='() => SortBy("name")'>Name @SortIndicator("name")</th>
                                <th class="sortable" @onclick='() => SortBy("type")'>Type @SortIndicator("type")</th>
                                <th>ID</th>
                                <th class="sortable" @onclick='() => SortBy("status")'>Status @SortIndicator("status")</th>
                                <th class="sortable" @onclick='() => SortBy("time")'>Time @SortIndicator("time")</th>
                                <th>Duration</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var person in filteredOnSiteList)
                            {
                                <tr>
                                    <td class="name-cell">
                                        @if (person.AllPunches.Count > 1)
                                        {
                                            <button class="expand-btn" @onclick="() => ToggleExpand(person)" @onclick:stopPropagation>
                                                <span class="expand-icon @(person.IsExpanded ? "expanded" : "")">▶</span>
                                            </button>
                                        }
                                        <span>@person.LastName, @person.FirstName</span>
                                    </td>
                                    <td><span class="type-badge @person.TransactionType.ToLower()">@person.TransactionType</span></td>
                                    <td>@person.IdNumber</td>
                                    <td><span class="status-badge @person.LastScanType.ToLower().Replace("_","-")">@FormatScanType(person.LastScanType)</span></td>
                                    <td>@person.LastScanTime.ToString("h:mm tt")</td>
                                    <td>@FormatDuration(person.CheckInTime)</td>
                                    <td>
                                        <button class="btn-action" @onclick="() => OpenCorrection(person)" title="Correct">
                                            ✏️
                                        </button>
                                        <button class="btn-action" @onclick="() => QuickCheckOut(person)" title="Check Out">
                                            🚪
                                        </button>
                                    </td>
                                </tr>
                                @if (person.IsExpanded && person.AllPunches.Count > 1)
                                {
                                    <tr class="punch-history-row">
                                        <td colspan="7">
                                            <div class="punch-history">
                                                <h4>All Punches Today</h4>
                                                <div class="punch-timeline">
                                                    @foreach (var punch in person.AllPunches.OrderBy(p => p.ScanDateTime))
                                                    {
                                                        <div class="punch-item">
                                                            <span class="punch-badge @punch.ScanType.ToLower().Replace("_","-")">
                                                                @FormatScanType(punch.ScanType)
                                                            </span>
                                                            <span class="punch-time">
                                                                @punch.ScanDateTime.ToString("h:mm:ss tt")
                                                            </span>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            @if (!filteredOnSiteList.Any())
                            {
                                <tr>
                                    <td colspan="7" class="empty-row">No one currently on site</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="table-footer">
                    Showing @filteredOnSiteList.Count of @onSiteList.Count people
                </div>
            </div>

            
                        <div class="right-sidebar">
                <div class="last-scan-section">
                <div class="section-header">
                    <h2>📸 Last Scan</h2>
                </div>
                @if (lastScannedPerson != null)
                {
                    <div class="last-scan-card">
                        @if (!string.IsNullOrEmpty(lastScannedPhoto))
                        {
                            <img src="data:image/jpeg;base64,@lastScannedPhoto" alt="Photo" class="last-scan-photo" />
                        }
                        else
                        {
                            <div class="last-scan-photo-placeholder">
                                @GetInitial(lastScannedPerson.FirstName)
                            </div>
                        }
                        <div class="last-scan-info">
                            <h3>@lastScannedPerson.FirstName @lastScannedPerson.LastName</h3>
                            <span class="last-scan-type @lastScannedPerson.ScanType.ToLower().Replace("_","-")">
                                @FormatScanType(lastScannedPerson.ScanType)
                            </span>
                            <span class="last-scan-time">@lastScannedPerson.ScanDateTime.ToString("h:mm:ss tt")</span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="empty-scan">No scans yet today</div>
                }
            </div>
<div class="activity-section">
                <div class="section-header">
                    <h2>📋 Activity</h2>
                    <label class="auto-refresh">
                        <input type="checkbox" @bind="autoRefresh" /> Auto
                    </label>
                </div>
                <div class="activity-list">
                    @foreach (var activity in recentActivity.Take(30))
                    {
                        <div class="activity-row @activity.ScanType.ToLower().Replace("_","-")">
                            <span class="activity-icon">@GetActivityIcon(activity.ScanType)</span>
                            <div class="activity-info">
                                <span class="activity-name">@activity.FirstName @activity.LastName</span>
                                <span class="activity-detail">@activity.TransactionType</span>
                            </div>
                            <div class="activity-time">
                                <span>@activity.ScanDateTime.ToString("h:mm:ss tt")</span>
                            </div>
                        </div>
                    }
                    @if (!recentActivity.Any())
                    {
                        <div class="empty-activity">No activity today</div>
                    }
                </div>
            </div>
            </div>
        </div>
    </div>
}

@if (showManualEntryModal)
{
    <div class="modal-overlay" @onclick="CloseManualEntry">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h2>➕ Manual Entry</h2>
                <button class="modal-close" @onclick="CloseManualEntry">✕</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Search Person</label>
                    <input type="text" @bind="manualSearchTerm" @bind:event="oninput" 
                           @onkeyup="SearchPeople" placeholder="Type name or ID..." />
                </div>
                @if (searchResults.Any())
                {
                    <div class="search-results">
                        @foreach (var result in searchResults.Take(10))
                        {
                            <div class="search-result-item" @onclick="() => SelectPerson(result)">
                                <strong>@result.LastName, @result.FirstName</strong>
                                <span class="result-meta">@result.Type - ID: @result.IdNumber</span>
                            </div>
                        }
                    </div>
                }
                @if (selectedPerson != null)
                {
                    <div class="selected-person">
                        <h4>@selectedPerson.FirstName @selectedPerson.LastName</h4>
                        <span>@selectedPerson.Type - ID: @selectedPerson.IdNumber</span>
                    </div>
                    <div class="form-group">
                        <label>Action</label>
                        <select @bind="manualScanType">
                            <option value="CAMPUS_IN">Check In</option>
                            <option value="CAMPUS_OUT">Check Out</option>
                            <option value="LUNCH_OUT">Lunch Out</option>
                            <option value="LUNCH_IN">Lunch In</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Time</label>
                        <input type="time" @bind="manualTime" />
                    </div>
                    <div class="form-group">
                        <label>Reason <span style="color:#b45309;">(required)</span></label>
                        <textarea @bind="manualNotes"
                                  maxlength="500"
                                  rows="3"
                                  placeholder="Why is a manual entry needed? (e.g., forgot to scan, phone dead, field trip return)"></textarea>
                        <div style="font-size:0.8rem; color:#6b7280; margin-top:4px;">
                            @(string.IsNullOrWhiteSpace(manualNotes) ? 0 : manualNotes.Trim().Length) / 500 characters
                            @if (!string.IsNullOrWhiteSpace(manualNotes) && manualNotes.Trim().Length < 5)
                            {
                                <span style="color:#b45309;">&middot; at least 5 characters</span>
                            }
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(manualEntryError))
                    {
                        <div class="form-error" style="color: #dc3545; padding: 8px; margin-top: 8px; background: #f8d7da; border-radius: 4px;">
                            @manualEntryError
                        </div>
                    }
                }
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" @onclick="CloseManualEntry">Cancel</button>
                <button class="btn-save" @onclick="SaveManualEntry"
                        disabled="@(selectedPerson == null || string.IsNullOrWhiteSpace(manualNotes) || manualNotes.Trim().Length < 5)">
                    Save Entry
                </button>
            </div>
        </div>
    </div>
}

@if (showCorrectionModal && correctionPerson != null)
{
    <div class="modal-overlay" @onclick="CloseCorrection">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header correction">
                <h2>✏️ Correct Entry</h2>
                <button class="modal-close" @onclick="CloseCorrection">✕</button>
            </div>
            <div class="modal-body">
                <div class="correction-person">
                    <h3>@correctionPerson.FirstName @correctionPerson.LastName</h3>
                    <span>@correctionPerson.TransactionType - ID: @correctionPerson.IdNumber</span>
                </div>
                <div class="correction-current">
                    <p><strong>Current Status:</strong> @FormatScanType(correctionPerson.LastScanType) at @correctionPerson.LastScanTime.ToString("h:mm tt")</p>
                </div>
                <hr />
                <h4>New Entry</h4>
                <div class="form-group">
                    <label>Action</label>
                    <select @bind="correctionScanType">
                        <option value="CAMPUS_IN">Check In</option>
                        <option value="CAMPUS_OUT">Check Out</option>
                        <option value="LUNCH_OUT">Lunch Out</option>
                        <option value="LUNCH_IN">Lunch In</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Time</label>
                    <input type="time" @bind="correctionTime" />
                </div>
                <div class="form-group">
                    <label>Reason for Correction *</label>
                    <textarea @bind="correctionNotes" placeholder="Required: Explain why this correction is needed..."></textarea>
                </div>
                @if (!string.IsNullOrEmpty(correctionError))
                {
                    <div class="form-error" style="color: #dc3545; padding: 8px; margin-top: 8px; background: #f8d7da; border-radius: 4px;">
                        @correctionError
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" @onclick="CloseCorrection">Cancel</button>
                <button class="btn-save" @onclick="SaveCorrection" disabled="@string.IsNullOrWhiteSpace(correctionNotes)">
                    Save Correction
                </button>
            </div>
        </div>
    </div>
}

@code {

    [Parameter] public string? CampusCode { get; set; }

    private bool hasCampusSelected = false;
    private string selectedCampusCode = "";
    private string selectedCampusName = "Reception";
    private int selectedCampusId = 0;
    private int staffCount = 0;
    private int studentCount = 0;
    
    private DateTime lastRefresh = DateTime.Now;
    private bool isLoading = false;
    private bool autoRefresh = true;
    private string searchTerm = "";
    private string personTypeFilter = "";
    private string currentUserName = "";
    private string currentUserEmail = "";

    private HubConnection? hubConnection;

    private List<Campus> availableCampuses = new();
    private List<OnSitePerson> onSiteList = new();
    private HashSet<string> expandedPersonIds = new();
    private List<ActivityItem> recentActivity = new();
    private AttendanceTransaction? lastScannedPerson = null;
    private string lastScannedPhoto = "";
    private System.Timers.Timer? refreshTimer;

    // Manual Entry
    private bool showManualEntryModal = false;
    private string manualSearchTerm = "";
    private List<PersonSearchResult> searchResults = new();
    private PersonSearchResult? selectedPerson = null;
    private string manualScanType = "CAMPUS_IN";
    private TimeOnly manualTime = TimeOnly.FromDateTime(DateTime.Now);
    private string manualNotes = "";
    private string? manualEntryError = null;

    // Correction
    private bool showCorrectionModal = false;
    private OnSitePerson? correctionPerson = null;
    private string correctionScanType = "CAMPUS_OUT";
    private TimeOnly correctionTime = TimeOnly.FromDateTime(DateTime.Now);
    private string correctionNotes = "";
    private string? correctionError = null;

    // Sorting
    private string sortColumn = "name";
    private bool sortAscending = true;

    private List<OnSitePerson> filteredOnSiteList
    {
        get
        {
            var filtered = onSiteList
                .Where(p => string.IsNullOrEmpty(searchTerm) ||
                            p.FirstName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                            p.LastName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                            p.IdNumber.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
                .Where(p => string.IsNullOrEmpty(personTypeFilter) || p.TransactionType == personTypeFilter);

            filtered = sortColumn switch
            {
                "name" => sortAscending
                    ? filtered.OrderBy(p => p.LastName).ThenBy(p => p.FirstName)
                    : filtered.OrderByDescending(p => p.LastName).ThenByDescending(p => p.FirstName),
                "type" => sortAscending
                    ? filtered.OrderBy(p => p.TransactionType)
                    : filtered.OrderByDescending(p => p.TransactionType),
                "status" => sortAscending
                    ? filtered.OrderBy(p => p.LastScanType)
                    : filtered.OrderByDescending(p => p.LastScanType),
                "time" => sortAscending
                    ? filtered.OrderBy(p => p.LastScanTime)
                    : filtered.OrderByDescending(p => p.LastScanTime),
                _ => filtered.OrderBy(p => p.LastName).ThenBy(p => p.FirstName)
            };

            return filtered.ToList();
        }
    }

    private bool firstRenderComplete = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUserName = user.FindFirst("name")?.Value ?? user.FindFirst(ClaimTypes.Name)?.Value ?? "Unknown";
        currentUserEmail = user.FindFirst("preferred_username")?.Value ?? user.FindFirst(ClaimTypes.Email)?.Value ?? "";

        using var context = await DbFactory.CreateDbContextAsync();
        // District Office is a payroll/HR rollup campus, not a physical
        // location with a front desk. Hidden from the reception campus picker
        // so the modal only offers the two real campuses. Matches the filter
        // already applied in StudentCheckin, SafetyDashboard, and Home's
        // Campus Safety Live section.
        availableCampuses = await context.Campuses
            .AsNoTracking()
            .Where(c => c.CampusCode != AppConstants.Campus.DistrictCode)
            .OrderBy(c => c.CampusName)
            .ToListAsync();

        if (!string.IsNullOrEmpty(CampusCode))
        {
            await SelectCampus(CampusCode);
        }

        refreshTimer = new System.Timers.Timer(15000);
        refreshTimer.Elapsed += async (s, e) =>
        {
            if (autoRefresh && hasCampusSelected)
            {
                await InvokeAsync(async () =>
                {
                    await RefreshData();
                    StateHasChanged();
                });
            }
        };
        refreshTimer.Start();

        // Initialize SignalR connection for real-time updates
        try
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri("/dashboardhub"))
                .WithAutomaticReconnect()
                .Build();

            hubConnection.On("ScanCompleted", async () =>
            {
                Logger.LogInformation("SignalR: Scan completed event received");
                await InvokeAsync(async () =>
                {
                    await RefreshData();
                    StateHasChanged();
                });
            });

            await hubConnection.StartAsync();
            
            // Join the campus-specific group
            if (!string.IsNullOrEmpty(selectedCampusCode))
            {
                await hubConnection.InvokeAsync("JoinDashboard", selectedCampusCode);
                Logger.LogInformation("SignalR: Joined dashboard group for {Campus}", selectedCampusCode);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to initialize SignalR connection");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !firstRenderComplete)
        {
            firstRenderComplete = true;
            
            if (!hasCampusSelected && string.IsNullOrEmpty(CampusCode))
            {
                try
                {
                    var savedCampus = await JS.InvokeAsync<string>("localStorage.getItem", "reception_campus");
                    if (!string.IsNullOrEmpty(savedCampus))
                    {
                        await SelectCampus(savedCampus);
                        StateHasChanged();
                    }
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Could not load saved campus preference");
                }
            }
        }
    }

    private async Task SelectCampus(string campusCode)
    {
        var campus = availableCampuses.FirstOrDefault(c => 
            c.CampusCode.Equals(campusCode, StringComparison.OrdinalIgnoreCase));
        
        if (campus != null)
        {
            selectedCampusCode = campus.CampusCode;
            selectedCampusName = campus.CampusName;
            selectedCampusId = campus.CampusId;
            hasCampusSelected = true;
            
            await JS.InvokeVoidAsync("localStorage.setItem", "reception_campus", campus.CampusCode);
            await RefreshData();

            // Join SignalR dashboard group for this campus
            if (hubConnection?.State == HubConnectionState.Connected)
            {
                try
                {
                    await hubConnection.InvokeAsync("JoinDashboard", selectedCampusCode);
                    Logger.LogInformation("SignalR: Joined dashboard group for {Campus}", selectedCampusCode);
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Failed to join SignalR dashboard group");
                }
            }
        }
    }

    private void ChangeCampus()
    {
        hasCampusSelected = false;
    }

    private async Task RefreshData()
    {
        if (isLoading) return;
        isLoading = true;

        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            var today = DateTime.Today;

            var todayTransactions = await context.AttendanceTransactions.AsNoTracking()
                .Where(t => t.ScanDateTime.Date == today && t.CampusId == selectedCampusId)
                .OrderByDescending(t => t.ScanDateTime)
                .ToListAsync();

            // Save expanded state before clearing
            expandedPersonIds = onSiteList.Where(p => p.IsExpanded).Select(p => p.IdNumber).ToHashSet();

            onSiteList.Clear();
            var peopleGroups = todayTransactions
                .GroupBy(t => new { t.IdNumber, t.TransactionType })
                .ToList();

            foreach (var group in peopleGroups)
            {
                var scans = group.OrderByDescending(t => t.ScanDateTime).ToList();
                var lastScan = scans.First();
                var firstIn = scans.LastOrDefault(s => s.ScanType == "CAMPUS_IN" || s.ScanType == "LUNCH_IN");

                if (lastScan.ScanType == "CAMPUS_IN" || lastScan.ScanType == "LUNCH_IN")
                {
                    onSiteList.Add(new OnSitePerson
                    {
                        IdNumber = lastScan.IdNumber,
                        FirstName = lastScan.FirstName,
                        LastName = lastScan.LastName,
                        TransactionType = lastScan.TransactionType,
                        LastScanType = lastScan.ScanType,
                        LastScanTime = lastScan.ScanDateTime,
                        CheckInTime = firstIn?.ScanDateTime ?? lastScan.ScanDateTime,
                        AllPunches = scans.Select(s => new PunchHistory { ScanType = s.ScanType, ScanDateTime = s.ScanDateTime }).ToList()
                    });
                }
            }

            staffCount = onSiteList.Count(p => p.TransactionType == "STAFF");
            studentCount = onSiteList.Count(p => p.TransactionType == "STUDENT");

            // Restore expanded state
            foreach (var person in onSiteList.Where(p => expandedPersonIds.Contains(p.IdNumber)))
            {
                person.IsExpanded = true;
            }

            recentActivity = todayTransactions.Take(50).Select(t => new ActivityItem
            {
                TransactionId = t.TransactionId,
                IdNumber = t.IdNumber,
                FirstName = t.FirstName,
                LastName = t.LastName,
                TransactionType = t.TransactionType,
                ScanType = t.ScanType,
                ScanDateTime = t.ScanDateTime
            }).ToList();

            // Get last scanned person and photo
            lastScannedPerson = todayTransactions.FirstOrDefault();
            if (lastScannedPerson != null)
            {
                int? dcid = null;
                int subjectType = lastScannedPerson.TransactionType == "STAFF" ? 1 : 0;
                
                if (lastScannedPerson.TransactionType == "STAFF")
                {
                    var staff = await context.Staff.AsNoTracking()
                        .FirstOrDefaultAsync(s => s.IdNumber == lastScannedPerson.IdNumber);
                    dcid = staff?.Dcid;
                }
                else
                {
                    var student = await context.Students.AsNoTracking()
                        .FirstOrDefaultAsync(s => s.StudentNumber == lastScannedPerson.IdNumber);
                    dcid = student?.Dcid;
                }
                
                if (dcid.HasValue)
                {
                    var photo = await context.Photos.AsNoTracking()
                        .FirstOrDefaultAsync(p => p.SubjectDcid == dcid.Value && p.SubjectType == subjectType);
                    lastScannedPhoto = photo?.PhotoData != null ? Convert.ToBase64String(photo.PhotoData) : "";
                }
                else
                {
                    lastScannedPhoto = "";
                }
            }

            lastRefresh = DateTime.Now;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error refreshing reception data");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenManualEntry()
    {
        manualSearchTerm = "";
        searchResults.Clear();
        selectedPerson = null;
        manualScanType = "CAMPUS_IN";
        manualTime = TimeOnly.FromDateTime(DateTime.Now);
        manualNotes = "";
        manualEntryError = null;
        showManualEntryModal = true;
    }

    private void CloseManualEntry()
    {
        showManualEntryModal = false;
    }

    private async Task SearchPeople(KeyboardEventArgs e)
    {
        if (string.IsNullOrWhiteSpace(manualSearchTerm) || manualSearchTerm.Length < 2)
        {
            searchResults.Clear();
            return;
        }

        using var context = await DbFactory.CreateDbContextAsync();
        var term = manualSearchTerm.ToLower();

        var staffResults = await context.Staff.AsNoTracking()
            .Where(s => (s.FirstName != null && s.FirstName.ToLower().Contains(term)) ||
                        (s.LastName != null && s.LastName.ToLower().Contains(term)) ||
                        (s.IdNumber != null && s.IdNumber.Contains(term)))
            .Take(5)
            .Select(s => new PersonSearchResult
            {
                IdNumber = s.IdNumber ?? "",
                FirstName = s.FirstName ?? "",
                LastName = s.LastName ?? "",
                Type = "STAFF"
            }).ToListAsync();

        var studentResults = await context.Students.AsNoTracking()
            .Where(s => s.IsActive &&
                        ((s.FirstName != null && s.FirstName.ToLower().Contains(term)) ||
                         (s.LastName != null && s.LastName.ToLower().Contains(term)) ||
                         (s.StudentNumber != null && s.StudentNumber.Contains(term))))
            .Take(5)
            .Select(s => new PersonSearchResult
            {
                IdNumber = s.StudentNumber ?? "",
                FirstName = s.FirstName ?? "",
                LastName = s.LastName ?? "",
                Type = "STUDENT"
            }).ToListAsync();

        searchResults = staffResults.Concat(studentResults).ToList();
        StateHasChanged();
    }

    private void SelectPerson(PersonSearchResult person)
    {
        selectedPerson = person;
        searchResults.Clear();
        manualSearchTerm = "";
    }

    private async Task SaveManualEntry()
    {
        if (selectedPerson == null) return;

        manualEntryError = null;

        // Geofence-tightening policy: every manual override must carry a
        // typed reason. Client-side UI disables the button below 5 chars;
        // this is the server-side defense-in-depth check.
        var trimmedReason = (manualNotes ?? string.Empty).Trim();
        if (trimmedReason.Length < 5)
        {
            manualEntryError = "A reason of at least 5 characters is required for manual entries.";
            return;
        }

        try
        {
            using var context = await DbFactory.CreateDbContextAsync();

            var scanDateTime = DateTime.Today.Add(manualTime.ToTimeSpan());

            var transaction = new AttendanceTransaction
            {
                TransactionType = selectedPerson.Type,
                IdNumber = selectedPerson.IdNumber,
                FirstName = selectedPerson.FirstName,
                LastName = selectedPerson.LastName,
                CampusId = selectedCampusId,
                LocationId = 1,
                ScanDateTime = scanDateTime,
                ScanType = manualScanType,
                ScanMethod = "MANUAL",
                TerminalId = 0,
                DataSource = "LOCAL",
                ValidationStatus = "VALID",
                Notes = $"[Manual Entry by {currentUserName}] {trimmedReason}",
                CreatedDate = DateTime.Now
            };

            context.AttendanceTransactions.Add(transaction);
            await context.SaveChangesAsync();

            // Geofence-tightening: separate audit row for every manual override
            // so the ScanMethod=MANUAL path is searchable and reviewable
            // independently of the transaction Notes field.
            await Audit.LogActionAsync(
                actionCode: AuditActions.Attendance.ManualOverride,
                entityType: AuditEntityTypes.AttendanceTx,
                entityId: transaction.TransactionId.ToString(),
                newValues: new
                {
                    transaction.TransactionId,
                    PersonType = selectedPerson.Type,
                    selectedPerson.IdNumber,
                    PersonName = $"{selectedPerson.FirstName} {selectedPerson.LastName}",
                    CampusId = selectedCampusId,
                    CampusCode = selectedCampusCode,
                    ScanType = manualScanType,
                    ScanDateTime = scanDateTime.ToString("yyyy-MM-dd HH:mm:ss"),
                    ReasonLength = trimmedReason.Length
                },
                reason: trimmedReason,
                deltaSummary:
                    $"Manual {manualScanType} recorded for {selectedPerson.FirstName} {selectedPerson.LastName} "
                    + $"(ID {selectedPerson.IdNumber}) at {scanDateTime:h:mm tt} by {currentUserName}",
                source: AuditSource.AdminUi,
                campusId: selectedCampusId);

            Logger.LogInformation(
                "Manual entry (override) created by {User}: {Person} {Type} at {Time} \u2014 reason: {Reason}",
                currentUserEmail, selectedPerson.IdNumber, manualScanType, scanDateTime, trimmedReason);

            CloseManualEntry();
            await RefreshData();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving manual entry");
            manualEntryError = "Failed to save entry. Please try again.";
            StateHasChanged();
        }
    }

    private void OpenCorrection(OnSitePerson person)
    {
        correctionPerson = person;
        correctionScanType = person.LastScanType == "CAMPUS_IN" ? "CAMPUS_OUT" : "CAMPUS_IN";
        correctionTime = TimeOnly.FromDateTime(DateTime.Now);
        correctionNotes = "";
        correctionError = null;
        showCorrectionModal = true;
    }

    private void CloseCorrection()
    {
        showCorrectionModal = false;
        correctionPerson = null;
    }

    private async Task SaveCorrection()
    {
        if (correctionPerson == null || string.IsNullOrWhiteSpace(correctionNotes)) return;

        correctionError = null;

        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            
            var scanDateTime = DateTime.Today.Add(correctionTime.ToTimeSpan());
            
            var transaction = new AttendanceTransaction
            {
                TransactionType = correctionPerson.TransactionType,
                IdNumber = correctionPerson.IdNumber,
                FirstName = correctionPerson.FirstName,
                LastName = correctionPerson.LastName,
                CampusId = selectedCampusId,
                LocationId = 1,
                ScanDateTime = scanDateTime,
                ScanType = correctionScanType,
                ScanMethod = "MANUAL",
                TerminalId = 0,
                DataSource = "LOCAL",
                ValidationStatus = "CORRECTED",
                Notes = $"[Correction by {currentUserName}] {correctionNotes}",
                CreatedDate = DateTime.Now
            };

            context.AttendanceTransactions.Add(transaction);
            await context.SaveChangesAsync();

            Logger.LogInformation("Correction made by {User}: {Person} - {Type} at {Time}. Reason: {Reason}",
                currentUserEmail, correctionPerson.IdNumber, correctionScanType, scanDateTime, correctionNotes);

            CloseCorrection();
            await RefreshData();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving correction");
            correctionError = "Failed to save correction. Please try again.";
            StateHasChanged();
        }
    }

    private void QuickCheckOut(OnSitePerson person)
    {
        correctionPerson = person;
        correctionScanType = "CAMPUS_OUT";
        correctionTime = TimeOnly.FromDateTime(DateTime.Now);
        correctionNotes = "Check-out from reception";
        showCorrectionModal = true;
    }

    private static string FormatDuration(DateTime checkInTime)
    {
        var duration = DateTime.Now - checkInTime;
        if (duration.TotalHours >= 1)
            return $"{(int)duration.TotalHours}h {duration.Minutes}m";
        return $"{duration.Minutes}m";
    }

    private static string GetActivityIcon(string scanType) => scanType switch
    {
        "CAMPUS_IN" => "➡️",
        "CAMPUS_OUT" => "⬅️",
        "LUNCH_OUT" => "🍽️",
        "LUNCH_IN" => "🔙",
        _ => "📍"
    };

    private void SortBy(string column)
    {
        if (sortColumn == column)
        {
            sortAscending = !sortAscending;
        }
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
    }

    private string SortIndicator(string column)
    {
        if (sortColumn != column) return "";
        return sortAscending ? " ▲" : " ▼";
    }

    private void ToggleExpand(OnSitePerson person)
    {
        person.IsExpanded = !person.IsExpanded;
        StateHasChanged();
    }

    private static string GetInitial(string? name)
    {
        if (string.IsNullOrEmpty(name)) return "?";
        return name[0].ToString().ToUpper();
    }

    private static string FormatScanType(string scanType) => scanType switch
    {
        "CAMPUS_IN" => "In",
        "CAMPUS_OUT" => "Out",
        "LUNCH_OUT" => "Lunch",
        "LUNCH_IN" => "Back",
        _ => scanType
    };

    public async ValueTask DisposeAsync()
    {
        refreshTimer?.Stop();
        refreshTimer?.Dispose();
        
        // Dispose SignalR connection
        if (hubConnection != null)
        {
            try
            {
                await hubConnection.DisposeAsync();
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Error disposing SignalR connection");
            }
        }
    }

