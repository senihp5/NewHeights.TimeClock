@page "/my/sub-timesheet"
@page "/my/sub-timesheet/{PeriodOffset:int}"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using NewHeights.TimeClock.Data
@using NewHeights.TimeClock.Data.Entities
@using NewHeights.TimeClock.Shared.Constants
@using NewHeights.TimeClock.Shared.Enums
@using NewHeights.TimeClock.Web.Services
@using System.Security.Claims
@attribute [Authorize(Policy = "RequireHourly")]
@rendermode InteractiveServer
@inject IDbContextFactory<TimeClockDbContext> DbFactory
@inject ISubstituteTimesheetService SubTimesheetService
@inject IPayPeriodService PayPeriodService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ILogger<MySubTimesheet> Logger

<PageTitle>My Sub Timesheet - @AppConstants.Branding.ShortName</PageTitle>

<div class="sub-timesheet-page">

    <header class="sub-timesheet-header">
        <div class="header-accent"></div>
        <div class="header-inner">
            <div class="header-brand">
                <img src="/images/logo.jpg" alt="New Heights" class="header-logo" />
                <div class="header-title-block">
                    <h1>Substitute Time Sheet</h1>
                    <p class="header-subtitle">
                        Track the periods you covered today. Approval routes to the campus where you checked in.
                    </p>
                </div>
            </div>
            <a class="btn-home" href="/" title="Home">🏠 Home</a>
        </div>
    </header>

    <div class="employee-info-bar">
        <div class="info-item">
            <span class="info-label">Name:</span>
            <span class="info-value">@employeeName</span>
        </div>
        <div class="info-item">
            <span class="info-label">Pay Period:</span>
            <span class="info-value">@(currentPayPeriod?.PeriodName ?? "—")</span>
        </div>
        @if (currentPayPeriod != null && periodOffset == 0 && !currentPayPeriod.IsPastDeadline)
        {
            <div class="info-item deadline @(currentPayPeriod.DaysUntilDeadline <= 2 ? "urgent" : "")">
                <span class="info-label">Deadline:</span>
                <span class="info-value">
                    @currentPayPeriod.EmployeeDeadline.ToString("dddd, MMM d")
                    (@currentPayPeriod.DaysUntilDeadline day@(currentPayPeriod.DaysUntilDeadline == 1 ? "" : "s"))
                </span>
            </div>
        }
        <div class="info-item history-shortcut">
            <button type="button" class="btn-history-inline" @onclick="OpenHistory"
                    disabled="@(employeeId == 0 || currentPayPeriod == null)">
                View My History
            </button>
        </div>
    </div>

    <div class="period-navigation">
        <label for="mysub-pp-picker" class="pp-label">Pay Period:</label>
        <select id="mysub-pp-picker" class="btn-nav pp-select"
                value="@selectedPayPeriodId"
                @onchange="OnPayPeriodChangedAsync"
                disabled="@isLoading">
            @foreach (var p in availablePeriods)
            {
                <option value="@p.PayPeriodId">
                    @p.PeriodName (@p.StartDate.ToString("MMM d") – @p.EndDate.ToString("MMM d, yyyy"))
                    @(p.IsOpen ? " · Current" : "")
                </option>
            }
        </select>
    </div>

    @if (!string.IsNullOrEmpty(actionError))
    {
        <div class="error-panel" role="alert">@actionError</div>
    }

    @if (isLoading)
    {
        <div class="loading">Loading sub timesheet...</div>
    }
    else if (!string.IsNullOrEmpty(loadError))
    {
        <div class="error-panel">@loadError</div>
    }
    else
    {
        @* Hero CTA: when today is in window, no card exists yet, and it's the current period *@
        @if (periodOffset == 0 && todayCard == null && HasTodayInWindow())
        {
            <div class="hero-cta @(todayCheckInCampusId.HasValue ? "ready" : "needs-campus")">
                <div class="hero-left">
                    <div class="hero-eyebrow">Today — @DateTime.Today.ToString("dddd, MMM d")</div>
                    @if (todayCheckInCampusId.HasValue)
                    {
                        <h2 class="hero-title">You're checked in at <span class="hero-campus">@GetCampusName(todayCheckInCampusId.Value)</span></h2>
                        <p class="hero-sub">Log the first period you covered to start today's timecard.</p>
                    }
                    else
                    {
                        <h2 class="hero-title">Ready to log a period?</h2>
                        <p class="hero-sub">
                            You're not checked in at a campus yet today. Pick a campus below to start today's timecard
                            — or check in at a kiosk first.
                        </p>
                    }
                </div>
                <div class="hero-right">
                    @if (todayCheckInCampusId.HasValue)
                    {
                        <button class="btn-hero-primary"
                                @onclick="() => OpenPickerForTodayAsync(todayCheckInCampusId.Value)"
                                disabled="@isOpeningToday">
                            @(isOpeningToday ? "Opening…" : "+ Log First Period")
                        </button>
                    }
                    else
                    {
                        <div class="hero-campus-picker">
                            <label for="hero-campus-select">Campus for today</label>
                            <select id="hero-campus-select" @bind="selectedTodayCampusId" disabled="@isOpeningToday">
                                <option value="0">— Select —</option>
                                @foreach (var kv in campusNameById.OrderBy(kv => kv.Value))
                                {
                                    <option value="@kv.Key">@kv.Value</option>
                                }
                            </select>
                            <button class="btn-hero-primary"
                                    @onclick="HandleTodayPickerFromManualCampusAsync"
                                    disabled="@(selectedTodayCampusId <= 0 || isOpeningToday)">
                                @(isOpeningToday ? "Opening…" : "+ Log First Period")
                            </button>
                        </div>
                    }
                </div>
            </div>
        }
        else if (cards.Count == 0)
        {
            <div class="empty-state">
                <h3>No substitute timecards in this pay period.</h3>
                <p>When you cover a period, it will appear here after you log it.</p>
            </div>
        }

        @foreach (var card in GetCardsOrderedByDate())
        {
            var isApproved = card.ApprovalStatus == ApprovalStatus.Approved;
            var isLocked = card.ApprovalStatus == ApprovalStatus.Locked;
            var isEditable = !isApproved && !isLocked;
            var times = checkInOutByCardId.TryGetValue(card.SubTimecardId, out var t) ? t : (In: (TimeOnly?)null, Out: (TimeOnly?)null);
            var teacherGroups = GroupEntriesByTeacher(card).ToList();

            <div class="day-card @(isApproved ? "approved" : "") @(isLocked ? "locked" : "")">
                <div class="day-card-header">
                    <div class="day-card-header-top">
                        <div class="day-card-heading">
                            <span class="day-date">@card.WorkDate.ToString("dddd, MMM d")</span>
                            <span class="day-campus">@(card.Campus?.CampusName ?? GetCampusName(card.CampusId))</span>
                        </div>
                        <span class="cm-status status-@card.ApprovalStatus.ToString().ToLower()"
                              title="Campus Manager approval">
                            CM: @card.ApprovalStatus
                        </span>
                    </div>
                    <div class="day-card-header-bottom">
                        <span class="checkin-pill">
                            <span class="ci-label">Check-In:</span>
                            <span class="ci-value">@(times.In?.ToString("h:mm tt") ?? "—")</span>
                        </span>
                        <span class="checkin-pill">
                            <span class="ci-label">Check-Out:</span>
                            <span class="ci-value">@(times.Out?.ToString("h:mm tt") ?? "—")</span>
                        </span>
                        <button type="button" class="btn-fix-times"
                                disabled="@(!isEditable)"
                                title="Submit a correction if your check-in or check-out time is wrong">
                            Fix Times
                        </button>
                    </div>
                </div>

                <div class="day-card-body">
                    @if (teacherGroups.Count == 0)
                    {
                        <p class="no-periods">No periods logged yet for this day.</p>
                    }
                    else
                    {
                        <table class="coverage-matrix">
                            <thead>
                                <tr>
                                    <th class="col-teacher">Teacher Covered</th>
                                    @foreach (var p in PeriodColumns)
                                    {
                                        <th class="col-period">P@(p)</th>
                                    }
                                    <th class="col-content">Content</th>
                                    <th class="col-room">Room</th>
                                    <th class="col-notecount">Notes</th>
                                    <th class="col-expand"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var tg in teacherGroups)
                                {
                                    var expanded = IsTeacherExpanded(tg.CardId, tg.TeacherEmployeeId, tg.TeacherName);
                                    var noteCount = tg.Entries.Count(e => !string.IsNullOrWhiteSpace(e.Notes));
                                    <tr class="teacher-summary-row @(expanded ? "expanded" : "")"
                                        @onclick="() => ToggleTeacherExpand(tg.CardId, tg.TeacherEmployeeId, tg.TeacherName)">
                                        <td class="teacher-cell">
                                            <strong>@tg.TeacherName</strong>
                                            @if (tg.TeacherEmployeeId.HasValue)
                                            {
                                                <span class="teacher-id-chip" title="HR Ascender match">#@tg.TeacherEmployeeId</span>
                                            }
                                        </td>
                                        @foreach (var p in PeriodColumns)
                                        {
                                            var entry = tg.EntryFor(p);
                                            <td class="period-cell @(entry != null ? "checked" : "empty")">
                                                @(entry != null ? "✓" : "—")
                                            </td>
                                        }
                                        <td class="content-cell">@(tg.ContentArea ?? "—")</td>
                                        <td class="room-cell">@(tg.Room ?? "—")</td>
                                        <td class="notecount-cell">
                                            @if (noteCount > 0)
                                            {
                                                <span class="note-badge">@noteCount</span>
                                            }
                                            else
                                            {
                                                <span class="muted">0</span>
                                            }
                                        </td>
                                        <td class="expand-cell">
                                            <span class="expand-arrow">@(expanded ? "▼" : "▶")</span>
                                        </td>
                                    </tr>
                                    @if (expanded)
                                    {
                                        <tr class="teacher-detail-row">
                                            <td colspan="@(PeriodColumns.Length + 5)">
                                                <div class="teacher-detail-grid">
                                                    @foreach (var entry in tg.Entries)
                                                    {
                                                        var isEditingThisNotes = editingNotesEntryId == entry.EntryId;
                                                        var isConfirmingThisRemove = confirmingRemoveEntryId == entry.EntryId;
                                                        <div class="period-detail-card">
                                                            <div class="period-detail-head">
                                                                <span class="pd-period">P@(entry.PeriodNumber) · @entry.PeriodName</span>
                                                                <span class="pd-time">@entry.StartTime.ToString("h:mm") – @entry.EndTime.ToString("h:mm tt")</span>
                                                                <span class="session-badge session-@entry.SessionType.ToLower()">@entry.SessionType</span>
                                                            </div>
                                                            @if (!string.IsNullOrWhiteSpace(entry.CourseName))
                                                            {
                                                                <div class="pd-row"><span class="pd-lbl">Course:</span> @entry.CourseName</div>
                                                            }
                                                            <div class="pd-notes @(isEditingThisNotes ? "editing" : "")">
                                                                <span class="pd-lbl">Notes:</span>
                                                                @if (isEditingThisNotes)
                                                                {
                                                                    <textarea class="inline-notes"
                                                                              @bind="editedNotes"
                                                                              rows="2"
                                                                              maxlength="500"
                                                                              disabled="@isSavingNotes"></textarea>
                                                                }
                                                                else
                                                                {
                                                                    <span class="pd-notes-text">@(string.IsNullOrWhiteSpace(entry.Notes) ? "(none)" : entry.Notes)</span>
                                                                }
                                                            </div>
                                                            <div class="pd-actions">
                                                                @if (!isEditable)
                                                                {
                                                                    <span class="muted">Locked</span>
                                                                }
                                                                else if (isEditingThisNotes)
                                                                {
                                                                    <button type="button" class="btn-inline-save"
                                                                            @onclick:stopPropagation="true"
                                                                            @onclick="() => SaveNotesAsync(entry)"
                                                                            disabled="@isSavingNotes">
                                                                        @(isSavingNotes ? "Saving…" : "Save")
                                                                    </button>
                                                                    <button type="button" class="btn-inline-cancel"
                                                                            @onclick:stopPropagation="true"
                                                                            @onclick="CancelEditNotes"
                                                                            disabled="@isSavingNotes">Cancel</button>
                                                                }
                                                                else if (isConfirmingThisRemove)
                                                                {
                                                                    <button type="button" class="btn-confirm-remove"
                                                                            @onclick:stopPropagation="true"
                                                                            @onclick="() => ConfirmRemoveAsync(entry)"
                                                                            disabled="@isRemoving">
                                                                        @(isRemoving ? "Removing…" : "Confirm Remove")
                                                                    </button>
                                                                    <button type="button" class="btn-inline-cancel"
                                                                            @onclick:stopPropagation="true"
                                                                            @onclick="CancelRemove"
                                                                            disabled="@isRemoving">Cancel</button>
                                                                }
                                                                else
                                                                {
                                                                    <button type="button" class="btn-inline-edit"
                                                                            @onclick:stopPropagation="true"
                                                                            @onclick="() => BeginEditNotes(entry)"
                                                                            title="Edit notes">Edit Notes</button>
                                                                    <button type="button" class="btn-inline-remove"
                                                                            @onclick:stopPropagation="true"
                                                                            @onclick="() => BeginRemove(entry.EntryId)"
                                                                            title="Remove this period">Remove</button>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    }

                    <div class="day-card-footer">
                        <span class="period-count">
                            @card.TotalPeriodsWorked period@(card.TotalPeriodsWorked == 1 ? "" : "s") worked
                            · @teacherGroups.Count @(teacherGroups.Count == 1 ? "teacher" : "teachers") covered
                        </span>
                        @if (isEditable)
                        {
                            <button class="btn-add-period" @onclick="() => OpenPickerForCard(card)">
                                + Add Period
                            </button>
                        }
                        else
                        {
                            <span class="read-only-note">Card is @card.ApprovalStatus.ToString().ToLower() — no further edits.</span>
                        }
                    </div>
                </div>
            </div>
        }

        @* If today's card already exists, we're checked in today but the hero is gone — surface a compact "log another period for today" bar. *@
        @if (periodOffset == 0 && todayCard != null
             && todayCard.ApprovalStatus != ApprovalStatus.Approved
             && todayCard.ApprovalStatus != ApprovalStatus.Locked)
        {
            <div class="today-quick-add">
                <span class="today-quick-label">
                    Need to log another period for today
                    (<strong>@GetCampusName(todayCard.CampusId)</strong>)?
                </span>
                <button class="btn-hero-primary btn-hero-compact"
                        @onclick="() => OpenPickerForCard(todayCard)">
                    + Add Period
                </button>
            </div>
        }

        <div class="pay-period-summary">
            <strong>Pay Period Summary:</strong>
            @cards.Sum(c => c.TotalPeriodsWorked) period@(cards.Sum(c => c.TotalPeriodsWorked) == 1 ? "" : "s")
            across @cards.Count @(cards.Count == 1 ? "day" : "days")
            @if (cards.Select(c => c.CampusId).Distinct().Count() > 1)
            {
                <span class="cross-campus-note"> (across multiple campuses)</span>
            }
        </div>
    }

</div>

<SubPeriodPickerModal Visible="@showPicker"
                      CampusId="@pickerCampusId"
                      WorkDate="@pickerWorkDate"
                      ExistingEntries="@pickerExistingEntries"
                      OnSave="HandlePickerSaveAsync"
                      OnCancel="HandlePickerCancel" />

<AuditHistoryPanel Visible="@showHistory"
                   EmployeeId="@employeeId"
                   EmployeeName="@employeeName"
                   FromDate="@(currentPayPeriod?.StartDate ?? DateOnly.FromDateTime(DateTime.Today))"
                   ToDate="@(currentPayPeriod?.EndDate ?? DateOnly.FromDateTime(DateTime.Today))"
                   OnClose="CloseHistory" />

@code {
    [Parameter] public int? PeriodOffset { get; set; }

    private int periodOffset = 0;
    private bool isLoading = true;
    private string loadError = "";

    private int employeeId;
    private string employeeName = "";
    private string currentUserEmail = "";
    private string currentUserEntraOid = "";
    private EmployeeType employeeType = EmployeeType.HourlyStaff;

    private PayPeriodInfo? currentPayPeriod;

    // Pay-period dropdown (replaced prev/next buttons 2026-04-24).
    private List<PayPeriodInfo> availablePeriods = new();
    private int selectedPayPeriodId = 0;

    private List<TcSubstituteTimecard> cards = new();
    private TcSubstituteTimecard? todayCard;
    private int? todayCheckInCampusId;

    private Dictionary<int, string> campusNameById = new();

    // ── Date-grouped redesign state (Phase 1) ─────────────────────────────
    // Per-card check-in/out times derived from TcTimePunches (first-in, last-out).
    private Dictionary<long, (TimeOnly? In, TimeOnly? Out)> checkInOutByCardId = new();
    // Teacher-row expansion keys: "{cardId}:{teacherEmpId or 0}:{teacherName}"
    private HashSet<string> expandedTeacherKeys = new();

    private static readonly int[] PeriodColumns = new[] { 1, 2, 3, 4, 5, 6 };

    private string BuildTeacherKey(long cardId, int? teacherEmployeeId, string teacherName)
        => $"{cardId}:{teacherEmployeeId ?? 0}:{teacherName ?? ""}";

    private bool IsTeacherExpanded(long cardId, int? teacherEmployeeId, string teacherName)
        => expandedTeacherKeys.Contains(BuildTeacherKey(cardId, teacherEmployeeId, teacherName));

    private void ToggleTeacherExpand(long cardId, int? teacherEmployeeId, string teacherName)
    {
        var key = BuildTeacherKey(cardId, teacherEmployeeId, teacherName);
        if (!expandedTeacherKeys.Add(key))
            expandedTeacherKeys.Remove(key);
    }

    /// <summary>Group a card's period entries by the teacher being covered.</summary>
    private IEnumerable<TeacherCoverageGroup> GroupEntriesByTeacher(TcSubstituteTimecard card)
    {
        return card.PeriodEntries
            .GroupBy(e => new {
                Id   = e.TeacherReplacedEmployeeId,
                Name = e.TeacherReplaced ?? "(Unknown teacher)"
            })
            .Select(g => new TeacherCoverageGroup
            {
                CardId            = card.SubTimecardId,
                TeacherEmployeeId = g.Key.Id,
                TeacherName       = g.Key.Name,
                // Show ALL distinct content tags for this teacher's periods
                // (e.g. "LAUNCH, ENG" when they teach PROF COMM in one period
                // and ENG 4B in another). Previously collapsed to FirstOrDefault
                // which hid the mixed-subject case entirely.
                ContentArea       = FormatDistinctTags(g.Select(e => e.ContentArea)),
                Room              = g.FirstOrDefault(e => !string.IsNullOrWhiteSpace(e.Room))?.Room,
                Entries           = g.OrderBy(e => e.PeriodNumber).ToList()
            })
            .OrderBy(tg => tg.Entries.FirstOrDefault()?.PeriodNumber ?? 99)
            .ThenBy(tg => tg.TeacherName);
    }

    private static string? FormatDistinctTags(IEnumerable<string?> values)
    {
        var distinct = values
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Select(x => x!.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
        return distinct.Count == 0 ? null : string.Join(", ", distinct);
    }

    private class TeacherCoverageGroup
    {
        public long CardId { get; set; }
        public int? TeacherEmployeeId { get; set; }
        public string TeacherName { get; set; } = "";
        public string? ContentArea { get; set; }
        public string? Room { get; set; }
        public List<TcSubstitutePeriodEntry> Entries { get; set; } = new();

        /// <summary>Returns the entry for a given period number, or null.</summary>
        public TcSubstitutePeriodEntry? EntryFor(int periodNumber)
            => Entries.FirstOrDefault(e => e.PeriodNumber == periodNumber);
    }

    // ── Picker modal state ────────────────────────────────────────────────
    private bool showPicker = false;
    private int pickerCampusId = 0;
    private DateOnly pickerWorkDate;
    private long? pickerCardId = null;
    private IReadOnlyList<TcSubstitutePeriodEntry>? pickerExistingEntries = null;

    // Today-prompt inline campus picker + loading flag.
    private int selectedTodayCampusId = 0;
    private bool isOpeningToday = false;

    // Surface for action-level failures (AddPeriod throws, etc).
    private string actionError = "";

    // ── Remove-entry flow state ───────────────────────────────────────────
    private long? confirmingRemoveEntryId = null;
    private bool isRemoving = false;

    // ── Edit-notes flow state ─────────────────────────────────────────────
    private long? editingNotesEntryId = null;
    private string editedNotes = "";
    private bool isSavingNotes = false;

    // ── History panel state ───────────────────────────────────────────────
    private bool showHistory = false;

    protected override async Task OnInitializedAsync()
    {
        periodOffset = PeriodOffset ?? 0;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUserEmail = user.FindFirst("preferred_username")?.Value
                        ?? user.FindFirst(ClaimTypes.Email)?.Value
                        ?? "";
        currentUserEntraOid = user.FindFirst("oid")?.Value
                           ?? user.FindFirst("http://schemas.microsoft.com/identity/claims/objectidentifier")?.Value
                           ?? "";

        // Populate pay-period dropdown; seed selection from URL offset for
        // back-compat with /my/sub-timesheet/{offset} deep links.
        availablePeriods = await PayPeriodService.GetRecentPayPeriodsAsync();
        var initialAnchor = DateTime.Today.AddDays(periodOffset * 14);
        var initialPeriod = await PayPeriodService.GetPayPeriodForDateAsync(initialAnchor);
        selectedPayPeriodId = availablePeriods.Any(p => p.PayPeriodId == initialPeriod.PayPeriodId)
            ? initialPeriod.PayPeriodId
            : availablePeriods.FirstOrDefault(p => p.IsOpen)?.PayPeriodId ?? availablePeriods.FirstOrDefault()?.PayPeriodId ?? 0;

        await LoadData();
    }

    private async Task OnPayPeriodChangedAsync(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var id)) return;
        selectedPayPeriodId = id;
        await LoadData();
    }

    protected override async Task OnParametersSetAsync()
    {
        var incoming = PeriodOffset ?? 0;
        if (incoming != periodOffset)
        {
            periodOffset = incoming;
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        isLoading = true;
        loadError = "";

        try
        {
            using var context = await DbFactory.CreateDbContextAsync();

            // Multi-step lookup: EntraObjectId (stable) → case-insensitive
            // Email (handles casing/renames). Matches the pattern used on
            // MyTimesheet, AbsenceRequest, MyRequests, ClassNotes, and
            // MobileCheckin so test subs + any Staff-less employees resolve
            // consistently. Sync-created subs always have EntraObjectId set.
            TcEmployee? employee = null;

            if (!string.IsNullOrWhiteSpace(currentUserEntraOid))
            {
                employee = await context.TcEmployees
                    .Include(e => e.Staff)
                    .FirstOrDefaultAsync(e => e.EntraObjectId == currentUserEntraOid && e.IsActive);
            }

            if (employee == null && !string.IsNullOrWhiteSpace(currentUserEmail))
            {
                var emailLower = currentUserEmail.Trim().ToLower();
                employee = await context.TcEmployees
                    .Include(e => e.Staff)
                    .FirstOrDefaultAsync(e => e.Email != null
                                           && e.Email.ToLower() == emailLower
                                           && e.IsActive);
            }

            if (employee == null)
            {
                loadError = "Your employee record was not found. Contact your supervisor.";
                return;
            }

            employeeId = employee.EmployeeId;
            employeeName = employee.Staff?.FullName
                        ?? employee.DisplayName
                        ?? employee.Email
                        ?? "Unknown";
            employeeType = employee.EmployeeType;

            if (employeeType != EmployeeType.Substitute)
            {
                Logger.LogInformation(
                    "Non-substitute {Email} (type {Type}) redirected from /my/sub-timesheet to /my/timesheet.",
                    currentUserEmail, employeeType);
                Navigation.NavigateTo("/my/timesheet", forceLoad: false);
                return;
            }

            // Resolve pay period from the dropdown selection. Fall back to
            // today's period if the selection isn't in the list for any reason.
            currentPayPeriod = availablePeriods.FirstOrDefault(p => p.PayPeriodId == selectedPayPeriodId);
            if (currentPayPeriod == null)
            {
                currentPayPeriod = await PayPeriodService.GetCurrentPayPeriodAsync();
                if (currentPayPeriod == null)
                {
                    loadError = "Could not resolve pay period for this date.";
                    return;
                }
                selectedPayPeriodId = currentPayPeriod.PayPeriodId;
            }

            cards = await SubTimesheetService.GetCardsForPayPeriodAsync(
                employeeId, currentPayPeriod.StartDate, currentPayPeriod.EndDate);

            campusNameById = await context.Campuses
                .AsNoTracking()
                .ToDictionaryAsync(c => c.CampusId, c => c.CampusName);

            var today = DateOnly.FromDateTime(DateTime.Today);

            // Auto-populate from any matching TcSubRequestAssignments every time
            // the sub loads their timesheet. Idempotent — the service only inserts
            // periods that aren't already on the card, and skips Approved/Locked
            // cards entirely. This self-heals the case where an assignment was
            // created AFTER the sub's kiosk check-in fired (e.g., a supervisor
            // assigned them manually later, or the assignment's campus was
            // corrected). Only runs when we're viewing the current period to
            // avoid doing rework on historical months.
            if (periodOffset == 0)
            {
                foreach (var card in cards.Where(c =>
                    c.ApprovalStatus != ApprovalStatus.Approved
                 && c.ApprovalStatus != ApprovalStatus.Locked))
                {
                    try
                    {
                        await SubTimesheetService.AutoPopulatePreAssignedAsync(card.SubTimecardId);
                    }
                    catch (Exception autoEx)
                    {
                        // Never break timesheet load over auto-populate failure.
                        Logger.LogWarning(autoEx,
                            "AutoPopulatePreAssignedAsync failed on card {CardId} during timesheet load for {Email}",
                            card.SubTimecardId, currentUserEmail);
                    }
                }

                // Refresh the cards list if auto-populate added any period rows.
                cards = await SubTimesheetService.GetCardsForPayPeriodAsync(
                    employeeId, currentPayPeriod.StartDate, currentPayPeriod.EndDate);
            }

            todayCard = cards.FirstOrDefault(c => c.WorkDate == today);

            // Batch-fetch all active IN/OUT punches for the pay period so each
            // date card can show first-in / last-out (Phase 1 of sub timesheet
            // redesign — gives the sub and HR a single-glance "were they here?"
            // reading instead of forcing drill-in). One query per period, not
            // one per card.
            checkInOutByCardId.Clear();
            var periodStart = currentPayPeriod.StartDate.ToDateTime(TimeOnly.MinValue);
            var periodEnd   = currentPayPeriod.EndDate.ToDateTime(TimeOnly.MaxValue);

            var periodPunches = await context.TcTimePunches
                .AsNoTracking()
                .Where(p => p.EmployeeId == employeeId
                         && p.PunchDateTime >= periodStart
                         && p.PunchDateTime <= periodEnd
                         && p.PunchStatus == PunchStatus.Active
                         && (p.PunchType == PunchType.In || p.PunchType == PunchType.Out))
                .OrderBy(p => p.PunchDateTime)
                .ToListAsync();

            foreach (var card in cards)
            {
                var forCard = periodPunches
                    .Where(p => p.CampusId == card.CampusId
                             && DateOnly.FromDateTime(p.PunchDateTime) == card.WorkDate)
                    .ToList();
                var firstIn = forCard.FirstOrDefault(p => p.PunchType == PunchType.In);
                var lastOut = forCard.LastOrDefault(p => p.PunchType == PunchType.Out);
                checkInOutByCardId[card.SubTimecardId] = (
                    firstIn != null ? TimeOnly.FromDateTime(firstIn.PunchDateTime) : (TimeOnly?)null,
                    lastOut != null ? TimeOnly.FromDateTime(lastOut.PunchDateTime) : (TimeOnly?)null);
            }

            if (periodOffset == 0)
                todayCheckInCampusId = await SubTimesheetService.GetCampusIdFromTodayCheckInAsync(employeeId);
            else
                todayCheckInCampusId = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading sub timesheet for {Email}", currentUserEmail);
            loadError = "Unable to load your sub timesheet. Please refresh and try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private IEnumerable<TcSubstituteTimecard> GetCardsOrderedByDate()
        => cards.OrderBy(c => c.WorkDate).ThenBy(c => c.CampusId);

    private string GetCampusName(int campusId)
        => campusNameById.TryGetValue(campusId, out var name) ? name : $"Campus {campusId}";

    private bool HasTodayInWindow()
    {
        if (currentPayPeriod == null) return false;
        var today = DateOnly.FromDateTime(DateTime.Today);
        return today >= currentPayPeriod.StartDate && today <= currentPayPeriod.EndDate;
    }

    // PreviousPeriod / NextPeriod removed 2026-04-24 in favor of the pay-period
    // dropdown. OnPayPeriodChangedAsync is the single entry point for nav.

    // ── Picker open handlers ──────────────────────────────────────────────

    private void OpenPickerForCard(TcSubstituteTimecard card)
    {
        actionError = "";
        pickerCampusId = card.CampusId;
        pickerWorkDate = card.WorkDate;
        pickerCardId = card.SubTimecardId;
        pickerExistingEntries = card.PeriodEntries.ToList();
        showPicker = true;
    }

    private async Task OpenPickerForTodayAsync(int campusId)
    {
        if (isOpeningToday) return;
        if (campusId <= 0)
        {
            actionError = "Please choose a campus before adding a period.";
            return;
        }

        isOpeningToday = true;
        actionError = "";
        try
        {
            var card = await SubTimesheetService.GetOrCreateTodayCardAsync(employeeId, campusId);

            await LoadData();

            pickerCampusId = campusId;
            pickerWorkDate = DateOnly.FromDateTime(DateTime.Today);
            pickerCardId = card.SubTimecardId;
            pickerExistingEntries = todayCard?.PeriodEntries.ToList()
                                    ?? new List<TcSubstitutePeriodEntry>();
            showPicker = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex,
                "OpenPickerForTodayAsync failed for employee {EmployeeId} campus {Campus}",
                employeeId, campusId);
            actionError = "Could not start today's timecard. Refresh and try again.";
        }
        finally
        {
            isOpeningToday = false;
        }
    }

    private async Task HandleTodayPickerFromManualCampusAsync()
    {
        if (selectedTodayCampusId <= 0)
        {
            actionError = "Please pick a campus first.";
            return;
        }
        await OpenPickerForTodayAsync(selectedTodayCampusId);
    }

    // ── Picker callbacks ──────────────────────────────────────────────────

    private async Task HandlePickerSaveAsync(PeriodPickerResult result)
    {
        if (pickerCardId == null)
        {
            actionError = "Lost reference to the open card — refresh and retry.";
            showPicker = false;
            return;
        }

        try
        {
            await SubTimesheetService.AddPeriodEntryAsync(
                subTimecardId: pickerCardId.Value,
                bellPeriodId: result.BellPeriodId,
                masterScheduleId: result.MasterScheduleId,
                sessionType: result.SessionType,
                notes: result.Notes,
                employeeId: employeeId);

            showPicker = false;
            pickerCardId = null;
            pickerExistingEntries = null;

            await LoadData();
        }
        catch (InvalidOperationException ex)
        {
            Logger.LogWarning(ex,
                "AddPeriodEntryAsync rejected for employee {EmployeeId} card {CardId}",
                employeeId, pickerCardId);
            actionError = ex.Message;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex,
                "Unexpected error adding period entry for employee {EmployeeId}", employeeId);
            actionError = "Could not save the period. Please try again.";
        }
    }

    private void HandlePickerCancel()
    {
        showPicker = false;
        pickerCardId = null;
        pickerExistingEntries = null;
    }

    // ── Remove-entry handlers ─────────────────────────────────────────────

    private void BeginRemove(long entryId)
    {
        actionError = "";
        editingNotesEntryId = null;
        editedNotes = "";
        confirmingRemoveEntryId = entryId;
    }

    private void CancelRemove()
    {
        confirmingRemoveEntryId = null;
    }

    private async Task ConfirmRemoveAsync(TcSubstitutePeriodEntry entry)
    {
        if (isRemoving) return;
        isRemoving = true;
        actionError = "";
        try
        {
            await SubTimesheetService.RemovePeriodEntryAsync(entry.EntryId, employeeId);
            confirmingRemoveEntryId = null;
            await LoadData();
        }
        catch (InvalidOperationException ex)
        {
            Logger.LogWarning(ex,
                "RemovePeriodEntryAsync rejected for employee {EmployeeId} entry {EntryId}",
                employeeId, entry.EntryId);
            actionError = ex.Message;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex,
                "Unexpected error removing period entry {EntryId} for employee {EmployeeId}",
                entry.EntryId, employeeId);
            actionError = "Could not remove the period. Please try again.";
        }
        finally
        {
            isRemoving = false;
        }
    }

    // ── Edit-notes handlers ───────────────────────────────────────────────

    private void BeginEditNotes(TcSubstitutePeriodEntry entry)
    {
        actionError = "";
        confirmingRemoveEntryId = null;
        editingNotesEntryId = entry.EntryId;
        editedNotes = entry.Notes ?? "";
    }

    private void CancelEditNotes()
    {
        editingNotesEntryId = null;
        editedNotes = "";
    }

    private async Task SaveNotesAsync(TcSubstitutePeriodEntry entry)
    {
        if (isSavingNotes) return;
        isSavingNotes = true;
        actionError = "";
        try
        {
            await SubTimesheetService.UpdatePeriodNotesAsync(entry.EntryId, editedNotes, employeeId);
            editingNotesEntryId = null;
            editedNotes = "";
            await LoadData();
        }
        catch (InvalidOperationException ex)
        {
            Logger.LogWarning(ex,
                "UpdatePeriodNotesAsync rejected for employee {EmployeeId} entry {EntryId}",
                employeeId, entry.EntryId);
            actionError = ex.Message;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex,
                "Unexpected error updating notes for entry {EntryId} for employee {EmployeeId}",
                entry.EntryId, employeeId);
            actionError = "Could not save the notes. Please try again.";
        }
        finally
        {
            isSavingNotes = false;
        }
    }

    // ── History panel handlers ────────────────────────────────────────────

    private void OpenHistory()
    {
        if (employeeId == 0 || currentPayPeriod == null) return;
        showHistory = true;
    }

    private void CloseHistory()
    {
        showHistory = false;
    }
