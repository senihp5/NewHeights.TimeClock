@page "/my/sub-timesheet"
@page "/my/sub-timesheet/{PeriodOffset:int}"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using NewHeights.TimeClock.Data
@using NewHeights.TimeClock.Data.Entities
@using NewHeights.TimeClock.Shared.Constants
@using NewHeights.TimeClock.Shared.Enums
@using NewHeights.TimeClock.Web.Services
@using System.Security.Claims
@attribute [Authorize(Policy = "RequireHourly")]
@rendermode InteractiveServer
@inject IDbContextFactory<TimeClockDbContext> DbFactory
@inject ISubstituteTimesheetService SubTimesheetService
@inject IPayPeriodService PayPeriodService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ILogger<MySubTimesheet> Logger

<PageTitle>My Sub Timesheet - @AppConstants.Branding.ShortName</PageTitle>

<div class="sub-timesheet-page">

    <header class="sub-timesheet-header">
        <div class="header-brand">
            <img src="/images/logo.jpg" alt="New Heights" class="header-logo" />
            <div>
                <h1>Substitute Time Sheet</h1>
                <p class="header-subtitle">
                    Track periods you covered. Approval routes to the campus where you checked in.
                </p>
            </div>
        </div>
    </header>

    <div class="employee-info-bar">
        <div class="info-item">
            <span class="info-label">Name:</span>
            <span class="info-value">@employeeName</span>
        </div>
        <div class="info-item">
            <span class="info-label">Pay Period:</span>
            <span class="info-value">@(currentPayPeriod?.PeriodName ?? "—")</span>
        </div>
        @if (currentPayPeriod != null && periodOffset == 0 && !currentPayPeriod.IsPastDeadline)
        {
            <div class="info-item deadline @(currentPayPeriod.DaysUntilDeadline <= 2 ? "urgent" : "")">
                <span class="info-label">Deadline:</span>
                <span class="info-value">
                    @currentPayPeriod.EmployeeDeadline.ToString("dddd, MMM d")
                    (@currentPayPeriod.DaysUntilDeadline day@(currentPayPeriod.DaysUntilDeadline == 1 ? "" : "s"))
                </span>
            </div>
        }
    </div>

    <div class="period-navigation">
        <button class="btn-nav" @onclick="PreviousPeriod" disabled="@isLoading">← Previous Period</button>
        <div class="current-period">
            <strong>
                @(currentPayPeriod != null
                    ? $"{currentPayPeriod.StartDate:MMM d} – {currentPayPeriod.EndDate:MMM d, yyyy}"
                    : "—")
            </strong>
            @if (periodOffset == 0)
            {
                <span class="current-badge">Current</span>
            }
        </div>
        <button class="btn-nav" @onclick="NextPeriod" disabled="@(periodOffset >= 0 || isLoading)">Next Period →</button>
    </div>

    @if (!string.IsNullOrEmpty(actionError))
    {
        <div class="error-panel" role="alert">@actionError</div>
    }

    @if (isLoading)
    {
        <div class="loading">Loading sub timesheet...</div>
    }
    else if (!string.IsNullOrEmpty(loadError))
    {
        <div class="error-panel">@loadError</div>
    }
    else
    {
        @if (cards.Count == 0 && (!HasTodayInWindow() || todayCard != null))
        {
            <div class="empty-state">
                <h3>No substitute timecards in this pay period yet.</h3>
                <p>Once you check in at a campus and cover a period, click "Add Period" to log it.</p>
            </div>
        }

        @foreach (var card in GetCardsOrderedByDate())
        {
            var isApproved = card.ApprovalStatus == ApprovalStatus.Approved;
            var isLocked = card.ApprovalStatus == ApprovalStatus.Locked;
            var isEditable = !isApproved && !isLocked;

            <div class="day-card @(isApproved ? "approved" : "") @(isLocked ? "locked" : "")">
                <div class="day-card-header">
                    <span class="day-date">@card.WorkDate.ToString("dddd, MMM d")</span>
                    <span class="day-campus">@(card.Campus?.CampusName ?? GetCampusName(card.CampusId))</span>
                    <span class="day-status status-@card.ApprovalStatus.ToString().ToLower()">
                        @card.ApprovalStatus
                    </span>
                </div>

                <div class="day-card-body">
                    @if (card.PeriodEntries.Count == 0)
                    {
                        <p class="no-periods">No periods logged yet.</p>
                    }
                    else
                    {
                        <table class="period-table">
                            <thead>
                                <tr>
                                    <th>Period</th>
                                    <th>Time</th>
                                    <th>Session</th>
                                    <th>Teacher</th>
                                    <th>Room</th>
                                    <th>Content</th>
                                    <th>Notes</th>
                                    <th class="col-actions">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in card.PeriodEntries.OrderBy(e => e.PeriodNumber))
                                {
                                    var isEditingThisNotes = editingNotesEntryId == entry.EntryId;
                                    var isConfirmingThisRemove = confirmingRemoveEntryId == entry.EntryId;
                                    <tr>
                                        <td><strong>P@(entry.PeriodNumber)</strong> — @entry.PeriodName</td>
                                        <td>
                                            @entry.StartTime.ToString("h:mm") –
                                            @entry.EndTime.ToString("h:mm tt")
                                        </td>
                                        <td><span class="session-badge session-@entry.SessionType.ToLower()">@entry.SessionType</span></td>
                                        <td>@(entry.TeacherReplaced ?? "—")</td>
                                        <td>@(entry.Room ?? "—")</td>
                                        <td>@(entry.ContentArea ?? "—")</td>
                                        <td class="notes-cell @(isEditingThisNotes ? "editing" : "")">
                                            @if (isEditingThisNotes)
                                            {
                                                <textarea class="inline-notes"
                                                          @bind="editedNotes"
                                                          rows="2"
                                                          maxlength="500"
                                                          disabled="@isSavingNotes"></textarea>
                                            }
                                            else
                                            {
                                                @(entry.Notes ?? "")
                                            }
                                        </td>
                                        <td class="actions-cell">
                                            @if (!isEditable)
                                            {
                                                <span class="muted">—</span>
                                            }
                                            else if (isEditingThisNotes)
                                            {
                                                <button type="button" class="btn-inline-save"
                                                        @onclick="() => SaveNotesAsync(entry)"
                                                        disabled="@isSavingNotes">
                                                    @(isSavingNotes ? "Saving…" : "Save")
                                                </button>
                                                <button type="button" class="btn-inline-cancel"
                                                        @onclick="CancelEditNotes"
                                                        disabled="@isSavingNotes">Cancel</button>
                                            }
                                            else if (isConfirmingThisRemove)
                                            {
                                                <button type="button" class="btn-confirm-remove"
                                                        @onclick="() => ConfirmRemoveAsync(entry)"
                                                        disabled="@isRemoving">
                                                    @(isRemoving ? "Removing…" : "Confirm Remove")
                                                </button>
                                                <button type="button" class="btn-inline-cancel"
                                                        @onclick="CancelRemove"
                                                        disabled="@isRemoving">Cancel</button>
                                            }
                                            else
                                            {
                                                <button type="button" class="btn-inline-edit"
                                                        @onclick="() => BeginEditNotes(entry)"
                                                        title="Edit notes">Notes</button>
                                                <button type="button" class="btn-inline-remove"
                                                        @onclick="() => BeginRemove(entry.EntryId)"
                                                        title="Remove this period">Remove</button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }

                    <div class="day-card-footer">
                        <span class="period-count">
                            @card.TotalPeriodsWorked period@(card.TotalPeriodsWorked == 1 ? "" : "s") worked
                        </span>
                        @if (isEditable)
                        {
                            <button class="btn-add-period" @onclick="() => OpenPickerForCard(card)">
                                + Add Period
                            </button>
                        }
                        else
                        {
                            <span class="read-only-note">Card is @card.ApprovalStatus.ToString().ToLower() — no further edits.</span>
                        }
                    </div>
                </div>
            </div>
        }

        @if (periodOffset == 0 && todayCard == null)
        {
            <div class="today-prompt">
                <h3>Today: @DateTime.Today.ToString("dddd, MMM d")</h3>
                @if (todayCheckInCampusId.HasValue)
                {
                    <p>
                        You're checked in at <strong>@GetCampusName(todayCheckInCampusId.Value)</strong>.
                        Log the first period you cover to start today's timecard.
                    </p>
                    <button class="btn-add-period"
                            @onclick="() => OpenPickerForTodayAsync(todayCheckInCampusId.Value)"
                            disabled="@isOpeningToday">
                        @(isOpeningToday ? "Opening…" : "+ Add Period")
                    </button>
                }
                else
                {
                    <p class="today-prompt-warn">
                        Not checked in at a campus yet today. Pick a campus below to start today's timecard
                        — or check in at a kiosk first.
                    </p>
                    <div class="campus-picker-row">
                        <label for="today-campus-select">Campus for today:</label>
                        <select id="today-campus-select" @bind="selectedTodayCampusId" disabled="@isOpeningToday">
                            <option value="0">— Select —</option>
                            @foreach (var kv in campusNameById.OrderBy(kv => kv.Value))
                            {
                                <option value="@kv.Key">@kv.Value</option>
                            }
                        </select>
                        <button class="btn-add-period"
                                @onclick="HandleTodayPickerFromManualCampusAsync"
                                disabled="@(selectedTodayCampusId <= 0 || isOpeningToday)">
                            @(isOpeningToday ? "Opening…" : "+ Add Period")
                        </button>
                    </div>
                }
            </div>
        }

        <div class="pay-period-summary">
            <strong>Pay Period Summary:</strong>
            @cards.Sum(c => c.TotalPeriodsWorked) period@(cards.Sum(c => c.TotalPeriodsWorked) == 1 ? "" : "s")
            across @cards.Count @(cards.Count == 1 ? "day" : "days")
            @if (cards.Select(c => c.CampusId).Distinct().Count() > 1)
            {
                <span class="cross-campus-note"> (across multiple campuses)</span>
            }
        </div>
    }

</div>

<SubPeriodPickerModal Visible="@showPicker"
                      CampusId="@pickerCampusId"
                      WorkDate="@pickerWorkDate"
                      ExistingEntries="@pickerExistingEntries"
                      OnSave="HandlePickerSaveAsync"
                      OnCancel="HandlePickerCancel" />

@code {
    [Parameter] public int? PeriodOffset { get; set; }

    private int periodOffset = 0;
    private bool isLoading = true;
    private string loadError = "";

    private int employeeId;
    private string employeeName = "";
    private string currentUserEmail = "";
    private EmployeeType employeeType = EmployeeType.HourlyStaff;

    private PayPeriodInfo? currentPayPeriod;
    private List<TcSubstituteTimecard> cards = new();
    private TcSubstituteTimecard? todayCard;
    private int? todayCheckInCampusId;

    private Dictionary<int, string> campusNameById = new();

    // ── Picker modal state ────────────────────────────────────────────────
    private bool showPicker = false;
    private int pickerCampusId = 0;
    private DateOnly pickerWorkDate;
    private long? pickerCardId = null;
    private IReadOnlyList<TcSubstitutePeriodEntry>? pickerExistingEntries = null;

    // Today-prompt inline campus picker + loading flag.
    private int selectedTodayCampusId = 0;
    private bool isOpeningToday = false;

    // Surface for action-level failures (AddPeriod throws, etc).
    private string actionError = "";

    // ── Remove-entry flow state ───────────────────────────────────────────
    private long? confirmingRemoveEntryId = null;
    private bool isRemoving = false;

    // ── Edit-notes flow state ─────────────────────────────────────────────
    private long? editingNotesEntryId = null;
    private string editedNotes = "";
    private bool isSavingNotes = false;

    protected override async Task OnInitializedAsync()
    {
        periodOffset = PeriodOffset ?? 0;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUserEmail = user.FindFirst("preferred_username")?.Value
                        ?? user.FindFirst(ClaimTypes.Email)?.Value
                        ?? "";

        await LoadData();
    }

    protected override async Task OnParametersSetAsync()
    {
        var incoming = PeriodOffset ?? 0;
        if (incoming != periodOffset)
        {
            periodOffset = incoming;
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        isLoading = true;
        loadError = "";

        try
        {
            using var context = await DbFactory.CreateDbContextAsync();

            var employee = await context.TcEmployees
                .Include(e => e.Staff)
                .FirstOrDefaultAsync(e => e.Email == currentUserEmail && e.IsActive);

            if (employee == null)
            {
                loadError = "Your employee record was not found. Contact your supervisor.";
                return;
            }

            employeeId = employee.EmployeeId;
            employeeName = employee.Staff?.FullName ?? employee.Email ?? "Unknown";
            employeeType = employee.EmployeeType;

            if (employeeType != EmployeeType.Substitute)
            {
                Logger.LogInformation(
                    "Non-substitute {Email} (type {Type}) redirected from /my/sub-timesheet to /my/timesheet.",
                    currentUserEmail, employeeType);
                Navigation.NavigateTo("/my/timesheet", forceLoad: false);
                return;
            }

            var anchorDate = DateTime.Today.AddDays(-15 * periodOffset);
            currentPayPeriod = await PayPeriodService.GetPayPeriodForDateAsync(anchorDate);
            if (currentPayPeriod == null)
            {
                loadError = "Could not resolve pay period for this date.";
                return;
            }

            cards = await SubTimesheetService.GetCardsForPayPeriodAsync(
                employeeId, currentPayPeriod.StartDate, currentPayPeriod.EndDate);

            campusNameById = await context.Campuses
                .AsNoTracking()
                .ToDictionaryAsync(c => c.CampusId, c => c.CampusName);

            var today = DateOnly.FromDateTime(DateTime.Today);
            todayCard = cards.FirstOrDefault(c => c.WorkDate == today);

            if (periodOffset == 0)
                todayCheckInCampusId = await SubTimesheetService.GetCampusIdFromTodayCheckInAsync(employeeId);
            else
                todayCheckInCampusId = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading sub timesheet for {Email}", currentUserEmail);
            loadError = "Unable to load your sub timesheet. Please refresh and try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private IEnumerable<TcSubstituteTimecard> GetCardsOrderedByDate()
        => cards.OrderBy(c => c.WorkDate).ThenBy(c => c.CampusId);

    private string GetCampusName(int campusId)
        => campusNameById.TryGetValue(campusId, out var name) ? name : $"Campus {campusId}";

    private bool HasTodayInWindow()
    {
        if (currentPayPeriod == null) return false;
        var today = DateOnly.FromDateTime(DateTime.Today);
        return today >= currentPayPeriod.StartDate && today <= currentPayPeriod.EndDate;
    }

    private void PreviousPeriod()
    {
        periodOffset--;
        Navigation.NavigateTo($"/my/sub-timesheet/{periodOffset}");
    }

    private void NextPeriod()
    {
        if (periodOffset >= 0) return;
        periodOffset++;
        if (periodOffset == 0)
            Navigation.NavigateTo("/my/sub-timesheet");
        else
            Navigation.NavigateTo($"/my/sub-timesheet/{periodOffset}");
    }

    // ── Picker open handlers ──────────────────────────────────────────────

    private void OpenPickerForCard(TcSubstituteTimecard card)
    {
        actionError = "";
        pickerCampusId = card.CampusId;
        pickerWorkDate = card.WorkDate;
        pickerCardId = card.SubTimecardId;
        pickerExistingEntries = card.PeriodEntries.ToList();
        showPicker = true;
    }

    private async Task OpenPickerForTodayAsync(int campusId)
    {
        if (isOpeningToday) return;
        if (campusId <= 0)
        {
            actionError = "Please choose a campus before adding a period.";
            return;
        }

        isOpeningToday = true;
        actionError = "";
        try
        {
            var card = await SubTimesheetService.GetOrCreateTodayCardAsync(employeeId, campusId);

            await LoadData();

            pickerCampusId = campusId;
            pickerWorkDate = DateOnly.FromDateTime(DateTime.Today);
            pickerCardId = card.SubTimecardId;
            pickerExistingEntries = todayCard?.PeriodEntries.ToList()
                                    ?? new List<TcSubstitutePeriodEntry>();
            showPicker = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex,
                "OpenPickerForTodayAsync failed for employee {EmployeeId} campus {Campus}",
                employeeId, campusId);
            actionError = "Could not start today's timecard. Refresh and try again.";
        }
        finally
        {
            isOpeningToday = false;
        }
    }

    private async Task HandleTodayPickerFromManualCampusAsync()
    {
        if (selectedTodayCampusId <= 0)
        {
            actionError = "Please pick a campus first.";
            return;
        }
        await OpenPickerForTodayAsync(selectedTodayCampusId);
    }

    // ── Picker callbacks ──────────────────────────────────────────────────

    private async Task HandlePickerSaveAsync(PeriodPickerResult result)
    {
        if (pickerCardId == null)
        {
            actionError = "Lost reference to the open card — refresh and retry.";
            showPicker = false;
            return;
        }

        try
        {
            await SubTimesheetService.AddPeriodEntryAsync(
                subTimecardId: pickerCardId.Value,
                bellPeriodId: result.BellPeriodId,
                masterScheduleId: result.MasterScheduleId,
                sessionType: result.SessionType,
                notes: result.Notes,
                employeeId: employeeId);

            showPicker = false;
            pickerCardId = null;
            pickerExistingEntries = null;

            await LoadData();
        }
        catch (InvalidOperationException ex)
        {
            Logger.LogWarning(ex,
                "AddPeriodEntryAsync rejected for employee {EmployeeId} card {CardId}",
                employeeId, pickerCardId);
            actionError = ex.Message;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex,
                "Unexpected error adding period entry for employee {EmployeeId}", employeeId);
            actionError = "Could not save the period. Please try again.";
        }
    }

    private void HandlePickerCancel()
    {
        showPicker = false;
        pickerCardId = null;
        pickerExistingEntries = null;
    }

    // ── Remove-entry handlers ─────────────────────────────────────────────

    private void BeginRemove(long entryId)
    {
        actionError = "";
        editingNotesEntryId = null;
        editedNotes = "";
        confirmingRemoveEntryId = entryId;
    }

    private void CancelRemove()
    {
        confirmingRemoveEntryId = null;
    }

    private async Task ConfirmRemoveAsync(TcSubstitutePeriodEntry entry)
    {
        if (isRemoving) return;
        isRemoving = true;
        actionError = "";
        try
        {
            await SubTimesheetService.RemovePeriodEntryAsync(entry.EntryId, employeeId);
            confirmingRemoveEntryId = null;
            await LoadData();
        }
        catch (InvalidOperationException ex)
        {
            Logger.LogWarning(ex,
                "RemovePeriodEntryAsync rejected for employee {EmployeeId} entry {EntryId}",
                employeeId, entry.EntryId);
            actionError = ex.Message;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex,
                "Unexpected error removing period entry {EntryId} for employee {EmployeeId}",
                entry.EntryId, employeeId);
            actionError = "Could not remove the period. Please try again.";
        }
        finally
        {
            isRemoving = false;
        }
    }

    // ── Edit-notes handlers ───────────────────────────────────────────────

    private void BeginEditNotes(TcSubstitutePeriodEntry entry)
    {
        actionError = "";
        confirmingRemoveEntryId = null;
        editingNotesEntryId = entry.EntryId;
        editedNotes = entry.Notes ?? "";
    }

    private void CancelEditNotes()
    {
        editingNotesEntryId = null;
        editedNotes = "";
    }

    private async Task SaveNotesAsync(TcSubstitutePeriodEntry entry)
    {
        if (isSavingNotes) return;
        isSavingNotes = true;
        actionError = "";
        try
        {
            await SubTimesheetService.UpdatePeriodNotesAsync(entry.EntryId, editedNotes, employeeId);
            editingNotesEntryId = null;
            editedNotes = "";
            await LoadData();
        }
        catch (InvalidOperationException ex)
        {
            Logger.LogWarning(ex,
                "UpdatePeriodNotesAsync rejected for employee {EmployeeId} entry {EntryId}",
                employeeId, entry.EntryId);
            actionError = ex.Message;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex,
                "Unexpected error updating notes for entry {EntryId} for employee {EmployeeId}",
                entry.EntryId, employeeId);
            actionError = "Could not save the notes. Please try again.";
        }
        finally
        {
            isSavingNotes = false;
        }
    }
}
