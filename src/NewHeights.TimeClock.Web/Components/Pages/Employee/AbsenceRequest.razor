@page "/employee/absence-request"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using NewHeights.TimeClock.Data
@using NewHeights.TimeClock.Data.Entities
@using NewHeights.TimeClock.Shared.Audit
@using NewHeights.TimeClock.Shared.Constants
@using NewHeights.TimeClock.Shared.Enums
@using NewHeights.TimeClock.Web.Services
@using System.Security.Claims
@attribute [Authorize(Policy = "RequireAnyStaff")]
@rendermode InteractiveServer
@inject IDbContextFactory<TimeClockDbContext> DbFactory
@inject IAuditService Audit
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ILogger<AbsenceRequest> Logger

<PageTitle>Substitute Request - @AppConstants.Branding.ShortName</PageTitle>

<div class="absence-request-page">

    <header class="absence-request-header">
        <h1>Substitute Request</h1>
        <p class="header-subtitle">
            Submit a request for substitute coverage, then go to <a href="/employee/my-sub-requests">My Sub Requests</a>
            to invite a sub. Once a sub accepts, the request goes to the campus admin for final approval.
        </p>
        <p class="header-note">
            <strong>Note:</strong> this form <em>does not</em> submit a time-off request to HR.
            PTO / sick / personal leave is tracked in Ascender — submit your leave there separately.
        </p>
    </header>

    @if (submittedRequestId.HasValue)
    {
        <div class="success-panel" role="status">
            <h2>Request Created</h2>
            <p>
                @if (!string.IsNullOrEmpty(SelectedTeacherName()))
                {
                    <span>Request (#@submittedRequestId) for <strong>@SelectedTeacherName()</strong> on </span>
                }
                else
                {
                    <span>Your request (#@submittedRequestId) for </span>
                }
                <strong>@form.StartDate.ToString("MMM d")@(form.StartDate != form.EndDate ? $" – {form.EndDate:MMM d, yyyy}" : $", {form.StartDate.Year}")</strong>
                is awaiting a substitute.
            </p>
            <p>
                <strong>Next step:</strong> go to
                <a href="/employee/my-sub-requests">My Sub Requests</a>
                to invite a substitute (manually or via auto-cascade).
                Once a sub accepts, the request will be sent to the campus admin for final approval.
            </p>
            <div class="success-actions">
                <a class="btn-primary" href="/employee/my-sub-requests">Find a Sub</a>
                <button type="button" class="btn-secondary" @onclick="ResetForm">Submit Another</button>
                <a class="btn-secondary" href="/">Back to Home</a>
            </div>
        </div>
    }
    else
    {
        <div class="employee-info-bar">
            <div class="info-item">
                <span class="info-label">Name:</span>
                <span class="info-value">@employeeName</span>
            </div>
            <div class="info-item">
                <span class="info-label">Campus:</span>
                <span class="info-value">@campusDisplay</span>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(loadError))
        {
            <div class="error-panel" role="alert">@loadError</div>
        }
        else if (isLoading)
        {
            <div class="loading">Loading…</div>
        }
        else
        {
            <form class="absence-form" @onsubmit="SubmitAsync" @onsubmit:preventDefault="true">

                @if (canSubmitOnBehalf && teacherOptions.Count > 0)
                {
                    <div class="form-row onbehalf-row">
                        <label for="on-behalf-of"><strong>Submitting on behalf of</strong></label>
                        <select id="on-behalf-of" @bind="onBehalfOfEmployeeId" @bind:after="OnOnBehalfOfChanged">
                            <option value="">— Myself (@employeeName) —</option>
                            @foreach (var t in teacherOptions)
                            {
                                <option value="@t.EmployeeId">@t.DisplayName (@t.CampusCode)</option>
                            }
                        </select>
                        @if (onBehalfOfEmployeeId.HasValue)
                        {
                            <p class="form-hint">
                                You are submitting this request on behalf of <strong>@SelectedTeacherName()</strong>.
                                The request will be tagged "Created by @currentUserName for @SelectedTeacherName()" in the supervisor list.
                            </p>
                        }
                    </div>
                }

                @if (canSubmitOnBehalf || isReceptionRoleUser)
                {
                    <div class="form-row">
                        <label for="request-type">Sub Pool</label>
                        <select id="request-type" @bind="form.RequestType">
                            <option value="TEACHER">Teacher / Classroom coverage</option>
                            <option value="RECEPTION">Reception / Front desk coverage</option>
                        </select>
                        <p class="form-hint">
                            Determines which sub pool the request draws from. Reception
                            requests never show teacher subs and vice versa.
                        </p>
                    </div>
                }

                @if (canSubmitOnBehalf)
                {
                    @* Phase A ext: Emergency Fill is supervisor-gated per design
                       decision. canSubmitOnBehalf covers Supervisor variants +
                       Admin + CampusAdmin — exactly the target set. *@
                    <div class="form-row emergency-row @(form.IsEmergency ? "emergency-row-active" : "")">
                        <label class="emergency-check">
                            <input type="checkbox" @bind="form.IsEmergency" />
                            <span class="emergency-label">
                                <strong>Emergency Fill</strong> — same-day must-fill position
                            </span>
                        </label>
                        @if (form.IsEmergency)
                        {
                            <div class="emergency-callout">
                                <strong>When submitted, this request will:</strong>
                                <ul>
                                    <li>Broadcast to every eligible substitute simultaneously (first to accept wins)</li>
                                    <li>Use a <strong>30-minute</strong> response window on each emailed link</li>
                                    <li>Show an URGENT banner on the sub's email and on the outreach panel</li>
                                </ul>
                            </div>
                        }
                    </div>
                }

                <div class="form-row">
                    <label for="absence-type">Absence Type</label>
                    <select id="absence-type" @bind="form.AbsenceType" required>
                        <option value="@AbsenceType.PTO">PTO</option>
                        <option value="@AbsenceType.Sick">Sick</option>
                        <option value="@AbsenceType.ProfessionalDev">Professional Development</option>
                        <option value="@AbsenceType.Personal">Personal</option>
                        <option value="@AbsenceType.Vacation">Vacation</option>
                        <option value="@AbsenceType.Other">Other</option>
                    </select>
                </div>

                <div class="form-row two-col">
                    <div>
                        <label for="start-date">Start Date</label>
                        <input id="start-date" type="date"
                               @bind="form.StartDate"
                               @bind:after="OnStartDateChanged"
                               required />
                    </div>
                    <div>
                        <label for="end-date">End Date</label>
                        <input id="end-date" type="date"
                               @bind="form.EndDate"
                               @bind:after="OnEndDateChanged"
                               min="@form.StartDate.ToString("yyyy-MM-dd")"
                               required />
                    </div>
                </div>

                @if (otherAbsences.Count > 0)
                {
                    <div class="same-day-banner" role="status">
                        <div class="same-day-heading">
                            <strong>@otherAbsences.Count</strong> other teacher@(otherAbsences.Count == 1 ? "" : "s") already absent during this date range
                        </div>
                        <ul class="same-day-list">
                            @foreach (var grp in otherAbsences.GroupBy(a => a.CampusCode).OrderBy(g => g.Key))
                            {
                                <li>
                                    <span class="campus-tag">@grp.Key</span>
                                    @string.Join(", ", grp.OrderBy(a => a.StartDate).Select(FormatOtherAbsence))
                                </li>
                            }
                        </ul>
                    </div>
                }

                <div class="form-row">
                    <label>Session</label>
                    <div class="radio-group" role="radiogroup">
                        <label class="radio-option">
                            <input type="radio" name="session" value="DAY"
                                   checked="@(form.SessionType == "DAY")"
                                   @onchange='() => form.SessionType = "DAY"' />
                            Day
                        </label>
                        <label class="radio-option">
                            <input type="radio" name="session" value="EVENING"
                                   checked="@(form.SessionType == "EVENING")"
                                   @onchange='() => form.SessionType = "EVENING"' />
                            Evening
                        </label>
                        <label class="radio-option">
                            <input type="radio" name="session" value="BOTH"
                                   checked="@(form.SessionType == "BOTH")"
                                   @onchange='() => form.SessionType = "BOTH"' />
                            Both
                        </label>
                    </div>
                </div>

                <div class="form-row">
                    <label>Periods Needing Coverage</label>
                    <div class="period-checks">
                        @for (int p = 1; p <= 6; p++)
                        {
                            var periodNum = p;
                            <label class="period-check">
                                <input type="checkbox"
                                       checked="@form.Periods.Contains(periodNum)"
                                       @onchange="(e) => TogglePeriod(periodNum, (bool?)e.Value == true)" />
                                P@(periodNum)
                            </label>
                        }
                        <button type="button" class="btn-inline" @onclick="SelectAllDay">Select All Day</button>
                        <button type="button" class="btn-inline" @onclick="ClearPeriods">Clear</button>
                    </div>
                </div>

                <div class="form-row">
                    <label for="subject-area">Subject Area</label>
                    <select id="subject-area" @bind="form.SubjectArea">
                        <option value="">— (optional) —</option>
                        <option value="ELAR">ELAR</option>
                        <option value="MATH">MATH</option>
                        <option value="SCI">Science</option>
                        <option value="SS">Social Studies</option>
                        <option value="CTE">CTE</option>
                        <option value="Advising">Advising</option>
                        <option value="Other">Other</option>
                    </select>
                </div>

                <div class="form-row">
                    <label for="special-instructions">Special Instructions (optional)</label>
                    <textarea id="special-instructions"
                              @bind="form.SpecialInstructions"
                              rows="3"
                              maxlength="1000"
                              placeholder="e.g. 'STAAR testing week — lesson plans on desk'"></textarea>
                </div>

                <div class="form-row">
                    <label for="reason">Reason (optional)</label>
                    <input id="reason" type="text"
                           @bind="form.AbsenceReason"
                           maxlength="500"
                           placeholder="e.g. 'Doctor appointment'" />
                </div>

                @if (!string.IsNullOrEmpty(submitError))
                {
                    <div class="error-panel" role="alert">@submitError</div>
                }

                <div class="form-actions">
                    <a class="btn-secondary" href="/">Cancel</a>
                    <button type="submit" class="btn-primary" disabled="@(isSubmitting || !CanSubmit())">
                        @(isSubmitting ? "Submitting…" : "Submit Request")
                    </button>
                </div>
            </form>
        }
    }

</div>

@code {
    private AbsenceForm form = new();

    private int employeeId;
    private string employeeName = "";
    private string currentUserEmail = "";
    private string currentUserName = "";
    private int campusId;
    private string campusDisplay = "";

    private bool isLoading = true;
    private bool isSubmitting = false;
    private string loadError = "";
    private string submitError = "";

    private long? submittedRequestId = null;

    private List<OtherAbsence> otherAbsences = new();

    // Migration 042: supervisor / campus admin can submit on behalf of an
    // absentee. canSubmitOnBehalf gates the picker UI; teacherOptions is the
    // list of available targets (active employees at the supervisor's campus,
    // excluding self and substitutes); onBehalfOfEmployeeId carries the picked
    // target (null = submitting for self, normal flow).
    private bool canSubmitOnBehalf = false;
    private List<TeacherOption> teacherOptions = new();
    private int? onBehalfOfEmployeeId = null;

    // Phase D4B: reception sub pool. Picker visible when submitter is in
    // Reception role, Supervisor, or Admin (since they may submit on behalf
    // of either type). Default chosen in OnInitializedAsync based on role.
    private bool isReceptionRoleUser = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUserEmail = user.FindFirst("preferred_username")?.Value
                        ?? user.FindFirst(ClaimTypes.Email)?.Value
                        ?? "";
        currentUserName = user.FindFirst("name")?.Value
                       ?? user.Identity?.Name
                       ?? currentUserEmail;

        // Mirrors UserContextService.IsSupervisor — any supervisor variant or admin.
        canSubmitOnBehalf =
            user.IsInRole(AppConstants.Roles.Supervisor)
         || user.IsInRole(AppConstants.Roles.SupervisorStopSix)
         || user.IsInRole(AppConstants.Roles.SupervisorMcCart)
         || user.IsInRole(AppConstants.Roles.Admin)
         || user.IsInRole(AppConstants.Roles.CampusAdmin);

        // Phase D4B: detect Reception role so the submitter can pick
        // RECEPTION as the RequestType for their own absence (or for an
        // on-behalf submission where the absentee is reception staff).
        isReceptionRoleUser = user.IsInRole(AppConstants.Roles.Reception);

        // Default the picker to RECEPTION when the submitter themselves
        // is reception staff submitting for self; supervisor/admin picks
        // explicitly.
        form.RequestType = isReceptionRoleUser ? "RECEPTION" : "TEACHER";

        await LoadEmployeeAsync();
    }

    private async Task LoadEmployeeAsync()
    {
        isLoading = true;
        loadError = "";
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();

            var employee = await context.TcEmployees
                .Include(e => e.Staff)
                .Include(e => e.HomeCampus)
                .FirstOrDefaultAsync(e => e.Email == currentUserEmail && e.IsActive);

            if (employee == null)
            {
                loadError = "Your employee record was not found. Contact your supervisor.";
                return;
            }

            employeeId = employee.EmployeeId;
            employeeName = employee.Staff?.FullName ?? employee.Email ?? "—";
            campusId = employee.HomeCampusId;
            campusDisplay = employee.HomeCampus?.CampusName ?? $"Campus {employee.HomeCampusId}";

            // Default both dates to today and session to Day.
            var today = DateOnly.FromDateTime(DateTime.Today);
            form.StartDate = today;
            form.EndDate = today;

            // Load teacher picker options if this user can submit on behalf.
            // Scope: active non-substitute employees at the same campus, excluding self.
            if (canSubmitOnBehalf)
            {
                teacherOptions = await context.TcEmployees
                    .AsNoTracking()
                    .Include(e => e.Staff)
                    .Include(e => e.HomeCampus)
                    .Where(e => e.IsActive
                             && e.EmployeeId != employeeId
                             && e.EmployeeType != EmployeeType.Substitute
                             && e.HomeCampusId == campusId)
                    .OrderBy(e => e.Staff!.LastName)
                    .ThenBy(e => e.Staff!.FirstName)
                    .Select(e => new TeacherOption
                    {
                        EmployeeId  = e.EmployeeId,
                        DisplayName = e.Staff != null
                            ? (e.Staff.FirstName + " " + e.Staff.LastName)
                            : (e.DisplayName ?? e.Email ?? ("Employee " + e.EmployeeId)),
                        CampusCode  = e.HomeCampus != null ? e.HomeCampus.CampusCode : "",
                        HomeCampusId = e.HomeCampusId
                    })
                    .ToListAsync();
            }

            await LoadOtherAbsencesAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading employee for absence request: {Email}", currentUserEmail);
            loadError = "Unable to load your employee record. Please refresh and try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnStartDateChanged()
    {
        if (form.EndDate < form.StartDate)
            form.EndDate = form.StartDate;
        await LoadOtherAbsencesAsync();
    }

    private async Task OnEndDateChanged()
    {
        if (form.EndDate < form.StartDate)
            form.EndDate = form.StartDate;
        await LoadOtherAbsencesAsync();
    }

    private async Task LoadOtherAbsencesAsync()
    {
        if (employeeId == 0) return;
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            otherAbsences = await context.TcSubRequests
                .AsNoTracking()
                .Where(r => r.RequestingEmployeeId != employeeId
                         && r.Status != SubRequestStatus.Denied
                         && r.Status != SubRequestStatus.Cancelled
                         && r.StartDate <= form.EndDate
                         && r.EndDate >= form.StartDate)
                .Select(r => new OtherAbsence
                {
                    TeacherName = r.RequestingEmployee.Staff != null
                        ? (r.RequestingEmployee.Staff.FirstName + " " + r.RequestingEmployee.Staff.LastName)
                        : (r.RequestingEmployee.Email ?? ("Employee " + r.RequestingEmployeeId)),
                    CampusCode = r.Campus.CampusCode,
                    StartDate = r.StartDate,
                    EndDate = r.EndDate,
                    Status = r.Status
                })
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex,
                "Could not load other absences for banner (employee {EmployeeId})", employeeId);
            otherAbsences = new();
        }
    }

    private static string FormatOtherAbsence(OtherAbsence a)
    {
        var dates = a.StartDate == a.EndDate
            ? a.StartDate.ToString("MMM d")
            : $"{a.StartDate:MMM d}\u2013{a.EndDate:MMM d}";
        return $"{a.TeacherName} ({dates})";
    }

    private void TogglePeriod(int periodNumber, bool checkedState)
    {
        if (checkedState)
        {
            if (!form.Periods.Contains(periodNumber))
                form.Periods.Add(periodNumber);
        }
        else
        {
            form.Periods.Remove(periodNumber);
        }
    }

    private void SelectAllDay()
    {
        form.Periods = new List<int> { 1, 2, 3, 4, 5, 6 };
    }

    private void ClearPeriods()
    {
        form.Periods = new();
    }

    private bool CanSubmit()
    {
        if (form.EndDate < form.StartDate) return false;
        if (form.Periods.Count == 0) return false;
        return true;
    }

    private async Task SubmitAsync()
    {
        if (isSubmitting || !CanSubmit()) return;
        submitError = "";

        if (form.Periods.Count == 0)
        {
            submitError = "Select at least one period needing coverage (or click 'Select All Day').";
            return;
        }
        if (form.EndDate < form.StartDate)
        {
            submitError = "End date must be on or after the start date.";
            return;
        }

        isSubmitting = true;
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();

            // Resolve the absentee + campus. When submitting on behalf of another
            // employee (supervisor flow), the absentee is the picked teacher and
            // the campus follows them (not the supervisor). CreatedByEmployeeId
            // records the supervisor as the actor.
            int targetEmployeeId = employeeId;
            int targetCampusId   = campusId;
            int? createdByForAudit = null;

            if (onBehalfOfEmployeeId.HasValue && canSubmitOnBehalf)
            {
                var target = teacherOptions.FirstOrDefault(t => t.EmployeeId == onBehalfOfEmployeeId.Value);
                if (target == null)
                {
                    submitError = "Selected teacher is no longer available. Please refresh.";
                    isSubmitting = false;
                    return;
                }
                targetEmployeeId = target.EmployeeId;
                targetCampusId   = target.HomeCampusId;
                createdByForAudit = employeeId;
            }

            var request = new TcSubRequest
            {
                RequestingEmployeeId = targetEmployeeId,
                CreatedByEmployeeId  = createdByForAudit,
                CampusId = targetCampusId,
                StartDate = form.StartDate,
                EndDate = form.EndDate,
                AbsenceType = form.AbsenceType,
                AbsenceReason = string.IsNullOrWhiteSpace(form.AbsenceReason) ? null : form.AbsenceReason.Trim(),
                PeriodsNeeded = string.Join(",", form.Periods.OrderBy(p => p).Select(p => $"P{p}")),
                SessionType = form.SessionType,
                SubjectArea = string.IsNullOrWhiteSpace(form.SubjectArea) ? null : form.SubjectArea,
                SpecialInstructions = string.IsNullOrWhiteSpace(form.SpecialInstructions) ? null : form.SpecialInstructions.Trim(),
                // Phase D4B: scopes the candidate sub pool when SubOutreachPanel
                // builds its candidate query. NULL is treated as TEACHER.
                RequestType = string.IsNullOrWhiteSpace(form.RequestType) ? "TEACHER" : form.RequestType,
                // Phase A ext: Emergency Fill — supervisor-gated. The checkbox
                // is only rendered when canSubmitOnBehalf (supervisor/admin/
                // campus-admin), so a form POST from a non-privileged user
                // will always arrive with IsEmergency=false.
                IsEmergency = canSubmitOnBehalf && form.IsEmergency,
                Status = SubRequestStatus.AwaitingSub,
                CreatedDate = DateTime.Now,
                ModifiedDate = DateTime.Now
            };

            context.TcSubRequests.Add(request);
            await context.SaveChangesAsync();

            await Audit.LogActionAsync(
                actionCode: AuditActions.Absence.Submitted,
                entityType: AuditEntityTypes.SubRequest,
                entityId: request.SubRequestId.ToString(),
                newValues: new
                {
                    request.SubRequestId,
                    request.RequestingEmployeeId,
                    request.CreatedByEmployeeId,
                    request.CampusId,
                    StartDate = request.StartDate.ToString("yyyy-MM-dd"),
                    EndDate = request.EndDate.ToString("yyyy-MM-dd"),
                    AbsenceType = request.AbsenceType.ToString(),
                    request.SessionType,
                    request.PeriodsNeeded,
                    request.SubjectArea,
                    HasSpecialInstructions = !string.IsNullOrWhiteSpace(request.SpecialInstructions),
                    Status = request.Status.ToString(),
                    OnBehalf = request.CreatedByEmployeeId.HasValue
                },
                deltaSummary: request.CreatedByEmployeeId.HasValue
                    ? $"Absence request #{request.SubRequestId} submitted by {currentUserName} "
                    + $"on behalf of {SelectedTeacherName()} for "
                    + $"{request.StartDate:MMM d}–{request.EndDate:MMM d} "
                    + $"({request.AbsenceType}, {request.PeriodsNeeded})"
                    : $"Absence request #{request.SubRequestId} submitted for "
                    + $"{request.StartDate:MMM d}–{request.EndDate:MMM d} "
                    + $"({request.AbsenceType}, {request.PeriodsNeeded})",
                source: AuditSource.AdminUi,
                employeeId: targetEmployeeId,
                campusId: targetCampusId);

            submittedRequestId = request.SubRequestId;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex,
                "Error submitting absence request for employee {EmployeeId}", employeeId);
            submitError = "Could not submit your request. Please try again.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void ResetForm()
    {
        form = new AbsenceForm
        {
            StartDate = DateOnly.FromDateTime(DateTime.Today),
            EndDate = DateOnly.FromDateTime(DateTime.Today),
            SessionType = "DAY",
            AbsenceType = AbsenceType.PTO,
            IsEmergency = false
        };
        submittedRequestId = null;
        submitError = "";
        onBehalfOfEmployeeId = null;
    }

    private async Task OnOnBehalfOfChanged()
    {
        // When the on-behalf target changes, refresh the conflict banner so it
        // reflects the absentee's date overlaps, not the supervisor's.
        await LoadOtherAbsencesAsync();
    }

    private string SelectedTeacherName()
    {
        if (!onBehalfOfEmployeeId.HasValue) return "";
        var t = teacherOptions.FirstOrDefault(x => x.EmployeeId == onBehalfOfEmployeeId.Value);
        return t?.DisplayName ?? "";
    }

    private class AbsenceForm
    {
        public AbsenceType AbsenceType { get; set; } = AbsenceType.PTO;
        public DateOnly StartDate { get; set; } = DateOnly.FromDateTime(DateTime.Today);
        public DateOnly EndDate { get; set; } = DateOnly.FromDateTime(DateTime.Today);
        public string SessionType { get; set; } = "DAY";
        public List<int> Periods { get; set; } = new();
        public string? SubjectArea { get; set; }
        public string? AbsenceReason { get; set; }
        public string? SpecialInstructions { get; set; }
        // Phase D4B: scopes the candidate sub pool. TEACHER (default) or RECEPTION.
        public string RequestType { get; set; } = "TEACHER";
        // Phase A ext: Emergency Fill — only bound when the submitter is a
        // supervisor/admin/campus-admin (the checkbox is gated by
        // canSubmitOnBehalf in the razor template).
        public bool IsEmergency { get; set; }
    }

    private class OtherAbsence
    {
        public string TeacherName { get; set; } = "";
        public string CampusCode { get; set; } = "";
        public DateOnly StartDate { get; set; }
        public DateOnly EndDate { get; set; }
        public SubRequestStatus Status { get; set; }
    }

    private class TeacherOption
    {
        public int EmployeeId { get; set; }
        public string DisplayName { get; set; } = "";
        public string CampusCode { get; set; } = "";
        public int HomeCampusId { get; set; }
    }
}
