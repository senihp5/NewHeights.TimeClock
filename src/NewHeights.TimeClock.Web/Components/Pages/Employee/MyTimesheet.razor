@code {
    [Parameter] public int WeekOffset { get; set; } = 0;

    private int weekOffset = 0;
    private bool isLoading = true;
    // Admin / salaried users reach this page without a TC_Employees row of
    // their own. Instead of rendering default DateOnly values ("Jan 1, 0001"),
    // flag the state so the UI can show a friendly explanation.
    private bool noEmployeeRecord = false;
    private string currentUserEntraOid = "";
    private bool isSubmitting = false;
    private bool certificationChecked = false;

    private string employeeName = "";
    private int employeeId = 0;
    private string currentUserEmail = "";
    private bool isHolidayEligible = true;

    private PayPeriodInfo? currentPayPeriod;
    private WeeklyTimesheet? weeklyTimesheet;
    private DateOnly selectedWeekStart;
    private DateOnly selectedWeekEnd;

    private decimal totalLeaveHours = 0;
    private decimal totalHolidayHours = 0;
    private decimal grandTotal => (weeklyTimesheet?.TotalHours ?? 0) + totalLeaveHours + totalHolidayHours;

    // Drill-down state
    private HashSet<DateOnly> expandedDays = new();

    // Holiday data
    private List<TcHolidaySchedule> weekHolidays = new();

    // Correction request state
    private List<TcCorrectionRequest> pendingCorrections = new();
    private bool showCorrectionModal = false;
    private DateOnly correctionDate;
    private DailyTimesheetEntry? correctionDayEntry;
    private string correctionType = "";
    private string correctionPunchType = "In";
    private TimeOnly correctionTime = new(8, 0);
    private long correctionOriginalPunchId = 0;

    // Phase A2: inline Edit Time modal state
    private bool showEditPunchModal = false;
    private long editPunchId = 0;
    private DateTime editPunchOriginalTime;
    private TimeOnly editPunchNewTime;
    private DateOnly editPunchWorkDate;
    private bool editPunchIsIn;
    private string editPunchReason = "";
    private string editPunchError = "";
    private bool isSavingEditPunch = false;
    private string correctionReason = "";
    private string correctionError = "";
    private bool isSubmittingCorrection = false;

    protected override async Task OnInitializedAsync()
    {
        weekOffset = WeekOffset;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUserEmail = user.FindFirst("preferred_username")?.Value ??
                           user.FindFirst(ClaimTypes.Email)?.Value ?? "";
        currentUserEntraOid = user.FindFirst("oid")?.Value
                           ?? user.FindFirst("http://schemas.microsoft.com/identity/claims/objectidentifier")?.Value
                           ?? "";

        currentPayPeriod = await PayPeriodService.GetCurrentPayPeriodAsync();
        await LoadEmployeeAndTimesheet();
    }

    private async Task LoadEmployeeAndTimesheet()
    {
        isLoading = true;
        noEmployeeRecord = false;

        try
        {
            using var context = await DbFactory.CreateDbContextAsync();

            // Multi-step lookup: EntraObjectId is the most stable match; fall
            // back to case-insensitive email. Matches the pattern used on the
            // Substitute Request and My Sub Requests pages.
            TcEmployee? employee = null;

            if (!string.IsNullOrWhiteSpace(currentUserEntraOid))
            {
                employee = await context.TcEmployees
                    .Include(e => e.Staff)
                    .FirstOrDefaultAsync(e => e.EntraObjectId == currentUserEntraOid && e.IsActive);
            }

            if (employee == null && !string.IsNullOrWhiteSpace(currentUserEmail))
            {
                var emailLower = currentUserEmail.Trim().ToLower();
                employee = await context.TcEmployees
                    .Include(e => e.Staff)
                    .FirstOrDefaultAsync(e => e.Email != null
                                           && e.Email.ToLower() == emailLower
                                           && e.IsActive);
            }

            if (employee != null)
            {
                if (employee.EmployeeType == EmployeeType.Substitute)
                {
                    Logger.LogInformation(
                        "Substitute {Email} redirected from /my/timesheet to /my/sub-timesheet (Phase 2).",
                        currentUserEmail);
                    Navigation.NavigateTo("/my/sub-timesheet", forceLoad: false);
                    return;
                }

                employeeId = employee.EmployeeId;
                employeeName = employee.Staff?.FullName ?? "Unknown";
                isHolidayEligible = employee.EmployeeType != EmployeeType.HourlyPartTime
                                 && employee.EmployeeType != EmployeeType.Substitute;
                await LoadTimesheet();
            }
            else
            {
                // Admin / IT-only users have the Admin role (which satisfies
                // RequireHourly) but no TC_Employees row. Flag so the UI
                // renders an empty-state panel instead of DateOnly.MinValue
                // ("Week of January 1 - January 1, 0001").
                noEmployeeRecord = true;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading employee data");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadTimesheet()
    {
        if (employeeId == 0) return;

        isLoading = true;
        certificationChecked = false;
        expandedDays.Clear();

        try
        {
            var today = DateOnly.FromDateTime(DateTime.Today);
            selectedWeekStart = today.AddDays(-(int)today.DayOfWeek + 1 + (weekOffset * 7));
            if (today.DayOfWeek == DayOfWeek.Sunday)
                selectedWeekStart = selectedWeekStart.AddDays(-7);
            selectedWeekEnd = selectedWeekStart.AddDays(6);

            weeklyTimesheet = await TimesheetService.GetWeeklyTimesheetAsync(employeeId, selectedWeekStart);

            // Load holidays for this week (only for benefits-eligible employees)
            using var context = await DbFactory.CreateDbContextAsync();
            if (isHolidayEligible)
            {
                weekHolidays = await context.TcHolidaySchedules
                    .AsNoTracking()
                    .Where(h => h.IsActive && h.HolidayDate >= selectedWeekStart && h.HolidayDate <= selectedWeekEnd)
                    .ToListAsync();
                totalHolidayHours = weekHolidays.Sum(h => h.HoursCredited);
            }
            else
            {
                weekHolidays.Clear();
                totalHolidayHours = 0;
            }
            totalLeaveHours = 0;

            // Load pending correction requests
            pendingCorrections = await context.TcCorrectionRequests
                .AsNoTracking()
                .Where(cr => cr.EmployeeId == employeeId &&
                             cr.WorkDate >= selectedWeekStart && cr.WorkDate <= selectedWeekEnd)
                .OrderByDescending(cr => cr.CreatedDate)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading timesheet");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void ToggleDayExpand(DateOnly date)
    {
        if (!expandedDays.Remove(date))
            expandedDays.Add(date);
    }

    private async Task PreviousWeek()
    {
        weekOffset--;
        await LoadTimesheet();
    }

    private async Task NextWeek()
    {
        if (weekOffset < 0)
        {
            weekOffset++;
            await LoadTimesheet();
        }
    }

    private async Task SubmitTimesheet()
    {
        if (!certificationChecked || isSubmitting) return;

        isSubmitting = true;
        try
        {
            await TimesheetService.SubmitTimesheetAsync(employeeId, selectedWeekEnd, currentUserEmail);
            await LoadTimesheet();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error submitting timesheet");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    // ── Punch pair builder ─────────────────────────────────────────────────
    private List<PunchPairDisplay> GetPunchPairs(DailyTimesheetEntry day)
    {
        var pairs = new List<PunchPairDisplay>();
        var punches = day.Punches.OrderBy(p => p.PunchTime).ToList();

        var inTypes = new HashSet<string> { "In", "LunchIn", "BreakIn" };
        var outTypes = new HashSet<string> { "Out", "LunchOut", "BreakOut" };

        var unmatched = new List<PunchEntry>(punches);

        // Match In→Out, LunchOut→LunchIn, BreakOut→BreakIn pairs
        var pairMappings = new[] { ("In", "Out", "Work", "work"), ("LunchOut", "LunchIn", "Lunch", "lunch"), ("BreakOut", "BreakIn", "Break", "break") };

        foreach (var (inType, outType, label, css) in pairMappings)
        {
            var ins = unmatched.Where(p => p.PunchType == inType).OrderBy(p => p.PunchTime).ToList();
            var outs = unmatched.Where(p => p.PunchType == outType).OrderBy(p => p.PunchTime).ToList();

            for (int i = 0; i < ins.Count; i++)
            {
                var inP = ins[i];
                var outP = i < outs.Count ? outs[i] : null;
                var hours = outP != null ? (decimal)(outP.PunchTime - inP.PunchTime).TotalHours : 0;

                pairs.Add(new PunchPairDisplay
                {
                    Label = label,
                    BadgeClass = css,
                    InTime = inP.PunchTime.ToString("h:mm tt"),
                    OutTime = outP?.PunchTime.ToString("h:mm tt") ?? "(open)",
                    RoundedIn = inP.RoundedTime?.ToString("h:mm tt") ?? inP.PunchTime.ToString("h:mm tt"),
                    RoundedOut = outP?.RoundedTime?.ToString("h:mm tt") ?? outP?.PunchTime.ToString("h:mm tt") ?? "—",
                    Hours = outP != null ? hours.ToString("F2") : "—",
                    IsManual = inP.IsManual || (outP?.IsManual ?? false),
                    IsModified = inP.IsModified || (outP?.IsModified ?? false),
                    InPunchId = inP.PunchId,
                    OutPunchId = outP?.PunchId,
                    InPunchDateTime = inP.PunchTime,
                    OutPunchDateTime = outP?.PunchTime,
                    WorkDate = day.Date
                });

                unmatched.Remove(inP);
                if (outP != null) unmatched.Remove(outP);
            }

            // Leftover outs without matching ins
            var remainingOuts = unmatched.Where(p => p.PunchType == outType).ToList();
            foreach (var outP in remainingOuts)
            {
                pairs.Add(new PunchPairDisplay
                {
                    Label = label,
                    BadgeClass = "unpaired",
                    InTime = "(missing)",
                    OutTime = outP.PunchTime.ToString("h:mm tt"),
                    RoundedIn = "—",
                    RoundedOut = outP.RoundedTime?.ToString("h:mm tt") ?? outP.PunchTime.ToString("h:mm tt"),
                    Hours = "—",
                    IsManual = outP.IsManual,
                    IsModified = outP.IsModified,
                    InPunchId = null,
                    OutPunchId = outP.PunchId,
                    InPunchDateTime = null,
                    OutPunchDateTime = outP.PunchTime,
                    WorkDate = day.Date
                });
                unmatched.Remove(outP);
            }
        }

        return pairs.OrderBy(p => p.InTime).ToList();
    }

    // ── Holiday helpers ────────────────────────────────────────────────────
    private decimal GetHolidayHours(DailyTimesheetEntry day)
    {
        if (!isHolidayEligible) return 0;
        var holiday = weekHolidays.FirstOrDefault(h => h.HolidayDate == day.Date);
        return holiday?.HoursCredited ?? 0;
    }

    private string GetHolidayName(DailyTimesheetEntry day)
    {
        return weekHolidays.FirstOrDefault(h => h.HolidayDate == day.Date)?.HolidayName ?? "";
    }

    private decimal GetDayTotal(DailyTimesheetEntry day)
    {
        return day.TotalHours + GetLeaveHours(day) + GetHolidayHours(day);
    }

    // ── Shift status ───────────────────────────────────────────────────────
    private string GetShiftStatus(DailyTimesheetEntry day, string shift)
    {
        if (day.TotalHours == 0 && !day.Punches.Any())
        {
            if (day.Date.DayOfWeek == DayOfWeek.Saturday || day.Date.DayOfWeek == DayOfWeek.Sunday)
                return "N/A";
            return "—";
        }

        var punches = day.Punches;
        bool hasInPunch = false;
        bool hasOutPunch = false;

        foreach (var p in punches)
        {
            var hour = p.PunchTime.Hour;
            bool inShift = shift switch
            {
                "AM" => hour >= 6 && hour < 12,
                "PM" => hour >= 12 && hour < 17,
                "Evening" => hour >= 16 && hour < 22,
                _ => false
            };

            if (inShift)
            {
                if (p.PunchType == "In" || p.PunchType == "LunchIn") hasInPunch = true;
                if (p.PunchType == "Out" || p.PunchType == "LunchOut") hasOutPunch = true;
            }
        }

        if (hasInPunch || hasOutPunch) return "In Office";
        if (day.Date.DayOfWeek == DayOfWeek.Saturday || day.Date.DayOfWeek == DayOfWeek.Sunday) return "N/A";
        return "—";
    }

    private decimal GetLeaveHours(DailyTimesheetEntry day) => 0; // TODO: integrate leave tracking

    // ── Correction request methods ─────────────────────────────────────────
    private void OpenCorrectionRequest(DailyTimesheetEntry day)
    {
        correctionDate = day.Date;
        correctionDayEntry = day;
        correctionType = "";
        correctionPunchType = "In";
        correctionTime = new TimeOnly(8, 0);
        correctionOriginalPunchId = 0;
        correctionReason = "";
        correctionError = "";
        showCorrectionModal = true;
    }

    private void CloseCorrectionModal()
    {
        showCorrectionModal = false;
    }

    private async Task SubmitCorrectionRequest()
    {
        correctionError = "";

        if (string.IsNullOrEmpty(correctionType))
        {
            correctionError = "Please select a correction type.";
            return;
        }
        if (string.IsNullOrWhiteSpace(correctionReason))
        {
            correctionError = "Please provide a reason for the correction.";
            return;
        }

        isSubmittingCorrection = true;
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();

            var requestType = correctionType switch
            {
                "MissedPunch" => CorrectionRequestType.MissedPunch,
                "WrongTime" => CorrectionRequestType.WrongTime,
                "WrongType" => CorrectionRequestType.WrongType,
                "AddPunch" => CorrectionRequestType.AddPunch,
                "DeletePunch" => CorrectionRequestType.DeletePunch,
                _ => CorrectionRequestType.MissedPunch
            };

            PunchType? punchType = correctionPunchType switch
            {
                "In" => PunchType.In,
                "Out" => PunchType.Out,
                "LunchOut" => PunchType.LunchOut,
                "LunchIn" => PunchType.LunchIn,
                _ => null
            };

            DateTime? requestedDateTime = null;
            if (correctionType == "MissedPunch" || correctionType == "AddPunch" || correctionType == "WrongTime")
            {
                requestedDateTime = correctionDate.ToDateTime(correctionTime);
            }

            var request = new TcCorrectionRequest
            {
                EmployeeId = employeeId,
                RequestType = requestType,
                WorkDate = correctionDate,
                RequestedPunchType = (correctionType == "MissedPunch" || correctionType == "AddPunch") ? punchType : null,
                RequestedDateTime = requestedDateTime,
                OriginalPunchId = correctionOriginalPunchId > 0 ? correctionOriginalPunchId : null,
                Reason = correctionReason,
                Status = CorrectionRequestStatus.Submitted,
                CreatedDate = DateTime.Now
            };

            context.TcCorrectionRequests.Add(request);
            await context.SaveChangesAsync();

            await Audit.LogActionAsync(
                actionCode: AuditActions.Correction.Submitted,
                entityType: AuditEntityTypes.Correction,
                entityId: request.RequestId.ToString(),
                newValues: new
                {
                    request.RequestId,
                    request.EmployeeId,
                    RequestType = request.RequestType.ToString(),
                    WorkDate = request.WorkDate.ToString("yyyy-MM-dd"),
                    RequestedPunchType = request.RequestedPunchType?.ToString(),
                    RequestedDateTime = request.RequestedDateTime?.ToString("yyyy-MM-dd HH:mm:ss"),
                    OriginalPunchId = request.OriginalPunchId,
                    Status = request.Status.ToString()
                },
                reason: request.Reason,
                deltaSummary:
                    $"Employee {employeeId} submitted {request.RequestType} correction request for {request.WorkDate:MMM d}",
                source: AuditSource.AdminUi,
                employeeId: employeeId);

            Logger.LogInformation("Correction request submitted: Employee={EmployeeId}, Date={Date}, Type={Type}",
                employeeId, correctionDate, correctionType);

            showCorrectionModal = false;
            await LoadTimesheet();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error submitting correction request");
            correctionError = "An error occurred. Please try again.";
        }
        finally
        {
            isSubmittingCorrection = false;
        }
    }

    // ── Phase A2: employee inline Edit Time ────────────────────────────────

    /// <summary>
    /// Open the time-edit modal for a single existing TcTimePunch. Only used
    /// to adjust the TIME of a punch the employee already made. Add / missing
    /// / delete corrections go through the Request Correction flow.
    /// </summary>
    private void OpenEditPunch(long punchId, DateTime currentTime, DateOnly workDate, bool isInside)
    {
        editPunchId = punchId;
        editPunchOriginalTime = currentTime;
        editPunchNewTime = TimeOnly.FromDateTime(currentTime);
        editPunchWorkDate = workDate;
        editPunchIsIn = isInside;
        editPunchReason = "";
        editPunchError = "";
        showEditPunchModal = true;
    }

    private void CloseEditPunchModal()
    {
        showEditPunchModal = false;
        editPunchId = 0;
        editPunchReason = "";
        editPunchError = "";
    }

    private async Task SaveEditPunchAsync()
    {
        if (isSavingEditPunch || editPunchId <= 0) return;

        var trimmedReason = (editPunchReason ?? string.Empty).Trim();
        if (trimmedReason.Length < 5)
        {
            editPunchError = "A reason of at least 5 characters is required.";
            return;
        }

        isSavingEditPunch = true;
        editPunchError = "";
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();

            var punch = await context.TcTimePunches
                .FirstOrDefaultAsync(p => p.PunchId == editPunchId && p.EmployeeId == employeeId);
            if (punch == null)
            {
                editPunchError = "Punch not found or not yours. Refresh and try again.";
                return;
            }

            // Defense-in-depth: don't allow edits of punches from a submitted /
            // locked pay period even if the button was somehow shown.
            if (weeklyTimesheet.IsSubmitted)
            {
                editPunchError = "This timesheet is already submitted. Ask your supervisor to open it.";
                return;
            }

            var originalDt = punch.PunchDateTime;
            var newDt = editPunchWorkDate.ToDateTime(editPunchNewTime);

            if (newDt == originalDt)
            {
                editPunchError = "The new time is the same as the current time.";
                return;
            }

            // Preserve the very first original if this punch has been edited before.
            if (!punch.OriginalPunchDateTime.HasValue)
                punch.OriginalPunchDateTime = originalDt;

            punch.PunchDateTime = newDt;
            punch.RoundedDateTime = newDt; // employee edits bypass the ceiling rounding
            punch.IsModified = true;
            punch.ModifiedBy = currentUserEmail;
            punch.ModifiedReason = $"[Employee Self-Edit] {trimmedReason}";

            // Flag the day as exception for supervisor review.
            var timecard = await context.TcDailyTimecards
                .FirstOrDefaultAsync(t => t.EmployeeId == employeeId && t.WorkDate == editPunchWorkDate);
            if (timecard != null)
            {
                timecard.HasException = true;
                timecard.ExceptionNotes = $"Employee edited {(editPunchIsIn ? "IN" : "OUT")} punch at "
                                        + $"{DateTime.Now:MMM d h:mm tt}: {trimmedReason}";
                timecard.ModifiedDate = DateTime.Now;
            }

            await context.SaveChangesAsync();

            await Audit.LogActionAsync(
                actionCode: AuditActions.Punch.Modified,
                entityType: AuditEntityTypes.Punch,
                entityId: punch.PunchId.ToString(),
                oldValues: new { OriginalPunchDateTime = originalDt.ToString("yyyy-MM-dd HH:mm:ss") },
                newValues: new
                {
                    punch.PunchId,
                    punch.EmployeeId,
                    PunchType = punch.PunchType.ToString(),
                    NewPunchDateTime = newDt.ToString("yyyy-MM-dd HH:mm:ss"),
                    Source = "EMPLOYEE_SELF_EDIT",
                    WorkDate = editPunchWorkDate.ToString("yyyy-MM-dd")
                },
                reason: trimmedReason,
                deltaSummary:
                    $"Employee {employeeId} edited {punch.PunchType} time from "
                    + $"{originalDt:h:mm tt} to {newDt:h:mm tt} on {editPunchWorkDate:MMM d}. Day flagged as exception.",
                source: AuditSource.AdminUi,
                employeeId: employeeId,
                punchId: punch.PunchId);

            await TimesheetService.RecalculateDailyTimecardAsync(employeeId, editPunchWorkDate);

            showEditPunchModal = false;
            await LoadTimesheet();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving employee inline edit for punch {PunchId}", editPunchId);
            editPunchError = "Could not save the change. Please try again.";
        }
        finally
        {
            isSavingEditPunch = false;
        }
    }

    private static string FormatRequestType(CorrectionRequestType type) => type switch
    {
        CorrectionRequestType.MissedPunch => "Missed Punch",
        CorrectionRequestType.WrongTime => "Wrong Time",
        CorrectionRequestType.WrongType => "Wrong Type",
        CorrectionRequestType.AddPunch => "Add Punch",
        CorrectionRequestType.DeletePunch => "Delete Punch",
        _ => type.ToString()
    };

    // ── Display DTOs ───────────────────────────────────────────────────────
    private class PunchPairDisplay
    {
        public string Label { get; set; } = "";
        public string BadgeClass { get; set; } = "";
        public string InTime { get; set; } = "";
        public string OutTime { get; set; } = "";
        public string RoundedIn { get; set; } = "";
        public string RoundedOut { get; set; } = "";
        public string Hours { get; set; } = "";
        public bool IsManual { get; set; }
        public bool IsModified { get; set; }

        // Populated for Phase A2 employee inline Edit Time. Null when that
        // side of the pair is missing. WorkDate is carried so the edit handler
        // knows which daily timecard to flag as exception.
        public long? InPunchId { get; set; }
        public long? OutPunchId { get; set; }
        public DateTime? InPunchDateTime { get; set; }
        public DateTime? OutPunchDateTime { get; set; }
        public DateOnly WorkDate { get; set; }
    }
