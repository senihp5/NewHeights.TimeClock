@page "/admin/schedule/import"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@attribute [Authorize(Policy = "RequireAdmin")]
@using NewHeights.TimeClock.Data
@using NewHeights.TimeClock.Data.Entities
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@using ClosedXML.Excel
@inject IDbContextFactory<TimeClockDbContext> DbFactory
@inject ILogger<ScheduleImport> Logger
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Schedule Import</PageTitle>

<div class="admin-page">
    <div class="admin-header">
        <div>
            <h1>Master Schedule Import</h1>
            <p class="admin-subtitle">Upload the campus master schedule spreadsheet to import teacher assignments.</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success">@successMessage</div>
    }

    @if (phase == ImportPhase.Upload)
    {
        <div class="si-upload-card">
            <h2>Step 1: Select Spreadsheet</h2>
            <p>
                Upload the campus master schedule XLSX file using the consolidated format:<br />
                <strong>Col A:</strong> Last, First &nbsp;|&nbsp; <strong>Col B:</strong> Room &nbsp;|&nbsp;
                <strong>Col C:</strong> DAYS (DAY/MW/TTH) &nbsp;|&nbsp;
                <strong>Cols D–I:</strong> Mon/Wed periods 1–6 &nbsp;|&nbsp;
                <strong>Cols J–O:</strong> Tue/Thu periods 1–6
            </p>

            <div class="si-field-row">
                <label>Campus</label>
                <select class="form-select si-select" @bind="selectedCampusId">
                    <option value="0">-- Select Campus --</option>
                    @foreach (var c in campuses)
                    {
                        <option value="@c.CampusId">@c.CampusName</option>
                    }
                </select>
            </div>

            <div class="si-field-row">
                <label>Term</label>
                <select class="form-select si-select" @bind="selectedTerm">
                    <option value="">-- Select Term --</option>
                    <option value="TERM2">Term 2</option>
                    <option value="TERM3">Term 3</option>
                    <option value="TERM4">Term 4</option>
                </select>
            </div>

            <div class="si-field-row">
                <label>School Year</label>
                <input class="form-control si-input" type="text" @bind="schoolYear" placeholder="e.g. 2025-26" />
            </div>

            <div class="si-field-row">
                <label>Spreadsheet File (.xlsx)</label>
                <InputFile OnChange="HandleFileSelected" accept=".xlsx" class="form-control si-file-input" />
            </div>

            <div class="si-button-row">
                <button class="btn btn-primary"
                        @onclick="ParseSpreadsheet"
                        disabled="@(isProcessing || selectedFile == null || selectedCampusId == 0 || string.IsNullOrEmpty(selectedTerm))">
                    @if (isProcessing)
                    {
                        <span>Parsing...</span>
                    }
                    else
                    {
                        <span>Parse &amp; Match Teachers</span>
                    }
                </button>
            </div>
        </div>
    }

    @if (phase == ImportPhase.Review && parsedRows.Count > 0)
    {
        <div class="si-review-section">
            <h2>Step 2: Review Teacher Matches</h2>

            <div class="si-summary-bar">
                <span class="si-badge si-badge-green">✓ Confident: @parsedRows.Count(r => r.TeacherMatchMethod is "Exact" or "LastName" or "Manual")</span>
                <span class="si-badge si-badge-yellow">⚠ Fuzzy: @parsedRows.Count(r => r.TeacherMatchMethod == "Fuzzy")</span>
                <span class="si-badge si-badge-red">✗ Unmatched: @parsedRows.Count(r => r.TeacherMatchMethod == "Unmatched")</span>
                <span class="si-badge si-badge-gray">Total rows: @parsedRows.Count</span>
            </div>

            <p class="si-hint">
                Green rows are ready to save. Yellow rows need verification. Red rows must be matched manually.
                Click any teacher name to reassign.
            </p>

            <table class="si-table">
                <thead>
                    <tr>
                        <th>Raw Name</th>
                        <th>Resolved Teacher</th>
                        <th>Match</th>
                        <th>Room</th>
                        <th>Pattern</th>
                        <th>Shift</th>
                        <th>MW Periods</th>
                        <th>TTh Periods</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in parsedRows)
                    {
                        <tr class="@GetRowClass(row)">
                            <td class="si-raw-cell">@row.RawTeacherCell</td>
                            <td>
                                @if (editingRow == row)
                                {
                                    <div class="si-inline-search">
                                        <input class="form-control form-control-sm"
                                               value="@searchText"
                                               @oninput="OnSearchChanged"
                                               placeholder="Search by last name..." />
                                        @if (searchResults.Count > 0)
                                        {
                                            <ul class="si-search-dropdown">
                                                @foreach (var s in searchResults)
                                                {
                                                    <li @onclick="() => AssignTeacher(row, s)">
                                                        @s.LastName, @s.FirstName (@s.IdNumber)
                                                    </li>
                                                }
                                            </ul>
                                        }
                                        <button class="btn btn-sm btn-secondary mt-1" @onclick="CancelEdit">Cancel</button>
                                    </div>
                                }
                                else
                                {
                                    <span class="@(row.TeacherMatchMethod == "Unmatched" ? "si-unmatched-link" : "si-matched-name")"
                                          @onclick="() => StartEdit(row)">
                                        @(row.ResolvedTeacherName ?? row.RawTeacherCell)
                                    </span>
                                }
                            </td>
                            <td>
                                <span class="si-method-badge si-method-@(row.TeacherMatchMethod?.ToLower() ?? "unmatched")">
                                    @(row.TeacherMatchMethod ?? "Unmatched")
                                </span>
                            </td>
                            <td>@row.Room</td>
                            <td>@row.DayPattern</td>
                            <td>
                                <span class="si-shift-badge si-shift-@(row.Shift?.ToLower() ?? "day")">
                                    @row.Shift
                                </span>
                            </td>
                            <td class="si-periods">@FormatPeriods(row.MW_P1, row.MW_P2, row.MW_P3, row.MW_P4, row.MW_P5, row.MW_P6)</td>
                            <td class="si-periods">@FormatPeriods(row.TTh_P1, row.TTh_P2, row.TTh_P3, row.TTh_P4, row.TTh_P5, row.TTh_P6)</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="si-button-row">
                <button class="btn btn-secondary" @onclick="() => phase = ImportPhase.Upload">← Back</button>
                <button class="btn btn-success"
                        @onclick="SaveImport"
                        disabled="@(isProcessing || parsedRows.Any(r => r.TeacherMatchMethod == "Unmatched" && r.TeacherStaffDcid == null))">
                    @if (isProcessing)
                    {
                        <span>Saving...</span>
                    }
                    else
                    {
                        <span>Save @parsedRows.Count Row(s) to Database</span>
                    }
                </button>
            </div>

            @if (parsedRows.Any(r => r.TeacherMatchMethod == "Unmatched" && r.TeacherStaffDcid == null))
            {
                <p class="si-warning">Cannot save until all red rows are manually matched. Click the teacher name to search and assign.</p>
            }
        </div>
    }
</div>

<style>
    .si-upload-card {
        background: var(--card-bg, #fff);
        border: 1px solid var(--border-color, #dee2e6);
        border-radius: 8px;
        padding: 1.5rem;
        max-width: 680px;
    }

    .si-upload-card p {
        font-size: 0.875rem;
        color: #4b5563;
        margin-bottom: 1rem;
    }

    .si-field-row {
        display: flex;
        flex-direction: column;
        gap: 4px;
        margin-bottom: 1rem;
    }

    .si-field-row label {
        font-weight: 600;
        font-size: 0.875rem;
    }

    .si-select, .si-input, .si-file-input {
        max-width: 400px;
    }

    .si-button-row {
        display: flex;
        gap: 0.75rem;
        margin-top: 1.25rem;
        flex-wrap: wrap;
    }

    .si-review-section { margin-top: 1rem; }

    .si-summary-bar {
        display: flex;
        gap: 0.75rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
    }

    .si-badge {
        padding: 0.25rem 0.75rem;
        border-radius: 999px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .si-badge-green  { background: #d1fae5; color: #065f46; }
    .si-badge-yellow { background: #fef3c7; color: #92400e; }
    .si-badge-red    { background: #fee2e2; color: #991b1b; }
    .si-badge-gray   { background: #f3f4f6; color: #374151; }

    .si-hint {
        font-size: 0.875rem;
        color: #6b7280;
        margin-bottom: 0.75rem;
    }

    .si-warning {
        color: #b91c1c;
        font-size: 0.875rem;
        margin-top: 0.5rem;
    }

    .si-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.8rem;
        margin-bottom: 1rem;
    }

    .si-table th {
        background: #1e3a5f;
        color: #fff;
        padding: 8px 10px;
        text-align: left;
        font-weight: 600;
        white-space: nowrap;
    }

    .si-table td {
        padding: 6px 10px;
        border-bottom: 1px solid #e5e7eb;
        vertical-align: top;
    }

    .si-row-green  { background: #f0fdf4; }
    .si-row-yellow { background: #fffbeb; }
    .si-row-red    { background: #fef2f2; }

    .si-raw-cell {
        font-size: 0.78rem;
        color: #6b7280;
        max-width: 130px;
        word-break: break-word;
    }

    .si-matched-name {
        cursor: pointer;
        text-decoration: underline dotted;
        color: #1e3a5f;
    }

    .si-unmatched-link {
        cursor: pointer;
        font-weight: 600;
        color: #dc2626;
        text-decoration: underline;
    }

    .si-method-badge {
        padding: 2px 7px;
        border-radius: 4px;
        font-size: 0.72rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .si-method-exact, .si-method-lastname { background: #d1fae5; color: #065f46; }
    .si-method-fuzzy   { background: #fef3c7; color: #92400e; }
    .si-method-manual  { background: #dbeafe; color: #1e40af; }
    .si-method-unmatched { background: #fee2e2; color: #991b1b; }

    .si-shift-badge {
        padding: 2px 7px;
        border-radius: 4px;
