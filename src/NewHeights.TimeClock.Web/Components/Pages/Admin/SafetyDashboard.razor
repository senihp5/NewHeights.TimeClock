@page "/admin/safety"
@page "/admin/onsite"
@page "/safety"
@layout KioskLayout
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@attribute [Authorize(Policy = "RequireReception")]
@using NewHeights.TimeClock.Shared.Constants
@using NewHeights.TimeClock.Data
@using NewHeights.TimeClock.Data.Entities
@using Microsoft.EntityFrameworkCore
@using NewHeights.TimeClock.Web.Services
@inject IDbContextFactory<TimeClockDbContext> DbFactory
@inject IJSRuntime JS
@inject ILogger<SafetyDashboard> Logger
@inject IUserContextService UserCtx
@implements IAsyncDisposable

<PageTitle>Safety Dashboard - @AppConstants.Branding.ShortName</PageTitle>

<div class="safety-dashboard">
    <header class="dashboard-header">
        <div class="header-left">
            <h1>&#128737; Safety Dashboard</h1>
            <p class="subtitle">
                @if (_isDistrictView)
                {
                    <span>All Campuses</span>
                }
                else
                {
                    <span>@_userCampusName</span>
                }
            </p>
        </div>
        <div class="header-right">
            <span class="last-updated">Last updated: @lastRefresh.ToString("h:mm:ss tt")</span>
            <button class="btn-refresh" @onclick="RefreshData" disabled="@isLoading">
                @if (isLoading) { <span>Loading...</span> } else { <span>&#128260; Refresh</span> }
            </button>
            <button class="btn-emergency" @onclick="ShowEmergencyMuster">
                &#128680; Emergency Muster
            </button>
        </div>
    </header>

    <div class="campus-overview">
        <h2>Campus Occupancy</h2>
        <div class="campus-cards">
            @foreach (var campus in campusStats)
            {
                <div class="campus-card @(selectedCampusFilter == campus.CampusCode ? "selected" : "")"
                     @onclick="() => FilterByCampus(campus.CampusCode)">
                    <h3>@campus.CampusName</h3>
                    <div class="occupancy-stats">
                        <div class="stat-item staff">
                            <span class="stat-value">@campus.StaffOnSite</span>
                            <span class="stat-label">Staff</span>
                        </div>
                        <div class="stat-item students">
                            <span class="stat-value">@campus.StudentsOnSite</span>
                            <span class="stat-label">Students</span>
                        </div>
                        <div class="stat-item total">
                            <span class="stat-value">@campus.TotalOnSite</span>
                            <span class="stat-label">Total</span>
                        </div>
                    </div>
                </div>
            }
            @if (_isDistrictView && campusStats.Count > 1)
            {
                <div class="campus-card total-card @(selectedCampusFilter == null ? "selected" : "")"
                     @onclick="@(() => FilterByCampus(null))">
                    <h3>All Campuses</h3>
                    <div class="occupancy-stats">
                        <div class="stat-item staff">
                            <span class="stat-value">@campusStats.Sum(c => c.StaffOnSite)</span>
                            <span class="stat-label">Staff</span>
                        </div>
                        <div class="stat-item students">
                            <span class="stat-value">@campusStats.Sum(c => c.StudentsOnSite)</span>
                            <span class="stat-label">Students</span>
                        </div>
                        <div class="stat-item total">
                            <span class="stat-value">@campusStats.Sum(c => c.TotalOnSite)</span>
                            <span class="stat-label">Total</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="main-content">
        <div class="onsite-panel">
            <div class="panel-header">
                <h2>&#128100; Currently On Site</h2>
                <div class="panel-controls">
                    <input type="text"
                           @bind="searchTerm"
                           @bind:event="oninput"
                           placeholder="Search by name or ID..."
                           class="search-input" />
                    <select @bind="personTypeFilter" class="filter-select">
                        <option value="">All People</option>
                        <option value="STAFF">Staff Only</option>
                        <option value="STUDENT">Students Only</option>
                    </select>
                    <button class="btn-export" @onclick="ExportOnSiteList">&#128196; Export</button>
                </div>
            </div>
            <div class="onsite-table-container">
                <table class="onsite-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Type</th>
                            <th>ID</th>
                            @if (_isDistrictView)
                            {
                                <th>Campus</th>
                            }
                            <th>Checked In</th>
                            <th>Duration</th>
                            @if (_canEdit)
                            {
                                <th>Actions</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (filteredOnSiteList.Any())
                        {
                            @foreach (var person in filteredOnSiteList)
                            {
                                <tr class="@person.TransactionType.ToLower()">
                                    <td class="name-cell"><strong>@person.LastName</strong>, @person.FirstName</td>
                                    <td><span class="type-badge @person.TransactionType.ToLower()">@person.TransactionType</span></td>
                                    <td>@person.IdNumber</td>
                                    @if (_isDistrictView)
                                    {
                                        <td>@person.CampusName</td>
                                    }
                                    <td>@person.CheckInTime.ToString("h:mm tt")</td>
                                    <td>@FormatDuration(person.CheckInTime)</td>
                                    @if (_canEdit)
                                    {
                                        <td>
                                            <button class="btn-action" @onclick="() => QuickCheckOut(person)" title="Check Out">
                                                &#128682; Out
                                            </button>
                                        </td>
                                    }
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="empty-message">
                                    @(isLoading ? "Loading..." : "No one currently on site")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="table-footer">
                <span>Showing @filteredOnSiteList.Count of @onSiteList.Count people</span>
            </div>
        </div>

        <div class="activity-panel">
            <div class="panel-header">
                <h2>&#128228; Live Activity</h2>
                <label class="auto-refresh-toggle">
                    <input type="checkbox" @bind="autoRefresh" />
                    Auto-refresh (30s)
                </label>
            </div>
            <div class="activity-feed">
                @if (recentActivity.Any())
                {
                    @foreach (var activity in recentActivity.Take(50))
                    {
                        <div class="activity-item @activity.ScanType.ToLower().Replace("_", "-")">
                            <span class="activity-icon">@GetActivityIcon(activity.ScanType)</span>
                            <div class="activity-details">
                                <span class="activity-name">@activity.FirstName @activity.LastName</span>
                                <span class="activity-type">@activity.TransactionType</span>
                            </div>
                            <div class="activity-meta">
                                <span class="activity-action">@FormatScanType(activity.ScanType)</span>
                                <span class="activity-time">@activity.ScanDateTime.ToString("h:mm:ss tt")</span>
                                @if (_isDistrictView)
                                {
                                    <span class="activity-campus">@activity.CampusName</span>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-activity"><p>No activity recorded today</p></div>
                }
            </div>
        </div>
    </div>
</div>

@if (showEmergencyModal)
{
    <div class="modal-overlay" @onclick="CloseEmergencyModal">
        <div class="modal-content emergency-modal" @onclick:stopPropagation>
            <div class="modal-header emergency">
                <h2>&#128680; Emergency Muster Report</h2>
                <button class="modal-close" @onclick="CloseEmergencyModal">X</button>
            </div>
            <div class="modal-body">
                <p class="emergency-notice">Everyone currently checked in who has NOT checked out.</p>
                <div class="emergency-timestamp">Generated: @DateTime.Now.ToString("MMMM d, yyyy h:mm:ss tt")</div>
                @foreach (var campus in campusStats.Where(c => c.TotalOnSite > 0))
                {
                    <div class="muster-campus">
                        <h3>@campus.CampusName (@campus.TotalOnSite people)</h3>
                        <h4>Staff (@campus.StaffOnSite)</h4>
                        <ul class="muster-list">
                            @foreach (var p in onSiteList.Where(x => x.CampusId == campus.CampusId && x.TransactionType == "STAFF").OrderBy(x => x.LastName))
                            {
                                <li>@p.LastName, @p.FirstName (@p.IdNumber)</li>
                            }
                        </ul>
                        <h4>Students (@campus.StudentsOnSite)</h4>
                        <ul class="muster-list">
                            @foreach (var p in onSiteList.Where(x => x.CampusId == campus.CampusId && x.TransactionType == "STUDENT").OrderBy(x => x.LastName))
                            {
                                <li>@p.LastName, @p.FirstName (@p.IdNumber)</li>
                            }
                        </ul>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn-print" @onclick="PrintMusterReport">Print Report</button>
                <button class="btn-export" @onclick="ExportMusterReport">Export CSV</button>
                <button class="btn-close" @onclick="CloseEmergencyModal">Close</button>
            </div>
        </div>
    </div>
}

@if (showCheckOutModal && checkOutPerson != null)
{
    <div class="modal-overlay" @onclick="CloseCheckOutModal">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h2>Check Out</h2>
                <button class="modal-close" @onclick="CloseCheckOutModal">X</button>
            </div>
            <div class="modal-body">
                <p>Check out <strong>@checkOutPerson.FirstName @checkOutPerson.LastName</strong>?</p>
                <div class="form-group">
                    <label>Time</label>
                    <input type="time" @bind="checkOutTime" />
                </div>
                <div class="form-group">
                    <label>Reason (optional)</label>
                    <input type="text" @bind="checkOutNotes" placeholder="e.g. Left campus" />
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" @onclick="CloseCheckOutModal">Cancel</button>
                <button class="btn-save" @onclick="SaveCheckOut">Confirm Check Out</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _isDistrictView = false;
    private bool _canEdit = false;
    private string _userCampusName = "";
    private int? _userCampusId = null;

    private DateTime lastRefresh = DateTime.Now;
    private bool isLoading = false;
    private bool autoRefresh = true;
    private bool showEmergencyModal = false;
    private bool showCheckOutModal = false;
    private string searchTerm = "";
    private string personTypeFilter = "";
    private string? selectedCampusFilter = null;

    private OnSitePerson? checkOutPerson = null;
    private TimeOnly checkOutTime = TimeOnly.FromDateTime(DateTime.Now);
    private string checkOutNotes = "";
    private string _currentUserName = "";

    private List<CampusStats> campusStats = new();
    private List<OnSitePerson> onSiteList = new();
    private List<ActivityItem> recentActivity = new();
    private System.Timers.Timer? refreshTimer;

    private List<OnSitePerson> filteredOnSiteList => onSiteList
        .Where(p => string.IsNullOrEmpty(searchTerm) ||
                    p.FirstName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    p.LastName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    p.IdNumber.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
        .Where(p => string.IsNullOrEmpty(personTypeFilter) || p.TransactionType == personTypeFilter)
        .Where(p => selectedCampusFilter == null || p.CampusCode == selectedCampusFilter)
        .OrderBy(p => p.LastName).ThenBy(p => p.FirstName)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        var ctx = await UserCtx.GetCurrentUserAsync();
        _currentUserName = ctx.DisplayName;

        // District view: HR, District role, or Admin see all campuses
        _isDistrictView = ctx.IsHR || ctx.IsAdmin || ctx.IsDistrict;

        // Can edit: HR (all campuses), Admin (all), Supervisor/CampusAdmin (own campus enforced by data scope)
        _canEdit = ctx.IsHR || ctx.IsAdmin || ctx.IsSupervisor || ctx.IsCampusAdmin;

        // Campus-scoped users: lock filter to their campus
        if (!_isDistrictView)
        {
            _userCampusId = ctx.CampusId;
            _userCampusName = ctx.CampusDisplayName;
            selectedCampusFilter = ctx.CampusCode;
        }

        await RefreshData();

        refreshTimer = new System.Timers.Timer(30000);
        refreshTimer.Elapsed += async (s, e) =>
        {
            if (autoRefresh)
                await InvokeAsync(async () => { await RefreshData(); StateHasChanged(); });
        };
        refreshTimer.Start();
    }

    private async Task RefreshData()
    {
        if (isLoading) return;
        isLoading = true;
        StateHasChanged();
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            var today = DateTime.Today;

            // Exclude DISTRICT as a campus — district employees check in at physical campuses
            var allCampuses = await context.Campuses.AsNoTracking()
                .Where(c => c.CampusCode != AppConstants.Campus.DistrictCode)
                .OrderBy(c => c.CampusName)
                .ToListAsync();

            // Campus-scoped: filter to user''s campus only
            var visibleCampuses = _isDistrictView
                ? allCampuses
                : allCampuses.Where(c => c.CampusId == _userCampusId).ToList();

            var visibleCampusIds = visibleCampuses.Select(c => c.CampusId).ToList();

            var todayTransactions = await context.AttendanceTransactions.AsNoTracking()
                .Where(t => t.ScanDateTime.Date == today && visibleCampusIds.Contains(t.CampusId))
                .OrderByDescending(t => t.ScanDateTime)
                .ToListAsync();

            campusStats = visibleCampuses.Select(c => new CampusStats
            {
                CampusId = c.CampusId,
                CampusCode = c.CampusCode,
                CampusName = c.CampusName
            }).ToList();

            onSiteList.Clear();
            foreach (var personGroup in todayTransactions.GroupBy(t => new { t.IdNumber, t.TransactionType }))
            {
                var ordered = personGroup.OrderByDescending(t => t.ScanDateTime).ToList();
                var lastScan = ordered.First();
                if (lastScan.ScanType == "CAMPUS_IN" || lastScan.ScanType == "LUNCH_IN")
                {
                    var campus = allCampuses.FirstOrDefault(c => c.CampusId == lastScan.CampusId);
                    var firstIn = ordered.Last(s => s.ScanType == "CAMPUS_IN" || s.ScanType == "LUNCH_IN");
                    onSiteList.Add(new OnSitePerson
                    {
                        IdNumber = lastScan.IdNumber,
                        FirstName = lastScan.FirstName,
                        LastName = lastScan.LastName,
                        TransactionType = lastScan.TransactionType,
                        CampusId = lastScan.CampusId,
                        CampusCode = campus?.CampusCode ?? "",
                        CampusName = campus?.CampusName ?? "Unknown",
                        CheckInTime = firstIn.ScanDateTime
                    });
                }
            }

            foreach (var stat in campusStats)
            {
                stat.StaffOnSite = onSiteList.Count(p => p.CampusId == stat.CampusId && p.TransactionType == "STAFF");
                stat.StudentsOnSite = onSiteList.Count(p => p.CampusId == stat.CampusId && p.TransactionType == "STUDENT");
            }

            recentActivity = todayTransactions.Take(100).Select(t =>
            {
                var campus = allCampuses.FirstOrDefault(c => c.CampusId == t.CampusId);
                return new ActivityItem
                {
                    TransactionId = t.TransactionId,
                    IdNumber = t.IdNumber,
                    FirstName = t.FirstName,
                    LastName = t.LastName,
                    TransactionType = t.TransactionType,
                    ScanType = t.ScanType,
                    ScanDateTime = t.ScanDateTime,
                    CampusName = campus?.CampusName ?? "Unknown"
                };
            }).ToList();

            lastRefresh = DateTime.Now;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error refreshing safety dashboard");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void FilterByCampus(string? campusCode)
    {
        // Campus-scoped users cannot change filter
        if (!_isDistrictView) return;
        selectedCampusFilter = campusCode;
        StateHasChanged();
    }

    private void QuickCheckOut(OnSitePerson person)
    {
        checkOutPerson = person;
        checkOutTime = TimeOnly.FromDateTime(DateTime.Now);
        checkOutNotes = "";
        showCheckOutModal = true;
    }

    private void CloseCheckOutModal() { showCheckOutModal = false; checkOutPerson = null; }

    private async Task SaveCheckOut()
    {
        if (checkOutPerson == null) return;
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            var t = new AttendanceTransaction
            {
                TransactionType = checkOutPerson.TransactionType,
                IdNumber = checkOutPerson.IdNumber,
                FirstName = checkOutPerson.FirstName,
                LastName = checkOutPerson.LastName,
                CampusId = checkOutPerson.CampusId,
                LocationId = 1,
                ScanDateTime = DateTime.Today.Add(checkOutTime.ToTimeSpan()),
                ScanType = "CAMPUS_OUT",
                ScanMethod = "MANUAL",
                TerminalId = 0,
                DataSource = "LOCAL",
                ValidationStatus = "VALID",
                Notes = string.IsNullOrWhiteSpace(checkOutNotes)
                    ? $"[Safety Dashboard checkout by {_currentUserName}]"
                    : $"[Safety Dashboard by {_currentUserName}] {checkOutNotes}",
                CreatedDate = DateTime.UtcNow
            };
            context.AttendanceTransactions.Add(t);
            await context.SaveChangesAsync();
            Logger.LogInformation("Safety dashboard checkout: {Person} by {User}", checkOutPerson.IdNumber, _currentUserName);
            CloseCheckOutModal();
            await RefreshData();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving checkout");
        }
    }

    private void ShowEmergencyMuster() { showEmergencyModal = true; }
    private void CloseEmergencyModal() { showEmergencyModal = false; }
    private async Task PrintMusterReport() { await JS.InvokeVoidAsync("print"); }
    private async Task ExportMusterReport() { await ExportToCsv(onSiteList, "EmergencyMuster"); }
    private async Task ExportOnSiteList() { await ExportToCsv(filteredOnSiteList, "OnSiteList"); }

    private async Task ExportToCsv(List<OnSitePerson> list, string prefix)
    {
        var csv = "Last Name,First Name,Type,ID,Campus,Check-In Time,Duration\n";
        foreach (var p in list.OrderBy(x => x.CampusName).ThenBy(x => x.LastName))
            csv += Q(p.LastName) + "," + Q(p.FirstName) + "," + p.TransactionType + "," + p.IdNumber + "," + Q(p.CampusName) + "," + p.CheckInTime.ToString("h:mm tt") + "," + FormatDuration(p.CheckInTime) + "\n";
        var fileName = $"{prefix}_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
        var bytes = System.Text.Encoding.UTF8.GetBytes(csv);
        await JS.InvokeVoidAsync("downloadFile", fileName, "text/csv", Convert.ToBase64String(bytes));
    }

    private static string Q(string s)
    {
        return "\"" + s.Replace("\"", "''") + "\"";
    }
    private static string FormatDuration(DateTime t)
    {
        var d = DateTime.Now - t;
        if (d.TotalHours >= 1) return ((int)d.TotalHours).ToString() + "h " + d.Minutes.ToString() + "m";
        return d.Minutes.ToString() + "m";
    }
    private static string GetActivityIcon(string scanType)
    {
        if (scanType == "CAMPUS_IN") return "In";
        if (scanType == "CAMPUS_OUT") return "Out";
        if (scanType == "LUNCH_OUT") return "Lunch";
        if (scanType == "LUNCH_IN") return "Back";
        return "-";
    }
    private static string FormatScanType(string scanType)
    {
        if (scanType == "CAMPUS_IN") return "Checked In";
        if (scanType == "CAMPUS_OUT") return "Checked Out";
        if (scanType == "LUNCH_OUT") return "Left for Lunch";
        if (scanType == "LUNCH_IN") return "Returned from Lunch";
        return scanType;
    }

    public ValueTask DisposeAsync() { refreshTimer?.Stop(); refreshTimer?.Dispose(); return ValueTask.CompletedTask; }

    private class CampusStats
    {
        public int CampusId { get; set; }
        public string CampusCode { get; set; } = "";
        public string CampusName { get; set; } = "";
        public int StaffOnSite { get; set; }
        public int StudentsOnSite { get; set; }
        public int TotalOnSite => StaffOnSite + StudentsOnSite;
    }
    private class OnSitePerson
    {
        public string IdNumber { get; set; } = "";
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string TransactionType { get; set; } = "";
        public int CampusId { get; set; }
        public string CampusCode { get; set; } = "";
        public string CampusName { get; set; } = "";
        public DateTime CheckInTime { get; set; }
    }
    private class ActivityItem
    {
        public long TransactionId { get; set; }
        public string IdNumber { get; set; } = "";
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string TransactionType { get; set; } = "";
        public string ScanType { get; set; } = "";
        public DateTime ScanDateTime { get; set; }
        public string CampusName { get; set; } = "";
    }
}
