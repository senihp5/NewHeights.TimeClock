@page "/admin/sub-pool-management"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using NewHeights.TimeClock.Data
@using NewHeights.TimeClock.Data.Entities
@using NewHeights.TimeClock.Shared.Audit
@using NewHeights.TimeClock.Shared.Constants
@using NewHeights.TimeClock.Shared.Enums
@using NewHeights.TimeClock.Web.Services
@using System.Security.Claims
@attribute [Authorize(Policy = "RequireSupervisor")]
@rendermode InteractiveServer
@inject IDbContextFactory<TimeClockDbContext> DbFactory
@inject IAuditService Audit
@inject AuthenticationStateProvider AuthStateProvider
@inject IGraphService Graph
@inject IConfiguration Config
@inject ILogger<SubPoolManagement> Logger

<PageTitle>Sub Pool Management</PageTitle>

<div style="padding: 1.25rem;">
    <header style="margin-bottom: 1.5rem;">
        <h1 style="margin:0;">Sub Pool Management</h1>
        <p style="color:#64748b; margin:.35rem 0 0; font-size:.9rem;">
            Teacher subs and admin subs are managed as separate pools. Admin subs
            sync from the <code>TimeClock.Substitute.Admin</code> Entra group and
            are tagged with one or more specialties (Reception, Admin, etc.).
        </p>
        @if (adminGroupConfigured && adminGroupFetchError == null)
        {
            <p style="margin:.4rem 0 0; font-size:.82rem; color:#075985;">
                SubstituteAdmin Entra group returned <strong>@adminGroupMemberCount</strong> transitive member(s).
            </p>
        }
        else if (!adminGroupConfigured)
        {
            <p style="margin:.4rem 0 0; font-size:.82rem; color:#854d0e;">
                SubstituteAdmin Entra group is not configured
                (set <code>GraphSync__EmployeeGroupIds__SubstituteAdmin</code>).
            </p>
        }
        else
        {
            <p style="margin:.4rem 0 0; font-size:.82rem; color:#b91c1c;">
                Could not fetch SubstituteAdmin group members: @adminGroupFetchError
            </p>
        }
    </header>

    @if (isLoading)
    {
        <div>Loading…</div>
    }
    else
    {
        @* ── Teacher Subs ─────────────────────────────────────────────── *@
        <section style="margin-bottom:2rem;">
            <h2 style="margin:0 0 .75rem;">Active Teacher Subs (@activeTeacherSubs.Count)</h2>
            <table style="width:100%; border-collapse:collapse; background:white; border:1px solid #e2e8f0;">
                <thead style="background:#f8fafc; text-align:left;">
                    <tr>
                        <th style="padding:.5rem .75rem; border-bottom:1px solid #e2e8f0;">Name</th>
                        <th style="padding:.5rem .75rem; border-bottom:1px solid #e2e8f0;">Email</th>
                        <th style="padding:.5rem .75rem; border-bottom:1px solid #e2e8f0; text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in activeTeacherSubs)
                    {
                        <tr>
                            <td style="padding:.5rem .75rem; border-bottom:1px solid #e2e8f0;">
                                <strong>@(s.Staff?.FullName ?? s.DisplayName ?? s.Email ?? $"Employee {s.EmployeeId}")</strong>
                            </td>
                            <td style="padding:.5rem .75rem; border-bottom:1px solid #e2e8f0; color:#475569; font-size:.85rem;">
                                @(s.Email ?? "—")
                            </td>
                            <td style="padding:.5rem .75rem; border-bottom:1px solid #e2e8f0; text-align:right; white-space:nowrap;">
                                <button type="button"
                                        style="margin-right:.4rem; padding:.35rem .6rem; background:#0369a1; color:white; border:none; border-radius:4px; cursor:pointer; font-size:.82rem;"
                                        title="Manually tag this sub as ADMIN_SUB. Normally admin subs should be in the SubstituteAdmin Entra group; this is a manual override."
                                        @onclick="() => ManualSetAdminSubAsync(s.EmployeeId)">
                                    Set Admin Sub
                                </button>
                                <button type="button"
                                        style="padding:.35rem .75rem; background:#dc2626; color:white; border:none; border-radius:4px; cursor:pointer; font-size:.85rem;"
                                        @onclick="() => OpenExcludeModal(s.EmployeeId)">
                                    Exclude
                                </button>
                            </td>
                        </tr>
                    }
                    @if (activeTeacherSubs.Count == 0)
                    {
                        <tr><td colspan="3" style="padding:.75rem; color:#94a3b8;">No active teacher subs.</td></tr>
                    }
                </tbody>
            </table>
        </section>

        @* ── Admin Subs ───────────────────────────────────────────────── *@
        <section style="margin-bottom:2rem;">
            <h2 style="margin:0 0 .4rem;">Active Admin Subs (@activeAdminSubs.Count)</h2>
            <p style="color:#64748b; font-size:.85rem; margin:0 0 .75rem;">
                Click <strong>Edit Specialties</strong>, pick one or more from the list,
                then click <strong>Save</strong>. Tags render as chips in the Specialties column.
            </p>
            <table style="width:100%; border-collapse:collapse; background:white; border:1px solid #e2e8f0;">
                <thead style="background:#f8fafc; text-align:left;">
                    <tr>
                        <th style="padding:.5rem .75rem; border-bottom:1px solid #e2e8f0;">Name</th>
                        <th style="padding:.5rem .75rem; border-bottom:1px solid #e2e8f0; text-align:center;" title="In SubstituteAdmin Entra group?">Admin Group</th>
                        <th style="padding:.5rem .75rem; border-bottom:1px solid #e2e8f0;">Email</th>
                        <th style="padding:.5rem .75rem; border-bottom:1px solid #e2e8f0;">Specialties</th>
                        <th style="padding:.5rem .75rem; border-bottom:1px solid #e2e8f0; text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in activeAdminSubs)
                    {
                        var inAdminGroup = !string.IsNullOrWhiteSpace(s.EntraObjectId)
                                        && adminGroupMemberObjectIds.Contains(s.EntraObjectId);
                        <tr>
                            <td style="padding:.5rem .75rem; border-bottom:1px solid #e2e8f0;">
                                <strong>@(s.Staff?.FullName ?? s.DisplayName ?? s.Email ?? $"Employee {s.EmployeeId}")</strong>
                            </td>
                            <td style="padding:.5rem .75rem; border-bottom:1px solid #e2e8f0; text-align:center;">
                                @if (!adminGroupConfigured)
                                {
                                    <span style="color:#cbd5e1;" title="SubstituteAdmin group not configured">—</span>
                                }
                                else if (string.IsNullOrWhiteSpace(s.EntraObjectId))
                                {
                                    <span style="color:#b45309; font-size:.85rem;" title="Sub has no EntraObjectId — cannot match against group">!</span>
                                }
                                else if (inAdminGroup)
                                {
                                    <span style="color:#16a34a; font-weight:600;" title="Member of SubstituteAdmin Entra group">&#10003;</span>
                                }
                                else
                                {
                                    <span style="color:#94a3b8;" title="Not a member of SubstituteAdmin (likely a manual override)">&#10005;</span>
                                }
                            </td>
                            <td style="padding:.5rem .75rem; border-bottom:1px solid #e2e8f0; color:#475569; font-size:.85rem;">
                                @(s.Email ?? "—")
                            </td>
                            <td style="padding:.5rem .75rem; border-bottom:1px solid #e2e8f0;">
                                @{
                                    var assigned = currentAssignmentsByEmployee.GetValueOrDefault(s.EmployeeId, new());
                                }
                                @if (assigned.Count == 0)
                                {
                                    <span style="color:#94a3b8; font-size:.85rem;">none</span>
                                }
                                else
                                {
                                    @foreach (var sid in assigned)
                                    {
                                        var name = specialtyCatalog.FirstOrDefault(x => x.SpecialtyId == sid)?.SpecialtyName ?? "?";
                                        <span style="display:inline-block; margin-right:4px; padding:1px 8px; background:#dbeafe; color:#1e40af; border:1px solid #93c5fd; border-radius:10px; font-size:0.78rem;">@name</span>
                                    }
                                }
                            </td>
                            <td style="padding:.5rem .75rem; border-bottom:1px solid #e2e8f0; text-align:right; white-space:nowrap;">
                                <button type="button"
                                        style="margin-right:.4rem; padding:.35rem .75rem; background:#1e40af; color:white; border:none; border-radius:4px; cursor:pointer; font-size:.82rem;"
                                        @onclick="() => OpenSpecialtyEditor(s.EmployeeId)">
                                    Edit Specialties
                                </button>
                                <button type="button"
                                        style="margin-right:.4rem; padding:.35rem .6rem; background:#64748b; color:white; border:none; border-radius:4px; cursor:pointer; font-size:.82rem;"
                                        title="Clear the ADMIN_SUB tag. The next sync may re-apply it if this employee remains in the admin Entra group."
                                        @onclick="() => ManualUnsetAdminSubAsync(s.EmployeeId)">
                                    Unset Admin Sub
                                </button>
                                <button type="button"
                                        style="padding:.35rem .75rem; background:#dc2626; color:white; border:none; border-radius:4px; cursor:pointer; font-size:.85rem;"
                                        @onclick="() => OpenExcludeModal(s.EmployeeId)">
                                    Exclude
                                </button>
                            </td>
                        </tr>
                    }
                    @if (activeAdminSubs.Count == 0)
                    {
                        <tr><td colspan="5" style="padding:.75rem; color:#94a3b8;">
                            No active admin subs. To add one: place the person in the
                            <code>TimeClock.Substitute.Admin</code> Entra group and run Employee Sync.
                        </td></tr>
                    }
                </tbody>
            </table>
        </section>

        @* ── Excluded Subs ────────────────────────────────────────────── *@
        @if (excludedSubs.Count > 0)
        {
            <section style="margin-bottom:2rem;">
                <h2 style="margin:0 0 .75rem;">Excluded Subs (@excludedSubs.Count)</h2>
                <p style="color:#64748b; font-size:.85rem; margin:0 0 .5rem;">
                    These subs remain in the Entra group but will not appear as outreach candidates.
                </p>
                <table style="width:100%; border-collapse:collapse; background:#fef2f2; border:1px solid #fecaca;">
                    <thead style="background:#fee2e2; text-align:left;">
                        <tr>
                            <th style="padding:.5rem .75rem;">Name</th>
                            <th style="padding:.5rem .75rem;">Pool</th>
                            <th style="padding:.5rem .75rem;">Excluded By</th>
                            <th style="padding:.5rem .75rem;">When</th>
                            <th style="padding:.5rem .75rem;">Reason</th>
                            <th style="padding:.5rem .75rem; text-align:right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in excludedSubs)
                        {
                            var wasAdmin = string.Equals(s.SubRole, "ADMIN_SUB", StringComparison.OrdinalIgnoreCase);
                            <tr>
                                <td style="padding:.5rem .75rem;"><strong>@(s.Staff?.FullName ?? s.DisplayName ?? s.Email ?? "—")</strong></td>
                                <td style="padding:.5rem .75rem; font-size:.85rem;">@(wasAdmin ? "Admin" : "Teacher")</td>
                                <td style="padding:.5rem .75rem; font-size:.85rem;">@(s.ExcludedFromSubPoolBy ?? "—")</td>
                                <td style="padding:.5rem .75rem; font-size:.85rem;">@(s.ExcludedFromSubPoolDate?.ToString("MMM d, yyyy h:mm tt") ?? "—")</td>
                                <td style="padding:.5rem .75rem; font-size:.85rem;">@(s.ExcludedFromSubPoolReason ?? "—")</td>
                                <td style="padding:.5rem .75rem; text-align:right;">
                                    <button type="button" style="padding:.35rem .75rem; background:#16a34a; color:white; border:none; border-radius:4px; cursor:pointer; font-size:.85rem;"
                                            @onclick="() => RestoreSubAsync(s.EmployeeId)">
                                        Restore to Pool
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        }
    }
</div>

@if (excludeModalOpen)
{
    <div style="position:fixed; inset:0; background:rgba(0,0,0,0.5); display:flex; align-items:center; justify-content:center; z-index:1000;" @onclick="CloseExcludeModal">
        <div style="background:white; padding:1.5rem; border-radius:8px; max-width:500px; width:90%;" @onclick:stopPropagation>
            <h3 style="margin-top:0;">Exclude from Sub Pool</h3>
            <p style="color:#475569;">@excludeTargetName will not appear as a candidate for any future outreach until restored. They remain in the Entra group.</p>
            <label for="exclude-reason" style="display:block; font-weight:600; margin-bottom:.25rem;">Reason (required)</label>
            <textarea id="exclude-reason" @bind="excludeReason" rows="3" maxlength="500"
                      style="width:100%; padding:.5rem; border:1px solid #cbd5e1; border-radius:4px; font-family:inherit;"
                      placeholder="e.g. did not show up for last 2 assignments"></textarea>
            <div style="margin-top:1rem; display:flex; justify-content:flex-end; gap:.5rem;">
                <button type="button" style="padding:.5rem 1rem; background:#e5e7eb; border:none; border-radius:4px; cursor:pointer;" @onclick="CloseExcludeModal">Cancel</button>
                <button type="button" style="padding:.5rem 1rem; background:#dc2626; color:white; border:none; border-radius:4px; cursor:pointer;"
                        disabled="@string.IsNullOrWhiteSpace(excludeReason)"
                        @onclick="ConfirmExcludeAsync">Confirm Exclude</button>
            </div>
        </div>
    </div>
}

@if (specialtyModalOpen)
{
    <div style="position:fixed; inset:0; background:rgba(0,0,0,0.5); display:flex; align-items:center; justify-content:center; z-index:1000;" @onclick="CloseSpecialtyEditor">
        <div style="background:white; padding:1.5rem; border-radius:8px; max-width:500px; width:90%;" @onclick:stopPropagation>
            <h3 style="margin-top:0;">Specialties — @specialtyTargetName</h3>
            <p style="color:#475569;">Pick one or more specialties. Save commits the selection.</p>
            @if (specialtyCatalog.Where(s => s.IsActive).Any())
            {
                @foreach (var sp in specialtyCatalog.Where(s => s.IsActive).OrderBy(s => s.SortOrder).ThenBy(s => s.SpecialtyName))
                {
                    <label style="display:block; padding:.4rem 0;">
                        <input type="checkbox"
                               checked="@workingSpecialtyIds.Contains(sp.SpecialtyId)"
                               @onchange="(e) => ToggleSpecialty(sp.SpecialtyId, (bool?)e.Value == true)" />
                        <strong>@sp.SpecialtyName</strong>
                        @if (!string.IsNullOrWhiteSpace(sp.Description))
                        {
                            <span style="color:#64748b; font-size:.85rem;"> — @sp.Description</span>
                        }
                    </label>
                }
            }
            else
            {
                <p style="color:#b45309;">No active specialties in the catalog. Run migration 046 to seed Reception + Admin.</p>
            }
            <div style="margin-top:1rem; display:flex; justify-content:flex-end; gap:.5rem;">
                <button type="button" style="padding:.5rem 1rem; background:#e5e7eb; border:none; border-radius:4px; cursor:pointer;" @onclick="CloseSpecialtyEditor">Cancel</button>
                <button type="button" style="padding:.5rem 1rem; background:#1e40af; color:white; border:none; border-radius:4px; cursor:pointer;" @onclick="ConfirmSpecialtyAsync">Save</button>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private string currentUserEmail = "";

    // Split pools — SubRole='ADMIN_SUB' lands in activeAdminSubs; everything
    // else (NULL / TEACHER_SUB) lands in activeTeacherSubs. Both tables render
    // independently so teacher and admin pools can be managed side by side
    // without cross-contamination (e.g. specialty chips only make sense on
    // the admin pool and the admin-group diagnostic column is noise on the
    // teacher table).
    private List<TcEmployee> activeTeacherSubs = new();
    private List<TcEmployee> activeAdminSubs = new();
    private List<TcEmployee> excludedSubs = new();
    private List<TcSubSpecialty> specialtyCatalog = new();
    private Dictionary<int, HashSet<int>> currentAssignmentsByEmployee = new();

    // SubstituteAdmin Entra group membership, fetched once on load. See
    // RefreshAdminGroupMembersAsync. Used to render the Admin Group column
    // on the admin table.
    private bool adminGroupConfigured = false;
    private HashSet<string> adminGroupMemberObjectIds = new(StringComparer.OrdinalIgnoreCase);
    private int adminGroupMemberCount = 0;
    private string? adminGroupFetchError = null;

    // Exclude modal state
    private bool excludeModalOpen = false;
    private int? excludeTargetEmployeeId = null;
    private string excludeTargetName = "";
    private string excludeReason = "";

    // Specialty editor modal state
    private bool specialtyModalOpen = false;
    private int? specialtyTargetEmployeeId = null;
    private string specialtyTargetName = "";
    private HashSet<int> workingSpecialtyIds = new();

    /// <summary>
    /// Combined view used by modal openers (OpenExcludeModal /
    /// OpenSpecialtyEditor) that take an EmployeeId and must find it
    /// regardless of whether the sub is currently rendered in the teacher
    /// or admin table.
    /// </summary>
    private IEnumerable<TcEmployee> AllActiveSubs => activeTeacherSubs.Concat(activeAdminSubs);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUserEmail = authState.User.FindFirst("preferred_username")?.Value
                        ?? authState.User.FindFirst(ClaimTypes.Email)?.Value
                        ?? "";
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        try
        {
            using var ctx = await DbFactory.CreateDbContextAsync();

            // Teacher pool: EmployeeType=Substitute without ADMIN_SUB tag.
            // These are the traditional sub pool members synced from the main
            // Substitute Entra group. NULL SubRole counts as teacher pool
            // (legacy default for Substitute-typed employees).
            var teacherPool = await ctx.TcEmployees
                .AsNoTracking()
                .Include(e => e.Staff)
                .Where(e => e.EmployeeType == EmployeeType.Substitute
                         && e.IsActive
                         && (e.SubRole == null || e.SubRole != "ADMIN_SUB"))
                .OrderBy(e => e.Staff!.LastName)
                .ThenBy(e => e.Staff!.FirstName)
                .ToListAsync();

            // Admin pool: anyone (any EmployeeType) tagged SubRole='ADMIN_SUB'.
            // This captures Substitutes who are also in the admin group AND
            // non-Substitutes (HourlyPartTime receptionists, SalariedStaff
            // admins, etc.) who are willing to cover admin-sub shifts.
            var adminPool = await ctx.TcEmployees
                .AsNoTracking()
                .Include(e => e.Staff)
                .Where(e => e.IsActive && e.SubRole == "ADMIN_SUB")
                .OrderBy(e => e.Staff!.LastName)
                .ThenBy(e => e.Staff!.FirstName)
                .ToListAsync();

            activeTeacherSubs = teacherPool.Where(s => !s.ExcludedFromSubPool).ToList();
            activeAdminSubs   = adminPool.Where(s => !s.ExcludedFromSubPool).ToList();
            excludedSubs      = teacherPool.Concat(adminPool).Where(s => s.ExcludedFromSubPool).ToList();

            specialtyCatalog = await ctx.TcSubSpecialties
                .AsNoTracking()
                .OrderBy(s => s.SortOrder).ThenBy(s => s.SpecialtyName)
                .ToListAsync();

            // Specialties UI only renders on admin-pool rows; but we fetch
            // for both pools in case a teacher sub has stale assignments —
            // they'll just be hidden by the UI's isAdminSub guard.
            var subIds = teacherPool.Concat(adminPool).Select(s => s.EmployeeId).ToList();
            currentAssignmentsByEmployee = (await ctx.TcSubSpecialtyAssignments
                .AsNoTracking()
                .Where(a => subIds.Contains(a.EmployeeId))
                .ToListAsync())
                .GroupBy(a => a.EmployeeId)
                .ToDictionary(g => g.Key, g => g.Select(a => a.SpecialtyId).ToHashSet());

            await RefreshAdminGroupMembersAsync();
        }
        finally
        {
            isLoading = false;
        }
    }

    /// <summary>
    /// Fetches transitive members of the SubstituteAdmin Entra group once per
    /// page load so the Admin Subs table can show which rows are in the group.
    /// Swallows exceptions into <c>adminGroupFetchError</c> so Graph outages
    /// don't break the whole page — manual Set/Unset Admin Sub buttons still
    /// work without the column.
    /// </summary>
    private async Task RefreshAdminGroupMembersAsync()
    {
        adminGroupConfigured = false;
        adminGroupMemberObjectIds = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        adminGroupMemberCount = 0;
        adminGroupFetchError = null;

        const string configKey = "GraphSync:EmployeeGroupIds:SubstituteAdmin";
        var adminGroupId = Config[configKey];
        if (string.IsNullOrWhiteSpace(adminGroupId))
        {
            return;
        }

        adminGroupConfigured = true;
        try
        {
            var members = await Graph.GetTransitiveMembersAsync(adminGroupId);
            adminGroupMemberObjectIds = members
                .Select(m => m.ObjectId)
                .Where(id => !string.IsNullOrWhiteSpace(id))
                .ToHashSet(StringComparer.OrdinalIgnoreCase);
            adminGroupMemberCount = adminGroupMemberObjectIds.Count;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to fetch SubstituteAdmin transitive members on SubPoolManagement page load");
            adminGroupFetchError = ex.Message;
        }
    }

    // ── Exclusion ────────────────────────────────────────────────────

    private void OpenExcludeModal(int employeeId)
    {
        var s = AllActiveSubs.FirstOrDefault(x => x.EmployeeId == employeeId);
        if (s == null) return;
        excludeTargetEmployeeId = employeeId;
        excludeTargetName = s.Staff?.FullName ?? s.DisplayName ?? s.Email ?? $"Employee {employeeId}";
        excludeReason = "";
        excludeModalOpen = true;
    }

    private void CloseExcludeModal()
    {
        excludeModalOpen = false;
        excludeTargetEmployeeId = null;
        excludeReason = "";
    }

    private async Task ConfirmExcludeAsync()
    {
        if (!excludeTargetEmployeeId.HasValue || string.IsNullOrWhiteSpace(excludeReason)) return;
        try
        {
            using var ctx = await DbFactory.CreateDbContextAsync();
            var sub = await ctx.TcEmployees.FindAsync(excludeTargetEmployeeId.Value);
            if (sub == null) { CloseExcludeModal(); return; }

            sub.ExcludedFromSubPool = true;
            sub.ExcludedFromSubPoolBy = currentUserEmail;
            sub.ExcludedFromSubPoolDate = DateTime.Now;
            sub.ExcludedFromSubPoolReason = excludeReason.Trim();
            sub.ModifiedDate = DateTime.Now;
            await ctx.SaveChangesAsync();

            await Audit.LogActionAsync(
                actionCode: AuditActions.SubPool.Excluded,
                entityType: AuditEntityTypes.Employee,
                entityId: sub.EmployeeId.ToString(),
                newValues: new
                {
                    sub.EmployeeId,
                    ExcludedBy = sub.ExcludedFromSubPoolBy,
                    sub.ExcludedFromSubPoolDate,
                    sub.ExcludedFromSubPoolReason
                },
                reason: sub.ExcludedFromSubPoolReason,
                deltaSummary: $"Sub {excludeTargetName} excluded from outreach pool by {currentUserEmail}: {sub.ExcludedFromSubPoolReason}",
                source: AuditSource.AdminUi,
                employeeId: sub.EmployeeId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error excluding sub {EmployeeId}", excludeTargetEmployeeId);
        }
        finally
        {
            CloseExcludeModal();
            await LoadAsync();
        }
    }

    private async Task RestoreSubAsync(int employeeId)
    {
        try
        {
            using var ctx = await DbFactory.CreateDbContextAsync();
            var sub = await ctx.TcEmployees.FindAsync(employeeId);
            if (sub == null) return;

            var name = sub.DisplayName ?? sub.Email ?? $"Employee {employeeId}";
            sub.ExcludedFromSubPool = false;
            sub.ExcludedFromSubPoolBy = null;
            sub.ExcludedFromSubPoolDate = null;
            sub.ExcludedFromSubPoolReason = null;
            sub.ModifiedDate = DateTime.Now;
            await ctx.SaveChangesAsync();

            await Audit.LogActionAsync(
                actionCode: AuditActions.SubPool.Restored,
                entityType: AuditEntityTypes.Employee,
                entityId: sub.EmployeeId.ToString(),
                newValues: new { sub.EmployeeId, RestoredBy = currentUserEmail },
                deltaSummary: $"Sub {name} restored to outreach pool by {currentUserEmail}",
                source: AuditSource.AdminUi,
                employeeId: sub.EmployeeId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error restoring sub {EmployeeId}", employeeId);
        }
        finally
        {
            await LoadAsync();
        }
    }

    // ── Manual SubRole override ──────────────────────────────────────
    //
    // The Entra overlay (EmployeeSyncService.ApplyAdminSubOverlayAsync)
    // normally flips SubRole automatically from Entra group membership.
    // These two methods let a supervisor do it by hand when:
    //  - The SubstituteAdmin group ID hasn't been configured yet
    //  - Graph returned 0 members (permission / consent / group-ID issue)
    //  - Patrick wants to pre-promote someone before the next sync runs
    //  - An overlay-driven flip needs to be unwound without waiting for
    //    the next sync to remove the user from the Entra group.
    //
    // Note: the next sync WILL re-assert whatever Entra says. A manual
    // flip isn't sticky across syncs unless the Entra group is also updated.

    private async Task ManualSetAdminSubAsync(int employeeId)
    {
        await SetRoleCoreAsync(employeeId, newRole: "ADMIN_SUB");
    }

    private async Task ManualUnsetAdminSubAsync(int employeeId)
    {
        // Clears the ADMIN_SUB tag. NULL is interpreted as legacy-TEACHER_SUB
        // for Substitute-typed employees and "not a sub at all" for non-subs.
        await SetRoleCoreAsync(employeeId, newRole: null);
    }

    private async Task SetRoleCoreAsync(int employeeId, string? newRole)
    {
        try
        {
            using var ctx = await DbFactory.CreateDbContextAsync();
            var sub = await ctx.TcEmployees.FindAsync(employeeId);
            if (sub == null) return;

            // No-op guard — don't write an audit row if nothing actually changed.
            if (string.Equals(sub.SubRole, newRole, StringComparison.OrdinalIgnoreCase))
                return;

            var oldRole = sub.SubRole;
            sub.SubRole = newRole;
            sub.ModifiedDate = DateTime.Now;
            await ctx.SaveChangesAsync();

            var name = sub.Staff?.FullName ?? sub.DisplayName ?? sub.Email ?? $"Employee {employeeId}";
            var actionCode = newRole == "ADMIN_SUB"
                ? AuditActions.SubPool.RoleManualSet
                : AuditActions.SubPool.RoleManualUnset;
            var summary = newRole == "ADMIN_SUB"
                ? $"Manually set {name} SubRole to ADMIN_SUB (was {oldRole ?? "NULL"}) by {currentUserEmail}"
                : $"Manually cleared {name} ADMIN_SUB tag (was {oldRole ?? "NULL"}) by {currentUserEmail}";

            await Audit.LogActionAsync(
                actionCode: actionCode,
                entityType: AuditEntityTypes.Employee,
                entityId: sub.EmployeeId.ToString(),
                oldValues: new { sub.EmployeeId, OldSubRole = oldRole },
                newValues: new { sub.EmployeeId, NewSubRole = newRole, ChangedBy = currentUserEmail },
                deltaSummary: summary,
                source: AuditSource.AdminUi,
                employeeId: sub.EmployeeId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Manual SubRole flip failed for employee {EmployeeId} -> {Role}", employeeId, newRole ?? "NULL");
        }
        finally
        {
            await LoadAsync();
        }
    }

    // ── Specialty editor ─────────────────────────────────────────────

    private void OpenSpecialtyEditor(int employeeId)
    {
        var s = AllActiveSubs.FirstOrDefault(x => x.EmployeeId == employeeId);
        if (s == null) return;
        specialtyTargetEmployeeId = employeeId;
        specialtyTargetName = s.Staff?.FullName ?? s.DisplayName ?? s.Email ?? $"Employee {employeeId}";
        workingSpecialtyIds = currentAssignmentsByEmployee.GetValueOrDefault(employeeId, new()).ToHashSet();
        specialtyModalOpen = true;
    }

    private void CloseSpecialtyEditor()
    {
        specialtyModalOpen = false;
        specialtyTargetEmployeeId = null;
        workingSpecialtyIds = new();
    }

    private void ToggleSpecialty(int specialtyId, bool isChecked)
    {
        if (isChecked) workingSpecialtyIds.Add(specialtyId);
        else workingSpecialtyIds.Remove(specialtyId);
    }

    private async Task ConfirmSpecialtyAsync()
    {
        if (!specialtyTargetEmployeeId.HasValue) return;
        try
        {
            using var ctx = await DbFactory.CreateDbContextAsync();
            var existing = await ctx.TcSubSpecialtyAssignments
                .Where(a => a.EmployeeId == specialtyTargetEmployeeId.Value)
                .ToListAsync();

            var existingIds = existing.Select(a => a.SpecialtyId).ToHashSet();
            var added   = workingSpecialtyIds.Except(existingIds).ToList();
            var removed = existingIds.Except(workingSpecialtyIds).ToList();

            // Remove unchecked ones.
            foreach (var rem in existing.Where(a => removed.Contains(a.SpecialtyId)))
                ctx.TcSubSpecialtyAssignments.Remove(rem);

            // Add newly checked ones.
            foreach (var addId in added)
                ctx.TcSubSpecialtyAssignments.Add(new TcSubSpecialtyAssignment
                {
                    EmployeeId = specialtyTargetEmployeeId.Value,
                    SpecialtyId = addId,
                    AssignedBy = currentUserEmail,
                    AssignedDate = DateTime.Now
                });

            await ctx.SaveChangesAsync();

            // Audit one row per change so individual assignments are filterable.
            foreach (var addId in added)
            {
                var name = specialtyCatalog.FirstOrDefault(x => x.SpecialtyId == addId)?.SpecialtyName ?? "?";
                await Audit.LogActionAsync(
                    actionCode: AuditActions.SubPool.SpecialtyAssigned,
                    entityType: AuditEntityTypes.Employee,
                    entityId: specialtyTargetEmployeeId.Value.ToString(),
                    newValues: new { EmployeeId = specialtyTargetEmployeeId.Value, SpecialtyId = addId, SpecialtyName = name },
                    deltaSummary: $"Specialty '{name}' assigned to {specialtyTargetName} by {currentUserEmail}",
                    source: AuditSource.AdminUi,
                    employeeId: specialtyTargetEmployeeId.Value);
            }
            foreach (var remId in removed)
            {
                var name = specialtyCatalog.FirstOrDefault(x => x.SpecialtyId == remId)?.SpecialtyName ?? "?";
                await Audit.LogActionAsync(
                    actionCode: AuditActions.SubPool.SpecialtyUnassigned,
                    entityType: AuditEntityTypes.Employee,
                    entityId: specialtyTargetEmployeeId.Value.ToString(),
                    newValues: new { EmployeeId = specialtyTargetEmployeeId.Value, SpecialtyId = remId, SpecialtyName = name },
                    deltaSummary: $"Specialty '{name}' removed from {specialtyTargetName} by {currentUserEmail}",
                    source: AuditSource.AdminUi,
                    employeeId: specialtyTargetEmployeeId.Value);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving specialties for {EmployeeId}", specialtyTargetEmployeeId);
        }
        finally
        {
            CloseSpecialtyEditor();
            await LoadAsync();
        }
    }
}
