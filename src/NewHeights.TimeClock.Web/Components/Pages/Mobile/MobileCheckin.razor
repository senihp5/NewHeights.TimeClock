@page "/mobile/checkin"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@layout KioskLayout
@rendermode InteractiveServer
@attribute [Authorize]
@using NewHeights.TimeClock.Web.Services
@using NewHeights.TimeClock.Data
@using NewHeights.TimeClock.Data.Entities
@using NewHeights.TimeClock.Shared.Audit
@using NewHeights.TimeClock.Shared.Constants
@using NewHeights.TimeClock.Shared.DTOs
@using NewHeights.TimeClock.Shared.Enums
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@inject IGeofenceService GeofenceService
@inject IDbContextFactory<TimeClockDbContext> DbFactory
@inject ITimePunchService TimePunchService
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@inject ILogger<MobileCheckin> Logger

<div class="kiosk-container mobile-clock-container">
    <header class="mobile-header">
        <div class="user-info" style="color: white;"><span>@userName</span></div>
        <div class="current-time" style="font-size: 1.5rem; color: white; font-weight: 600;">@currentTime.ToString("h:mm tt")</div>
    </header>

    @if (showResult)
    {
        <div class="scan-area">
            <div class="result-display @resultClass">
                @if (!string.IsNullOrEmpty(photoBase64))
                {
                    <img src="@photoSrc" alt="Photo" class="employee-photo" />
                }
                <div class="result-message">
                    <h3>@resultMessage</h3>
                    @if (!string.IsNullOrEmpty(lastCheckType))
                    {
                        <span class="punch-type-badge @punchBadgeClass">@punchBadgeText</span>
                    }
                    <p style="margin-top: 8px; opacity: 0.8; font-size: 0.95rem;">@userName</p>
                    <p style="margin-top: 4px; opacity: 0.7; font-size: 0.85rem;">@nearestCampusName</p>
                    @if (!string.IsNullOrEmpty(payrollWarning))
                    {
                        <div style="margin-top: 12px; padding: 10px 14px; background: #fff3cd; color: #856404; border: 1px solid #ffeeba; border-radius: 8px; font-size: 0.9rem; text-align: left;">
                            <strong>Heads up:</strong> @payrollWarning
                        </div>
                    }
                </div>
            </div>
        </div>
        <div style="text-align: center; padding: 20px;">
            <button class="btn btn-primary" @onclick="ResetForNext">Done</button>
        </div>
    }
    else
    {
        <div class="location-status @locationStatusClass">
            @if (isCheckingLocation)
            {
                <div class="spinner"></div>
                <span>Checking your location...</span>
            }
            else if (locationVerified)
            {
                @if (adminOverrideApplied)
                {
                    <span style="color: #ffd54f;">@nearestCampusName <span style="font-size:.8em; opacity:.9;">(admin override)</span></span>
                }
                else
                {
                    <span>@nearestCampusName</span>
                }
            }
            else
            {
                <span style="font-size: 0.9rem;">@locationErrorMessage</span>
            }
        </div>

        @if (!locationVerified && !isCheckingLocation && !string.IsNullOrEmpty(locationErrorMessage))
        {
            <div style="text-align: center; padding: 20px;">
                <p style="color: #ff6b6b; margin-bottom: 15px;">@locationErrorMessage</p>
                <button class="btn btn-primary" @onclick="CheckLocation">Try Again</button>
                <p style="color: rgba(255,255,255,0.7); margin-top: 15px;">You must be on campus to check in/out</p>

                @if (isAdmin)
                {
                    @* Admin-only: desktop browsers return wildly inaccurate
                       geolocation (IP / WiFi fix can be off by kilometers —
                       54m is actually close). This lets admins test the
                       mobile-checkin flow from a desktop without being on
                       campus. Audit logs flag the override so it's obvious
                       later if someone abuses it. *@
                    <div style="margin-top: 24px; padding: 14px 16px; background: rgba(255, 193, 7, 0.12); border: 1px solid rgba(255, 193, 7, 0.45); border-radius: 10px; color: #ffd54f; text-align: left;">
                        <div style="font-weight: 700; margin-bottom: 6px;">⚠️ Admin Testing Override</div>
                        <p style="margin: 0 0 10px; font-size: 0.88rem; color: rgba(255,255,255,0.85); line-height: 1.45;">
                            Desktop browsers use IP/WiFi for geolocation and are often inaccurate.
                            Real devices use GPS and will work correctly on campus. Use this to test
                            the check-in flow without being physically on site.
                        </p>
                        <button class="btn btn-primary" style="background: #f5b81c; color: #1e3a5f; font-weight: 700;"
                                @onclick="ApplyAdminOverride">
                            Force Check-In (Admin)
                        </button>
                    </div>
                }
            </div>
        }
        else if (locationVerified)
        {
            <div style="text-align: center; padding: 40px 20px;">
                @if (!string.IsNullOrEmpty(photoBase64))
                {
                    <img src="@photoSrc" alt="" style="width: 150px; height: 150px; border-radius: 50%; object-fit: cover; border: 4px solid white; margin-bottom: 20px;" />
                }
                <h2 style="color: white; margin-bottom: 10px;">@userName</h2>
                <p style="color: rgba(255,255,255,0.7); margin-bottom: 30px;">@currentStatus</p>
                @if (isProcessing)
                {
                    <div class="spinner" style="margin: 20px auto;"></div>
                }
                else
                {
                    <button class="btn @actionButtonClass" style="padding: 20px 60px; font-size: 1.5rem; border-radius: 12px;" @onclick="ProcessCheckin">
                        @actionButtonText
                    </button>
                }
            </div>
        }
    }
    <footer class="kiosk-footer"><p>Campus Check-In</p></footer>
</div>

@if (showEarlyOutModal)
{
    <div class="early-out-overlay" @onclick="() => SubmitEarlyOut(null)">
        <div class="early-out-modal" @onclick:stopPropagation>
            <h2>Leaving Early?</h2>
            <p class="early-out-name">@earlyOutPersonName</p>
            <div class="early-out-reasons">
                @foreach (var reason in EarlyOutReasons)
                {
                    <button class="early-out-reason-btn @(selectedEarlyOutReason == reason.Code? "selected" : "")"
                            @onclick="() => SelectEarlyOutReason(reason.Code)">
                        @reason.Label
                    </button>
                }
            </div>
            <p class="early-out-countdown">
                Auto-submitting in <strong>@earlyOutCountdown</strong>s
                @if (!string.IsNullOrEmpty(selectedEarlyOutReason))
                {
                    <span> with selected reason</span>
                }
                else
                {
                    <span> with no reason</span>
                }
            </p>
            <div class="early-out-actions">
                <button class="early-out-skip" @onclick="() => SubmitEarlyOut(null)">Skip</button>
                <button class="early-out-confirm"
                        disabled="@string.IsNullOrEmpty(selectedEarlyOutReason)"
                        @onclick="() => SubmitEarlyOut(selectedEarlyOutReason)">
                    Confirm Reason
                </button>
            </div>
        </div>
    </div>
}
@code {
    private System.Timers.Timer? clockTimer;
    private DateTime currentTime = DateTime.Now;
    private string userName = "";

    // Admin-testing override. Lets admin users bypass the geofence when
    // testing from a desktop browser, where IP-based geolocation is
    // wildly inaccurate. Never auto-applied — the admin has to click the
    // override button explicitly, and the click is audited.
    private bool isAdmin = false;
    private bool adminOverrideApplied = false;
    private string? staffIdNumber;

    // Identity fallback for substitutes and manually-added test employees
    // who don't have PowerSchool Staff rows. See LoadStaffInfo — when the
    // Staff lookup misses, we fall back to TcEmployees via EntraObjectId
    // (stable) or Email (string-match) to resolve the IdNumber used by
    // downstream punch + AttendanceTransactions code paths.
    private string currentUserEmail = "";
    private string currentUserEntraOid = "";
    private string? staffFirstName;
    private string? staffLastName;
    private string photoBase64 = "";

    // Location
    private bool isCheckingLocation = true;
    private bool locationVerified = false;
    private string locationErrorMessage = "";
    private string locationStatusClass = "checking";
    private int? nearestCampusId;
    private string nearestCampusName = "";

    // Migration 039: persisted onto AttendanceTransaction.Latitude/Longitude
    // for audit proof of the geofence validation.
    private double? latestLatitude;
    private double? latestLongitude;
    private double? latestAccuracyMeters;

    // Result
    private bool showResult = false;
    private bool isSuccess = false;
    private bool isProcessing = false;
    private string resultMessage = "";
    private string lastCheckType = "";

    // Payroll-side soft warning. AttendanceTransaction always commits
    // (safety-first); if the TcTimePunch write fails we surface this text so
    // the hourly user knows to correct on /my/timesheet without blocking
    // the safety-presence confirmation.
    private string payrollWarning = "";

    // Status + action button
    private string currentStatus = "Loading...";
    private bool nextActionIsCheckIn = true;

    // Early-out modal state
    private bool showEarlyOutModal = false;
    private string? selectedEarlyOutReason;
    private int earlyOutCountdown = 10;
    private System.Timers.Timer? earlyOutTimer;
    private TaskCompletionSource<string?>? earlyOutTcs;
    private string earlyOutPersonName = string.Empty;
    private static readonly (string Code, string Label)[] EarlyOutReasons =
    {
        ("LUNCH",     "Lunch / Meal Break"),
        ("MEDICAL",   "Medical / Appt"),
        ("MEETING",   "Meeting / Prof. Dev"),
        ("PERSONAL",  "Personal / Family"),
        ("EMERGENCY", "Campus Emergency"),
    };

    private string photoSrc => "data:image/jpeg;base64," + photoBase64;
    private string resultClass => isSuccess ? "success" : "error";
    private string punchBadgeClass => lastCheckType == "IN" ? "in" : "out";
    private string punchBadgeText => string.IsNullOrEmpty(lastCheckType) ? "" : (lastCheckType == "IN" ? "CHECKED IN" : "CHECKED OUT");
    private string actionButtonClass => nextActionIsCheckIn ? "btn-success" : "btn-warning";
    private string actionButtonText => nextActionIsCheckIn ? "CHECK IN" : "CHECK OUT";

    protected override async Task OnInitializedAsync()
    {
        clockTimer = new System.Timers.Timer(1000);
        clockTimer.Elapsed += OnClockTick;
        clockTimer.Start();

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            userName = user.FindFirst("name")?.Value ?? user.Identity.Name ?? "User";
            staffIdNumber = user.FindFirst("employeeid")?.Value ?? user.FindFirst("employee_id")?.Value;
            currentUserEmail = user.FindFirst("preferred_username")?.Value
                            ?? user.FindFirst(ClaimTypes.Email)?.Value
                            ?? "";
            currentUserEntraOid = user.FindFirst("oid")?.Value
                               ?? user.FindFirst("http://schemas.microsoft.com/identity/claims/objectidentifier")?.Value
                               ?? "";
            var parts = userName.Split(' ', 2);
            staffFirstName = parts.Length > 0 ? parts[0] : "";
            staffLastName = parts.Length > 1 ? parts[1] : "";
            isAdmin = user.IsInRole(AppConstants.Roles.Admin);
        }
    }

    /// <summary>
    /// Admin-only escape hatch for desktop testing. When the geofence check
    /// fails and the signed-in user is a TimeClock.Admin, they can click
    /// Force Check-In to skip the location guard. Falls through to the
    /// nearest campus (which was already resolved before the check failed)
    /// so subsequent punch flow has a CampusId. Writes a warning log +
    /// audit row so the bypass is visible in compliance reports.
    /// </summary>
    private async Task ApplyAdminOverride()
    {
        if (!isAdmin) return;

        // Use the campus we resolved earlier as the "nearest" before the
        // check failed. If we couldn't even resolve one, block — there's
        // no campus to attribute the punch to.
        if (nearestCampusId == 0)
        {
            var fallbackCampus = await GeofenceService.GetNearestCampusAsync(
                latestLatitude ?? 0, latestLongitude ?? 0);
            if (fallbackCampus == null)
            {
                locationErrorMessage = "Admin override failed — no campus could be resolved. Location services may be off.";
                return;
            }
            nearestCampusId = fallbackCampus.CampusId;
            nearestCampusName = fallbackCampus.CampusName;
        }

        locationVerified = true;
        locationStatusClass = "verified";
        adminOverrideApplied = true;
        Logger.LogWarning(
            "Geofence admin override applied by {User} for campus {Campus}. Reported position: ({Lat}, {Lon}).",
            userName, nearestCampusName, latestLatitude, latestLongitude);

        await LoadStaffInfo();
        await LoadCurrentStatus();
        StateHasChanged();
    }

    private void OnClockTick(object? sender, System.Timers.ElapsedEventArgs e)
    {
        currentTime = DateTime.Now;
        try { InvokeAsync(StateHasChanged); } catch { }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CheckLocation();
        }
    }

    private async Task CheckLocation()
    {
        isCheckingLocation = true;
        locationStatusClass = "checking";
        locationVerified = false;
        locationErrorMessage = "";
        StateHasChanged();
        try
        {
            var position = await JS.InvokeAsync<LocResult>("kioskInterop.getPosition");
            if (position != null)
            {
                latestLatitude = position.Latitude;
                latestLongitude = position.Longitude;
                latestAccuracyMeters = position.Accuracy > 0 ? position.Accuracy : null;

                var nearestCampus = await GeofenceService.GetNearestCampusAsync(position.Latitude, position.Longitude);
                if (nearestCampus != null)
                {
                    var result = await GeofenceService.ValidateLocationAsync(nearestCampus.CampusId, position.Latitude, position.Longitude);
                    if (result.IsValid)
                    {
                        locationVerified = true;
                        locationStatusClass = "verified";
                        nearestCampusId = nearestCampus.CampusId;
                        nearestCampusName = nearestCampus.CampusName;

                        await LoadStaffInfo();
                        await LoadCurrentStatus();
                    }
                    else
                    {
                        locationStatusClass = "error";
                        locationErrorMessage = result.Message ?? "Too far from campus";
                    }
                }
                else
                {
                    locationStatusClass = "error";
                    locationErrorMessage = "No campuses configured";
                }
            }
            else
            {
                locationStatusClass = "error";
                locationErrorMessage = "Could not get GPS position";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "CheckLocation error");
            locationStatusClass = "error";
            var msg = ex.Message ?? ex.ToString();
            if (msg.Contains("denied") || msg.Contains("GEO_ERROR_1"))
                locationErrorMessage = "Location permission denied - check browser settings";
            else if (msg.Contains("unavailable") || msg.Contains("GEO_ERROR_2"))
                locationErrorMessage = "Location unavailable - " + msg;
            else if (msg.Contains("timeout") || msg.Contains("GEO_ERROR_3"))
                locationErrorMessage = "Location timed out - " + msg;
            else
                locationErrorMessage = "Location error: " + msg;
        }
        finally
        {
            isCheckingLocation = false;
            StateHasChanged();
        }
    }

    private async Task LoadStaffInfo()
    {
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            Staff? staff = null;
            if (!string.IsNullOrEmpty(staffIdNumber))
                staff = await context.Staff.AsNoTracking().Where(s => s.IdNumber == staffIdNumber).FirstOrDefaultAsync();
            if (staff == null && !string.IsNullOrEmpty(staffFirstName))
                staff = await context.Staff.AsNoTracking().Where(s => s.FirstName == staffFirstName && s.LastName == staffLastName).FirstOrDefaultAsync();

            if (staff != null)
            {
                staffIdNumber = staff.IdNumber;
                staffFirstName = staff.FirstName;
                staffLastName = staff.LastName;
                userName = staff.FirstName + " " + staff.LastName;
                if (staff.Dcid > 0)
                {
                    var photo = await context.Photos.AsNoTracking()
                        .Where(p => p.SubjectDcid == staff.Dcid && p.SubjectType == 1)
                        .FirstOrDefaultAsync();
                    if (photo?.PhotoData != null) photoBase64 = Convert.ToBase64String(photo.PhotoData);
                }
                return;
            }

            // PowerSchool Staff lookup missed. This is the normal case for
            // substitutes and for employees added via /admin/employees/add —
            // they live in TC_Employees with no StaffDcid link. Resolve by
            // EntraObjectId (stable across renames) then by email. Populate
            // staffIdNumber from TcEmployees.IdNumber (SUB-NNNN for synced
            // subs, MANUAL-NNNN for admin-form adds) so downstream punch
            // creation + AttendanceTransactions queries use the right key.
            TcEmployee? employee = null;
            if (!string.IsNullOrWhiteSpace(currentUserEntraOid))
            {
                employee = await context.TcEmployees
                    .AsNoTracking()
                    .FirstOrDefaultAsync(e => e.EntraObjectId == currentUserEntraOid && e.IsActive);
            }
            if (employee == null && !string.IsNullOrWhiteSpace(currentUserEmail))
            {
                var lower = currentUserEmail.Trim().ToLower();
                employee = await context.TcEmployees
                    .AsNoTracking()
                    .FirstOrDefaultAsync(e => e.Email != null && e.Email.ToLower() == lower && e.IsActive);
            }

            if (employee != null)
            {
                staffIdNumber = employee.IdNumber;
                if (!string.IsNullOrWhiteSpace(employee.DisplayName))
                {
                    userName = employee.DisplayName;
                    var nameParts = employee.DisplayName.Split(' ', 2);
                    if (nameParts.Length > 0 && string.IsNullOrWhiteSpace(staffFirstName))
                        staffFirstName = nameParts[0];
                    if (nameParts.Length > 1 && string.IsNullOrWhiteSpace(staffLastName))
                        staffLastName = nameParts[1];
                }
                // Photo: no PowerSchool link so we skip the Photos table
                // lookup. UI will render a blank avatar area which is fine
                // for subs and test accounts.
            }
        }
        catch (Exception ex) { Logger.LogError(ex, "Error loading staff info"); }
    }

    private async Task LoadCurrentStatus()
    {
        if (string.IsNullOrEmpty(staffIdNumber))
        {
            currentStatus = "Staff record not found";
            return;
        }
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            var today = DateTime.Today;
            var lastTrans = await context.AttendanceTransactions.AsNoTracking()
                .Where(t => t.IdNumber == staffIdNumber && t.ScanDateTime.Date == today)
                .OrderByDescending(t => t.ScanDateTime).FirstOrDefaultAsync();

            if (lastTrans == null)
            {
                currentStatus = "Not checked in today";
                nextActionIsCheckIn = true;
            }
            else if (lastTrans.ScanType == "CAMPUS_IN" || lastTrans.ScanType == "LUNCH_IN")
            {
                currentStatus = "Checked in at " + lastTrans.ScanDateTime.ToString("h:mm tt");
                nextActionIsCheckIn = false;
            }
            else
            {
                currentStatus = "Currently checked out";
                nextActionIsCheckIn = true;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading status");
            currentStatus = "Error loading status";
        }
    }

    private async Task ProcessCheckin()
    {
        if (string.IsNullOrEmpty(staffIdNumber) || nearestCampusId == null)
        {
            resultMessage = "Unable to process - staff not found";
            isSuccess = false;
            showResult = true;
            return;
        }
        isProcessing = true;
        StateHasChanged();
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            var scanType = nextActionIsCheckIn ? "CAMPUS_IN" : "CAMPUS_OUT";

            // Look up shift + type so (a) the early-out check only fires for the
            // employee's session and (b) we know whether to dual-write a TcTimePunch
            // row for hourly / PT / sub employees after the AttendanceTransaction.
            var signedInEmployee = await context.TcEmployees.AsNoTracking()
                .Where(e => e.IsActive && e.IdNumber == staffIdNumber)
                .Select(e => new { e.Shift, e.EmployeeType })
                .FirstOrDefaultAsync();
            var signedInShift = signedInEmployee?.Shift ?? EmployeeShift.Day;
            var signedInType = signedInEmployee?.EmployeeType;
            bool needsTimePunch = signedInType == EmployeeType.HourlyStaff
                               || signedInType == EmployeeType.HourlyPartTime
                               || signedInType == EmployeeType.Substitute;

            string? earlyOutReason = null;
            if (!nextActionIsCheckIn && nearestCampusId.HasValue)
            {
                if (await ShouldPromptEarlyOut(context, nearestCampusId.Value, signedInShift))
                {
                    earlyOutPersonName = staffFirstName + " " + staffLastName;
                    earlyOutReason = await ShowEarlyOutPrompt();
                }
            }
            var transaction = new AttendanceTransaction
            {
                TransactionType = "STAFF",
                IdNumber = staffIdNumber,
                FirstName = staffFirstName ?? "",
                LastName = staffLastName ?? "",
                CampusId = nearestCampusId.Value,
                LocationId = 1,
                ScanDateTime = DateTime.Now,
                ScanType = scanType,
                ScanMethod = "GPS_MOBILE",
                TerminalId = 0,
                DataSource = "LOCAL",
                ValidationStatus = "VALID",
                PunchSubType = earlyOutReason,
                // Migration 039: GPS proof of the geofence validation.
                Latitude = latestLatitude.HasValue ? (decimal?)Convert.ToDecimal(latestLatitude.Value) : null,
                Longitude = latestLongitude.HasValue ? (decimal?)Convert.ToDecimal(latestLongitude.Value) : null,
                LocationAccuracyMeters = latestAccuracyMeters.HasValue ? (decimal?)Convert.ToDecimal(latestAccuracyMeters.Value) : null,
                CreatedDate = DateTime.Now
            };
            context.AttendanceTransactions.Add(transaction);
            await context.SaveChangesAsync();

            // Dual-write for hourly / PT / sub employees: mirror the check-in
            // to TC_TimePunches via TimePunchService so payroll sees the same
            // event the safety system just recorded. Salaried users and any
            // user not in TcEmployees only get the AttendanceTransaction row.
            // Safety-first: a payroll failure produces a soft warning — the
            // AttendanceTransaction is already committed, so the user is not
            // blocked. They can self-correct on /my/timesheet via the Phase A
            // inline-edit workflow.
            payrollWarning = "";
            if (needsTimePunch)
            {
                try
                {
                    var punchResult = await TimePunchService.ProcessPunchAsync(new PunchRequest
                    {
                        IdNumber       = staffIdNumber,
                        CampusId       = nearestCampusId.Value,
                        Latitude       = latestLatitude,
                        Longitude      = latestLongitude,
                        ScanMethod     = "GPS_MOBILE",
                        IsMobileMode   = true,
                        PunchSubType   = earlyOutReason,
                        PunchSource    = AuditSource.Mobile
                    });
                    if (!punchResult.Success)
                    {
                        payrollWarning = $"Payroll record did not save ({punchResult.Message}). Use My Timesheet to request a correction.";
                        Logger.LogWarning("Mobile dual-write: TcTimePunch failed for {IdNumber} at campus {CampusId}. Attendance row committed. Result: {Message} / {ErrorCode}",
                            staffIdNumber, nearestCampusId.Value, punchResult.Message, punchResult.ErrorCode);
                    }
                }
                catch (Exception pex)
                {
                    payrollWarning = "Payroll record did not save. Use My Timesheet to request a correction.";
                    Logger.LogError(pex, "Mobile dual-write: TcTimePunch threw for {IdNumber} at campus {CampusId}. Attendance row committed.",
                        staffIdNumber, nearestCampusId.Value);
                }
            }

            isSuccess = true;
            lastCheckType = nextActionIsCheckIn ? "IN" : "OUT";
            var now = DateTime.Now;
            var greeting = GetGreeting(now.Hour);
            resultMessage = nextActionIsCheckIn
                ? $"Good {greeting}, {staffFirstName}!"
                : $"Goodbye, {staffFirstName}!";
            showResult = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error processing checkin");
            isSuccess = false;
            resultMessage = "Error processing";
            showResult = true;
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private void ResetForNext()
    {
        showResult = false;
        lastCheckType = "";
        resultMessage = "";
        payrollWarning = "";
        isSuccess = false;
        _ = Task.Run(async () =>
        {
            await LoadCurrentStatus();
            await InvokeAsync(StateHasChanged);
        });
    }

    // ── Early-out helpers ────────────────────────────────────────────────

    private async Task<bool> ShouldPromptEarlyOut(TimeClockDbContext context, int campusId, EmployeeShift shift = EmployeeShift.Day)
    {
        var now = DateTime.Now;
        var nowTime = TimeOnly.FromDateTime(now);
        var today = now.DayOfWeek;

        if (today == DayOfWeek.Saturday || today == DayOfWeek.Sunday) return false;

        var windows = await context.TcStaffHoursWindows.AsNoTracking()
            .Where(w => w.CampusId == campusId && w.IsActive)
            .ToListAsync();

        foreach (var w in windows)
        {
            if (w.SessionType == "NIGHT" && today == DayOfWeek.Friday) continue;

            // Only check windows that match the employee's shift
            if (shift == EmployeeShift.Day     && w.SessionType != "DAY")   continue;
            if (shift == EmployeeShift.Evening && w.SessionType != "NIGHT") continue;
            // EmployeeShift.Both: check all windows (no filter)

            if (nowTime >= w.ExpectedArrivalTime && nowTime < w.ExpectedDepartureTime)
                return true;
        }
        return false;
    }

    private void SelectEarlyOutReason(string code)
    {
        selectedEarlyOutReason = code;
        StateHasChanged();
    }

    private async Task<string?> ShowEarlyOutPrompt()
    {
        selectedEarlyOutReason = null;
        earlyOutCountdown = 10;
        earlyOutTcs = new TaskCompletionSource<string?>();
        showEarlyOutModal = true;
        StateHasChanged();

        earlyOutTimer = new System.Timers.Timer(1000);
        earlyOutTimer.Elapsed += async (s, e) =>
        {
            earlyOutCountdown--;
            if (earlyOutCountdown <= 0)
            {
                earlyOutTimer?.Stop();
                earlyOutTimer?.Dispose();
                earlyOutTimer = null;
                earlyOutTcs.TrySetResult(selectedEarlyOutReason);
            }
            try { await InvokeAsync(StateHasChanged); } catch { }
        };
        earlyOutTimer.Start();

        return await earlyOutTcs.Task;
    }

    private async Task SubmitEarlyOut(string? reason)
    {
        earlyOutTimer?.Stop();
        earlyOutTimer?.Dispose();
        earlyOutTimer = null;
        earlyOutTcs?.TrySetResult(reason);
        showEarlyOutModal = false;
        StateHasChanged();
        await Task.CompletedTask;
    }

    // ──────────────────────────────────────────────────────────────────────

    private static string GetGreeting(int hour) =>
        hour < 12 ? "morning" : hour < 17 ? "afternoon" : "evening";

    public ValueTask DisposeAsync()
    {
        clockTimer?.Stop();
        clockTimer?.Dispose();
        earlyOutTimer?.Stop();
        earlyOutTimer?.Dispose();
        return ValueTask.CompletedTask;
    }

    private class LocResult
    {
        public double Latitude { get; set; }
        public double Longitude { get; set; }
        public double Accuracy { get; set; }
    }
}
