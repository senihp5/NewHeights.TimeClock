@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated != true)
        {
            Nav.NavigateTo("MicrosoftIdentity/Account/SignIn", forceLoad: true);
            return;
        }

        // Detect mobile device
        bool isMobile = false;
        try
        {
            var ua = await JS.InvokeAsync<string>("getUserAgent");
            isMobile = System.Text.RegularExpressions.Regex.IsMatch(ua,
                @"Android|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini",
                System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        }
        catch { }

        // Hourly employees (full- and part-time) and substitutes -> Mobile Clock.
        // Keep this role list in lockstep with Program.cs RequireHourly policy.
        if (user.IsInRole("TimeClock.Employee") ||
            user.IsInRole("TimeClock.Employee.StopSix") ||
            user.IsInRole("TimeClock.Employee.McCart") ||
            user.IsInRole("TimeClock.Employee.StopSix.PT") ||
            user.IsInRole("TimeClock.Employee.McCart.PT") ||
            user.IsInRole("TimeClock.Substitute"))
        {
            Nav.NavigateTo("/mobile/clock", forceLoad: false);
            return;
        }

        // Supervisors -> Home dashboard
        if (user.IsInRole("TimeClock.Supervisor") ||
            user.IsInRole("TimeClock.Supervisor.StopSix") ||
            user.IsInRole("TimeClock.Supervisor.McCart"))
        {
            Nav.NavigateTo("/", forceLoad: false);
            return;
        }

        // HR staff -> Home dashboard
        if (user.IsInRole("TimeClock.HR"))
        {
            Nav.NavigateTo("/", forceLoad: false);
            return;
        }

        // Campus admins -> Home dashboard
        if (user.IsInRole("TimeClock.CampusAdmin"))
        {
            Nav.NavigateTo("/", forceLoad: false);
            return;
        }

        // AllStaff (salaried) on mobile -> Campus Check-In
        if (user.IsInRole("TimeClock.AllStaff") && isMobile)
        {
            Nav.NavigateTo("/mobile/checkin", forceLoad: false);
            return;
        }

        // AllStaff on desktop -> Home
        if (user.IsInRole("TimeClock.AllStaff"))
        {
            Nav.NavigateTo("/", forceLoad: false);
            return;
        }

        // Authenticated but no TimeClock group -> Access Denied
        Nav.NavigateTo("/access-denied", forceLoad: false);
    }
}
