@using NewHeights.TimeClock.Shared.Constants
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

<div class="top-row navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">
            <img src="images/NHLogo.png" alt="New Heights" class="nav-logo" />
            <span class="nav-brand-text">@AppConstants.Branding.ShortName</span>
        </a>
    </div>
</div>

<div class="nav-scrollable">
    <nav class="flex-column">

        <AuthorizeView Policy="RequireAdmin">
            <div class="nav-item px-2">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">Home</NavLink>
            </div>
        </AuthorizeView>

        <AuthorizeView Policy="RequireAnyStaff" Context="mobileCtx">
            <details class="nav-section-group" open>
                <summary class="nav-section">Mobile</summary>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="mobile/checkin">Campus Check-In</NavLink>
                </div>
                @* Substitute Request + My Sub Requests are teacher/staff-absence
                   flows ("I'm going to be out, find me a sub"). Substitutes
                   don't request subs for themselves — they COVER classes —
                   so both links are hidden from the Substitute role. Subs
                   instead see My Assignments below. *@
                @if (!mobileCtx.User.Claims.Any(c => c.Type == ClaimTypes.Role && c.Value.StartsWith("TimeClock.Substitute", StringComparison.OrdinalIgnoreCase)))
                {
                    <div class="nav-item px-2">
                        <NavLink class="nav-link" href="employee/absence-request">Substitute Request</NavLink>
                    </div>
                    <div class="nav-item px-2">
                        <NavLink class="nav-link" href="employee/my-sub-requests">My Sub Requests</NavLink>
                    </div>
                }
                @if (mobileCtx.User.Claims.Any(c => c.Type == ClaimTypes.Role && c.Value.StartsWith("TimeClock.Substitute", StringComparison.OrdinalIgnoreCase)))
                {
                    <div class="nav-item px-2">
                        <NavLink class="nav-link" href="sub/my-assignments">My Assignments</NavLink>
                    </div>
                }
            </details>
        </AuthorizeView>

        <AuthorizeView Policy="RequireHourly" Context="hourlyCtx">
            <div class="nav-item px-2">
                <NavLink class="nav-link" href="mobile/checkin">Mobile Check-In</NavLink>
            </div>
        </AuthorizeView>

        @* My Timesheet / My Sub Timesheet — only users who actually clock in.
           RequireHourly (Employee* variants + Substitute + Admin) gates this
           section so salaried teachers, AllStaff, HR, Reception, and District
           roles don't see a link that leads to an empty page. A receptionist
           who is also in an Employee PT group will pass RequireHourly and
           see their timesheet link; receptionists who don't punch the clock
           won't. *@
        <AuthorizeView Policy="RequireHourly" Context="myTimeCtx">
            <details class="nav-section-group" open>
                <summary class="nav-section">My Time</summary>
                @if (myTimeCtx.User.Claims.Any(c => c.Type == ClaimTypes.Role && c.Value.StartsWith("TimeClock.Substitute", StringComparison.OrdinalIgnoreCase)))
                {
                    <div class="nav-item px-2">
                        <NavLink class="nav-link" href="my/sub-timesheet">My Sub Timesheet</NavLink>
                    </div>
                }
                else
                {
                    <div class="nav-item px-2">
                        <NavLink class="nav-link" href="my/timesheet">My Timesheet</NavLink>
                    </div>
                }
            </details>
        </AuthorizeView>

        <AuthorizeView Policy="RequireSupervisor">
            <details class="nav-section-group" open>
                <summary class="nav-section">Supervisor</summary>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="supervisor/timesheets">Team Timesheets</NavLink>
                </div>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="supervisor/sub-timesheets">Sub Timesheets</NavLink>
                </div>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="supervisor/sub-requests">Sub Requests</NavLink>
                </div>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="supervisor/sub-calendar">Sub Calendar</NavLink>
                </div>
            </details>
        </AuthorizeView>

        @* Reception Sub Requests — moved here from the Dashboards section so it
           groups visually with the Supervisor 'Sub Requests' link. Scoped by
           RequireReception so reception-only users (non-supervisors) still see
           it. Flat single-item link, not inside a collapsible group. *@
        <AuthorizeView Policy="RequireReception">
            <div class="nav-item px-2">
                <NavLink class="nav-link" href="reception/sub-requests">Reception Sub Requests</NavLink>
            </div>
        </AuthorizeView>

        <AuthorizeView Policy="RequireHR">
            <details class="nav-section-group" open>
                <summary class="nav-section">HR</summary>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="hr/payroll">Payroll Review</NavLink>
                </div>
            </details>
        </AuthorizeView>

        <AuthorizeView Policy="RequireSupervisor">
            <details class="nav-section-group" open>
                <summary class="nav-section">Reports</summary>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="reports/safety">Safety Report</NavLink>
                </div>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="reports/timeclock">TimeClock Report</NavLink>
                </div>
            </details>
        </AuthorizeView>

        <AuthorizeView Policy="RequireReception">
            <details class="nav-section-group" open>
                <summary class="nav-section">Dashboards</summary>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="reception" Match="NavLinkMatch.All">Reception</NavLink>
                </div>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="safety" Match="NavLinkMatch.All">Safety</NavLink>
                </div>
            </details>
        </AuthorizeView>

        <AuthorizeView Policy="RequireAdmin">
            <details class="nav-section-group" open>
                <summary class="nav-section">Admin</summary>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="admin/pay-periods">Pay Periods</NavLink>
                </div>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="admin/staff-hours">Staff Hours Windows</NavLink>
                </div>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="admin/holidays">Holiday Schedule</NavLink>
                </div>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="admin/bell-schedules">Bell Schedules</NavLink>
                </div>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="admin/timecard-recalc">Timecard Recalc</NavLink>
                </div>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="admin/hourly-csv-import">Hourly CSV Import</NavLink>
                </div>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="admin/sub-paper-entry">Sub Paper Entry</NavLink>
                </div>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="admin/email-test">Email Test</NavLink>
                </div>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="admin/employees/sync">Employee Sync</NavLink>
                </div>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="admin/employees/add">Add Employee (Manual)</NavLink>
                </div>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="admin/schedule/import">Schedule Import</NavLink>
                </div>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="admin/audit">Audit Log</NavLink>
                </div>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="admin/sub-pool-management">Sub Pool Management</NavLink>
                </div>
            </details>
        </AuthorizeView>

    </nav>
</div>
